---
// src/layouts/Layout.astro
export interface Props {
  title: string;
  description?: string;
  showFooter?: boolean; // ✅ ADD THIS
}
import Header from "../components/Header.astro";
const {
  title,
  description = "Tech Engineer - Community for developers",
  showFooter = true, // ✅ ADD THIS with default
} = Astro.props;
const userIsLoggedIn = false;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/assets/icon.png" />
  </head>
  <body>
    <Header isLoggedIn={userIsLoggedIn} />
    <div class="main-content">
      <slot />
    </div>
    {/* ✅ Conditionally show footer */}
    {
      showFooter && (
        <footer>
          <p>© 2024 Tech Engineer. All rights reserved.</p>
        </footer>
      )
    }
  </body>
</html>
<style>
  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    background-color: #f1f2f2;
    font-family: sans-serif;
  }
  /* ✅ NEW: Push content below fixed header */
  .main-content {
    padding-top: 60px; /* Same as your header height */
    min-height: calc(100vh - 60px);
  }
</style>
