---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  imageIsSquare?: boolean; // ← ADD THIS LINE

  showFooter?: boolean;
}

import Header from "../components/Header.astro";

const {
  title,
  description = "Tech Engineer - Community for developers to ask, answer, and grow together.",
  image = "/assets/icon.png",
  showFooter = true,
  imageIsSquare = true,
} = Astro.props;
``;

const siteUrl = "https://forum.techengineer.co";
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const socialImageURL = new URL(image, siteUrl);

// ✅ Smart card type: square avatars use "summary", landscape images use "summary_large_image"
const isDefaultImage = image === "/assets/icon.png" || !image;
const twitterCardType = isDefaultImage
  ? "summary"
  : imageIsSquare
    ? "summary"
    : "summary_large_image";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/assets/icon.png" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook / WhatsApp -->
    <!-- Open Graph / Facebook / WhatsApp -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Tech Engineer" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <!-- ✅ ALWAYS include og:image (even if default) -->
    <meta property="og:image" content={socialImageURL} />
    {imageIsSquare && <meta property="og:image:width" content="200" />}
    {imageIsSquare && <meta property="og:image:height" content="200" />}
    {!imageIsSquare && <meta property="og:image:width" content="1200" />}
    {!imageIsSquare && <meta property="og:image:height" content="630" />}
    <!-- Twitter -->
    <meta property="twitter:card" content={twitterCardType} />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <!-- ✅ ALWAYS include twitter:image (even if default) -->
    <meta property="twitter:image" content={socialImageURL} />

    <!-- Google Search Verification -->
    <meta
      name="google-site-verification"
      content="z6HubTvD3dO5bo7HxpvtRl86cKQdCBsBh65kavbq0ZM"
    />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Firebase SDKs -->
    <script
      src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"
    ></script>
    <script
      src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"
    ></script>
  </head>

  <body>
    <Header isLoggedIn={false} />

    <div class="main-content">
      <slot />
    </div>

    {
      showFooter && (
        <footer class="site-footer">
          <div class="footer-inner">
            <div class="footer-brand">
              <div class="footer-logo">
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="16 18 22 12 16 6" />
                  <polyline points="8 6 2 12 8 18" />
                </svg>
                <span>Tech Engineer</span>
              </div>
              <p class="footer-tagline">
                Community for developers to ask, answer, and grow together.
              </p>
            </div>

            <div class="footer-links-grid">
              <div class="footer-col">
                <h4 class="footer-col-title">Platform</h4>
                <ul>
                  <li>
                    <a href="/">Home</a>
                  </li>
                  <li>
                    <a href="/question">Questions</a>
                  </li>
                  <li>
                    <a href="/user">Users</a>
                  </li>
                </ul>
              </div>
              <div class="footer-col">
                <h4 class="footer-col-title">Courses</h4>
                <ul>
                  <li>
                    <a href="https://techengineer.co/video-editing-course-mohali-chandigarh">
                      Video Editing
                    </a>
                  </li>
                  <li>
                    <a href="https://techengineer.co/ai-machine-learning-course-mohali">
                      AI & Machine Learning
                    </a>
                  </li>
                  <li>
                    <a href="https://techengineer.co">All Courses</a>
                  </li>
                </ul>
              </div>
              <div class="footer-col">
                <h4 class="footer-col-title">Connect</h4>
                <ul>
                  <li>
                    <a
                      href="http://www.facebook.com/people/TechEngineer/100083472395433/"
                      target="_blank"
                      rel="noopener"
                    >
                      Facebook
                    </a>
                  </li>
                  <li>
                    <a
                      href="https://x.com/TechEngineer115"
                      target="_blank"
                      rel="noopener"
                    >
                      X (Twitter)
                    </a>
                  </li>
                  <li>
                    <a
                      href="https://www.youtube.com/@TechEngineerAI/"
                      target="_blank"
                      rel="noopener"
                    >
                      YouTube
                    </a>
                  </li>
                  <li>
                    <a
                      href="https://www.instagram.com/techengineer_ai/"
                      target="_blank"
                      rel="noopener"
                    >
                      Instagram
                    </a>
                  </li>
                  <li>
                    <a
                      href="https://wa.me/918544884846"
                      target="_blank"
                      rel="noopener"
                    >
                      WhatsApp
                    </a>
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <div class="footer-bottom">
            <p>&copy; 2026 Tech Engineer. All rights reserved.</p>
          </div>
        </footer>
      )
    }

    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        width: 100%;
        background-color: #f1f2f2;
        font-family:
          "Inter",
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      .main-content {
        padding-top: 60px;
        min-height: calc(100vh - 60px);
      }
      .site-footer {
        background: #1a1a2e;
        color: #c4c4d4;
        margin-top: 40px;
      }
      .footer-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 48px 24px 32px;
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 48px;
      }
      @media (max-width: 700px) {
        .footer-inner {
          grid-template-columns: 1fr;
          gap: 32px;
        }
      }
      .footer-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #fff;
        font-size: 18px;
        font-weight: 800;
        margin-bottom: 12px;
      }
      .footer-logo svg {
        color: #2e69ff;
      }
      .footer-tagline {
        font-size: 14px;
        line-height: 1.6;
        color: #8888a4;
        max-width: 280px;
      }
      .footer-links-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }
      @media (max-width: 500px) {
        .footer-links-grid {
          grid-template-columns: 1fr 1fr;
        }
      }
      .footer-col-title {
        font-size: 13px;
        font-weight: 700;
        color: #fff;
        text-transform: uppercase;
        margin-bottom: 14px;
      }
      .footer-col ul {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .footer-col a {
        color: #8888a4;
        text-decoration: none;
        font-size: 14px;
      }
      .footer-col a:hover {
        color: #2e69ff;
      }
      .footer-bottom {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        padding: 18px 24px;
        text-align: center;
      }
    </style>

    <script>
      // We attach this to window so the inline script can see it
      (window as any).syncLoginState = function () {
        const isLoggedIn = !!localStorage.getItem("userId");
        const header = document.querySelector(".header") as HTMLElement;
        if (!header) return;

        header.setAttribute("data-logged-in", isLoggedIn ? "true" : "false");

        const loginBtn = header.querySelector(".login-btn") as HTMLElement;
        const userMenu = header.querySelector(".user-menu") as HTMLElement;
        const userName = header.querySelector(".user-name") as HTMLElement;
        const userAvatar = header.querySelector(
          ".user-avatar",
        ) as HTMLImageElement;

        if (isLoggedIn) {
          if (loginBtn) loginBtn.style.display = "none";
          if (userMenu) userMenu.style.display = "flex";
          if (userName)
            userName.textContent =
              localStorage.getItem("currentUser") || "User";
          if (userAvatar) {
            const avatar = localStorage.getItem("userAvatar");
            if (avatar && avatar !== "icon.png" && avatar !== "null") {
              userAvatar.src =
                avatar.startsWith("http") || avatar.startsWith("data:")
                  ? avatar
                  : `/assets/${avatar}`;
            }
          }
        } else {
          if (loginBtn) loginBtn.style.display = "inline-flex";
          if (userMenu) userMenu.style.display = "none";
        }
      };

      // Initial runs
      (window as any).syncLoginState();
      window.addEventListener("load", (window as any).syncLoginState);
      window.addEventListener("storage", (window as any).syncLoginState);
    </script>

    <!-- REPLACE BOTH OLD SCRIPTS WITH THIS ONE -->
    <script is:inline>
      document.addEventListener("DOMContentLoaded", function () {
        var checkFirebase = setInterval(function () {
          if (typeof firebase !== "undefined" && firebase.auth) {
            clearInterval(checkFirebase);

            var GOOGLE_SHEET_URL =
              "https://script.google.com/macros/s/AKfycbwfpjk3Y2gzDt0T_JS7c2OhQajr_UildmeqEgQVPQxIFAjYnYG8alaQF0XmGjeI-_uzkQ/exec";

            firebase.auth().onAuthStateChanged(function (user) {
              // If Firebase says logged in, but localStorage is empty (e.g., user cleared cache)
              if (user && !localStorage.getItem("userId")) {
                var email = user.email || user.uid + "@social-login";
                var name = user.displayName || "";
                var avatar = user.photoURL || "";

                // Call the backend to properly restore their onboarding state
                fetch(GOOGLE_SHEET_URL, {
                  method: "POST",
                  body: JSON.stringify({
                    action: "loginUser",
                    email: email,
                    name: name,
                    avatar: avatar,
                    authProvider: "Session",
                  }),
                })
                  .then(function (res) {
                    return res.json();
                  })
                  .then(function (data) {
                    if (data.status === "success") {
                      var dbUser = data.user;
                      localStorage.setItem("userId", dbUser.id);
                      localStorage.setItem("userEmail", dbUser.email);
                      localStorage.setItem("currentUser", dbUser.name);
                      localStorage.setItem("username", dbUser.username);
                      localStorage.setItem("userAvatar", dbUser.avatar);
                      localStorage.setItem(
                        "isProfileComplete",
                        String(data.isProfileComplete),
                      );

                      // Reload so the Header reads the new localStorage and skips the setup modal
                      window.location.reload();
                    }
                  });
              }
            });
          }
        }, 200);
      });

      // Updated Logout to clear the new localStorage items
      window.logout = function () {
        if (typeof firebase !== "undefined" && firebase.auth)
          firebase.auth().signOut();

        localStorage.removeItem("userId");
        localStorage.removeItem("userEmail");
        localStorage.removeItem("currentUser");
        localStorage.removeItem("username");
        localStorage.removeItem("userInterests");
        localStorage.removeItem("userRole");
        localStorage.removeItem("userAvatar");
        localStorage.removeItem("isProfileComplete");

        window.location.reload();
      };
    </script>
  </body>
</html>
