---
// src/components/SpaceCard.astro
const { name, followers, desc, icon } = Astro.props;
---

<div class="space-card">
    <div class="space-info">
        <div class="space-icon">{icon}</div>
        <div class="space-text">
            <h4 class="space-name">{name}</h4>
            <p class="space-stats">{followers} followers</p>
            <p class="space-desc">{desc}</p>
        </div>
    </div>
    <button class="follow-btn">
        <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
        >
            <path d="M12 5v14M5 12h14"></path>
        </svg>
    </button>
</div>

<style>
    .space-card {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 15px;
        border-bottom: 1px solid #eee;
        background: white;
    }
    .space-card:hover {
        background-color: #fafafa;
    }

    .space-info {
        display: flex;
        gap: 12px;
    }
    .space-icon {
        width: 40px;
        height: 40px;
        background: #eee;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: #666;
        font-size: 12px;
        flex-shrink: 0;
    }

    .space-name {
        margin: 0;
        font-size: 15px;
        color: #282829;
    }
    .space-stats {
        margin: 2px 0;
        font-size: 12px;
        color: #939598;
    }
    .space-desc {
        margin: 4px 0 0 0;
        font-size: 13px;
        color: #636466;
        line-height: 1.4;
    }

    .follow-btn {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 1px solid #dee0e1;
        background: none;
        color: #2e69ff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .follow-btn:hover {
        background: #f0f5ff;
    }
</style>