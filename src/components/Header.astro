<script>
  const GOOGLE_SHEET_URL =
    "https://script.google.com/macros/s/AKfycbywCeoEu7CNLZtgRKyy4wsnvGw8B6wpNrP5ke0RoJ6XrVfwgsmBKAlIKvli79IVAWQJxQ/exec";

  // Cleanup old data
  if (localStorage.getItem("recentQuestion")) {
    localStorage.removeItem("recentQuestion");
  }

  // ====== ELEMENTS ======
  const askBtn = document.getElementById("askBtn") as HTMLButtonElement;
  const loginModal = document.getElementById("loginModal") as HTMLDivElement;
  const interestModal = document.getElementById(
    "interestModal",
  ) as HTMLDivElement;
  const closeModal = document.getElementById("closeModal") as HTMLButtonElement;
  const saveInterestsBtn = document.getElementById(
    "saveInterestsBtn",
  ) as HTMLButtonElement;
  const guestIcon = document.getElementById("guest-icon") as HTMLDivElement;
  const userAvatar = document.getElementById("user-avatar") as HTMLImageElement;
  const questionModal = document.getElementById(
    "question-modal",
  ) as HTMLDialogElement;
  const mobileSearchBtn = document.getElementById(
    "mobileSearchBtn",
  ) as HTMLButtonElement;
  const mobileSearchBar = document.getElementById(
    "mobileSearchBar",
  ) as HTMLDivElement;
  const mobileSearchClose = document.getElementById(
    "mobileSearchClose",
  ) as HTMLButtonElement;
  const menuToggle = document.getElementById("menuToggle") as HTMLButtonElement;
  const mobileMenu = document.getElementById("mobileMenu") as HTMLDivElement;
  const mobileOverlay = document.getElementById(
    "mobileOverlay",
  ) as HTMLDivElement;
  const closeMenuBtn = document.getElementById(
    "closeMenu",
  ) as HTMLButtonElement;
  const profileTrigger = document.getElementById(
    "profile-trigger",
  ) as HTMLDivElement;
  const userDropdown = document.getElementById(
    "userDropdown",
  ) as HTMLDivElement;
  const signOutBtn = document.getElementById("signOutBtn") as HTMLButtonElement;
  const displayUserName = document.getElementById(
    "displayUserName",
  ) as HTMLElement;

  // ====== TOPICS DATA ======
  const availableTopics = [
    "Full-Stack Development",
    "JavaScript & Frameworks",
    "Python & Data Science",
    "Web Performance & SEO",
    "DevOps & Cloud (AWS)",
    "Cybersecurity & InfoSec",
    "Open Source Projects",
    "Mobile App Dev",
    "Bug Fixes & Debugging",
    "UI/UX Design",
    "AI & Machine Learning",
    "Data Structures & Algorithms",
  ];
  let selectedTopics: string[] = [];

  const topicGrid = document.getElementById("topicGrid");
  availableTopics.forEach((topic) => {
    const chip = document.createElement("div");
    chip.className = "topic-chip";
    chip.innerText = topic;
    chip.addEventListener("click", () => {
      chip.classList.toggle("active");
      if (chip.classList.contains("active")) {
        selectedTopics.push(topic);
      } else {
        selectedTopics = selectedTopics.filter((t) => t !== topic);
      }
      if (saveInterestsBtn)
        saveInterestsBtn.disabled = selectedTopics.length === 0;
    });
    topicGrid?.appendChild(chip);
  });

  // ====== CHECK EXISTING LOGIN ======
  function checkExistingLogin() {
    const savedId = localStorage.getItem("userId");
    const savedName = localStorage.getItem("currentUser");
    const savedAvatar = localStorage.getItem("userAvatar");

    if (savedId && savedName) {
      askBtn?.setAttribute("data-logged-in", "true");
      guestIcon?.classList.add("hidden");
      userAvatar?.classList.remove("hidden");
      if (displayUserName) displayUserName.innerText = savedName;
      if (savedAvatar && userAvatar) {
        userAvatar.src =
          savedAvatar.startsWith("http") || savedAvatar.startsWith("data:")
            ? savedAvatar
            : `/assets/${savedAvatar}`;
      }
      // Update mobile profile link
      const mobileProfileLink = document.getElementById(
        "mobileProfileLink",
      ) as HTMLAnchorElement;
      if (mobileProfileLink) {
        mobileProfileLink.href = `/user?name=${encodeURIComponent(savedName)}`;
      }
    }
  }
  checkExistingLogin();

  // ====== MOBILE MENU ======
  function openMobileMenu() {
    mobileMenu?.classList.add("active");
    mobileOverlay?.classList.add("active");
    menuToggle?.classList.add("active");
    document.body.style.overflow = "hidden";
  }
  function closeMobileMenu() {
    mobileMenu?.classList.remove("active");
    mobileOverlay?.classList.remove("active");
    menuToggle?.classList.remove("active");
    document.body.style.overflow = "";
  }
  menuToggle?.addEventListener("click", openMobileMenu);
  closeMenuBtn?.addEventListener("click", closeMobileMenu);
  mobileOverlay?.addEventListener("click", closeMobileMenu);

  // ====== MOBILE SEARCH ======
  mobileSearchBtn?.addEventListener("click", () => {
    mobileSearchBar?.classList.add("active");
    setTimeout(() => {
      (
        document.getElementById("mobileSearchInput") as HTMLInputElement
      )?.focus();
    }, 100);
  });
  mobileSearchClose?.addEventListener("click", () => {
    mobileSearchBar?.classList.remove("active");
  });

  // ====== ASK BUTTON ======
  askBtn?.addEventListener("click", () => {
    const isLoggedIn = askBtn.getAttribute("data-logged-in") === "true";
    if (isLoggedIn) {
      questionModal?.showModal();
    } else {
      loginModal?.classList.add("active");
    }
  });

  // ====== FIREBASE SOCIAL LOGIN ======
  const firebase = (window as any).firebase;
  let currentAuthEmail = "";
  let currentAuthPhoto = "";

  if (firebase) {
    const firebaseConfig = {
      apiKey: "AIzaSyBNiy6oIGpqDhNKP345-QrhxQ9jKEvTMZI",
      authDomain: "forums-techengineer.firebaseapp.com",
      projectId: "forums-techengineer",
      storageBucket: "forums-techengineer.firebasestorage.app",
      messagingSenderId: "283633017019",
      appId: "1:283633017019:web:a8bd10bd207e753543899e",
    };
    firebase.initializeApp(firebaseConfig);
    const auth = firebase.auth();

    async function handleSocialLogin(provider: any) {
      try {
        const result = await auth.signInWithPopup(provider);
        const user = result.user;
        if (user) {
          const email = user.email || `${user.uid}@social-login`;
          const userName = user.displayName || "";
          const userPhoto = user.photoURL || "";

          const checkResponse = await fetch(
            `${GOOGLE_SHEET_URL}?action=checkUser&email=${encodeURIComponent(email)}`,
          );
          const userData = await checkResponse.json();

          if (userData.isNew) {
            currentAuthEmail = email;
            currentAuthPhoto = userPhoto;
            (document.getElementById("setupName") as HTMLInputElement).value =
              userName;
            loginModal?.classList.remove("active");
            document
              .getElementById("profileSetupModal")
              ?.classList.add("active");
          } else {
            localStorage.setItem("userId", email);
            localStorage.setItem("currentUser", userData.name || userName);
            localStorage.setItem("userRole", userData.role || "Tech Engineer");
            localStorage.setItem("userInterests", userData.interests || "");
            if (userData.avatar || userPhoto)
              localStorage.setItem("userAvatar", userData.avatar || userPhoto);

            loginModal?.classList.remove("active");
            window.dispatchEvent(new CustomEvent("user-logged-in"));
            updateUIAfterLogin(
              userData.name || userName,
              userData.avatar || userPhoto,
            );
          }
        }
      } catch (error: any) {
        if (error.code !== "auth/popup-closed-by-user") {
          console.error("Login Error:", error);
        }
      }
    }

    document.getElementById("googleLoginBtn")?.addEventListener("click", () => {
      const provider = new firebase.auth.GoogleAuthProvider();
      handleSocialLogin(provider);
    });
    document.getElementById("githubLoginBtn")?.addEventListener("click", () => {
      const provider = new firebase.auth.GithubAuthProvider();
      handleSocialLogin(provider);
    });
  }

  function updateUIAfterLogin(displayName: string, photoURL: string | null) {
    if (displayUserName) displayUserName.innerText = displayName;
    askBtn?.setAttribute("data-logged-in", "true");
    guestIcon?.classList.add("hidden");
    userAvatar?.classList.remove("hidden");
    if (photoURL && userAvatar) {
      userAvatar.src = photoURL;
      localStorage.setItem("userAvatar", photoURL);
    }
    const mobileProfileLink = document.getElementById(
      "mobileProfileLink",
    ) as HTMLAnchorElement;
    if (mobileProfileLink) {
      mobileProfileLink.href = `/user?name=${encodeURIComponent(displayName)}`;
    }
  }

  // ====== PROFILE SETUP ======
  document
    .getElementById("saveProfileBtn")
    ?.addEventListener("click", async () => {
      const btn = document.getElementById(
        "saveProfileBtn",
      ) as HTMLButtonElement;
      const name = (
        document.getElementById("setupName") as HTMLInputElement
      ).value.trim();
      const role = (
        document.getElementById("setupRole") as HTMLInputElement
      ).value.trim();

      if (!name) {
        alert("Please enter a name");
        return;
      }

      if (btn) {
        btn.classList.add("loading");
        btn.disabled = true;
      }

      try {
        await fetch(GOOGLE_SHEET_URL, {
          method: "POST",
          body: JSON.stringify({
            action: "saveProfile",
            email: currentAuthEmail,
            name: name,
            role: role || "Tech Engineer",
            avatar: currentAuthPhoto,
            authProvider: "google",
          }),
        });

        localStorage.setItem("userId", currentAuthEmail);
        localStorage.setItem("currentUser", name);
        localStorage.setItem("userRole", role || "Tech Engineer");
        if (currentAuthPhoto)
          localStorage.setItem("userAvatar", currentAuthPhoto);

        document
          .getElementById("profileSetupModal")
          ?.classList.remove("active");
        interestModal?.classList.add("active");
      } catch (error) {
        console.error("Error saving profile:", error);
      } finally {
        if (btn) {
          btn.classList.remove("loading");
          btn.disabled = false;
        }
      }
    });

  // ====== SAVE INTERESTS ======
  saveInterestsBtn?.addEventListener("click", async () => {
    const interestsString = selectedTopics.join(", ");
    const emailToSave = currentAuthEmail || localStorage.getItem("userId");

    if (saveInterestsBtn) {
      saveInterestsBtn.innerText = "Saving...";
      saveInterestsBtn.disabled = true;
    }

    try {
      await fetch(GOOGLE_SHEET_URL, {
        method: "POST",
        body: JSON.stringify({
          action: "saveProfile",
          email: emailToSave,
          interests: interestsString,
        }),
      });
      localStorage.setItem("userInterests", interestsString);
      interestModal?.classList.remove("active");

      if (currentAuthEmail) {
        document.getElementById("welcomeModal")?.classList.add("active");
      } else {
        questionModal?.showModal();
      }
    } catch (error) {
      console.error("Error saving topics:", error);
    } finally {
      if (saveInterestsBtn) {
        saveInterestsBtn.innerText = "Continue";
        saveInterestsBtn.disabled = false;
      }
    }
  });

  // ====== WELCOME DONE ======
  document.getElementById("welcomeDoneBtn")?.addEventListener("click", () => {
    document.getElementById("welcomeModal")?.classList.remove("active");
    updateUIAfterLogin(
      localStorage.getItem("currentUser") || "Guest",
      localStorage.getItem("userAvatar"),
    );
    window.dispatchEvent(new CustomEvent("user-logged-in"));
  });

  // ====== MODAL CLOSE ======
  closeModal?.addEventListener("click", () =>
    loginModal?.classList.remove("active"),
  );
  window.addEventListener("click", (e) => {
    if (e.target === loginModal) loginModal?.classList.remove("active");
    if (e.target === interestModal) interestModal?.classList.remove("active");
    if (e.target === document.getElementById("profileSetupModal")) {
      document.getElementById("profileSetupModal")?.classList.remove("active");
    }
    if (e.target === document.getElementById("welcomeModal")) {
      document.getElementById("welcomeModal")?.classList.remove("active");
    }
  });

  // ====== PROFILE DROPDOWN ======
  profileTrigger?.addEventListener("click", (e) => {
    e.stopPropagation();
    const isLoggedIn = askBtn?.getAttribute("data-logged-in") === "true";
    if (!isLoggedIn) {
      loginModal?.classList.add("active");
    } else {
      userDropdown?.classList.toggle("active");
    }
  });
  document.addEventListener("click", (e) => {
    if (!userDropdown?.contains(e.target as Node)) {
      userDropdown?.classList.remove("active");
    }
  });

  // ====== SIGN OUT ======
  signOutBtn?.addEventListener("click", () => {
    if (firebase) firebase.auth().signOut();
    localStorage.removeItem("userId");
    localStorage.removeItem("currentUser");
    localStorage.removeItem("userInterests");
    localStorage.removeItem("userRole");
    localStorage.removeItem("userAvatar");

    askBtn?.setAttribute("data-logged-in", "false");
    document.getElementById("guest-icon")?.classList.remove("hidden");
    document.getElementById("user-avatar")?.classList.add("hidden");
    userDropdown?.classList.remove("active");

    window.dispatchEvent(new CustomEvent("user-logged-out"));
    window.location.reload();
  });

  // ====== NOTIFICATION DOT ======
  async function checkNotifications() {
    const email = localStorage.getItem("userId");
    if (!email) return;
    try {
      const res = await fetch(
        `${GOOGLE_SHEET_URL}?action=getNotifications&email=${encodeURIComponent(email)}&filter=all`,
      );
      const notifs = await res.json();
      const hasUnread = notifs.some((n: any) => !n.isRead);
      document.querySelectorAll(".notif-dot").forEach((dot) => {
        if (hasUnread) dot.classList.add("has-notif");
        else dot.classList.remove("has-notif");
      });
    } catch (e) {}
  }
  checkNotifications();

  // ====== SEARCH LOGIC ======
  import { searchQuestions } from "../scripts/questionEngine";

  const searchInput = document.getElementById(
    "searchInput",
  ) as HTMLInputElement;
  const searchDropdown = document.getElementById(
    "searchDropdown",
  ) as HTMLElement;
  const searchResults = document.getElementById("searchResults") as HTMLElement;
  const mobileSearchInput = document.getElementById(
    "mobileSearchInput",
  ) as HTMLInputElement;
  const mobileSearchDropdown = document.getElementById(
    "mobileSearchDropdown",
  ) as HTMLElement;
  const mobileSearchResults = document.getElementById(
    "mobileSearchResults",
  ) as HTMLElement;

  function highlight(text: string, query: string): string {
    if (!query) return text;
    const words = query.split(" ").filter((w) => w.length > 2);
    let result = text;
    words.forEach((word) => {
      const regex = new RegExp(`(${word})`, "gi");
      result = result.replace(regex, "<mark>$1</mark>");
    });
    return result;
  }

  function renderResults(
    query: string,
    container: HTMLElement | null,
    dropdown: HTMLElement | null,
  ) {
    if (!container || !dropdown) return;
    const results = searchQuestions(query);
    if (!query.trim() || results.length === 0) {
      dropdown.classList.remove("active");
      return;
    }
    container.innerHTML = results
      .slice(0, 8)
      .map(
        (q: any) => `
        <a href="/question/${q.slug}" class="search-result-item">
          <div class="result-question">${highlight(q.question, query)}</div>
          <div class="result-snippet">${q.answers?.length || 0} answers</div>
        </a>
      `,
      )
      .join("");
    dropdown.classList.add("active");
  }

  searchInput?.addEventListener("input", (e) =>
    renderResults(
      (e.target as HTMLInputElement).value,
      searchResults,
      searchDropdown,
    ),
  );
  searchInput?.addEventListener("keypress", (e) => {
    if (e.key === "Enter") {
      const v = (e.target as HTMLInputElement).value.trim();
      if (v) window.location.href = `/search?q=${encodeURIComponent(v)}`;
    }
  });
  mobileSearchInput?.addEventListener("input", (e) =>
    renderResults(
      (e.target as HTMLInputElement).value,
      mobileSearchResults,
      mobileSearchDropdown,
    ),
  );
  mobileSearchInput?.addEventListener("keypress", (e) => {
    if (e.key === "Enter") {
      const v = (e.target as HTMLInputElement).value.trim();
      if (v) window.location.href = `/search?q=${encodeURIComponent(v)}`;
    }
  });
  document.addEventListener("click", (e) => {
    const t = e.target as Node;
    if (searchDropdown && !searchDropdown.contains(t) && t !== searchInput)
      searchDropdown.classList.remove("active");
    if (
      mobileSearchDropdown &&
      !mobileSearchDropdown.contains(t) &&
      t !== mobileSearchInput
    )
      mobileSearchDropdown.classList.remove("active");
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      searchDropdown?.classList.remove("active");
      mobileSearchDropdown?.classList.remove("active");
      closeMobileMenu();
    }
  });
</script>
