---
const {
  id,
  avatar,
  name,
  follow_enabled,
  role_name,
  updated_time,
  heading,
  description,
  images,
  upvotes,
  comments,
  shares,
  slug,
} = Astro.props;
import { formatContent } from "../utils/formatContent";

// ✅ Universal helper for both avatars AND post images
function getMediaUrl(url: string | null | undefined): string {
  if (!url || url === "icon.png" || url === "null" || url === "") {
    return "/assets/icon.png";
  }
  if (url.startsWith("data:")) return url;
  if (url.startsWith("http://") || url.startsWith("https://")) return url;
  if (url.startsWith("iVBOR") || url.startsWith("/9j/")) {
    return `data:image/png;base64,${url}`;
  }
  if (url.includes("googleusercontent.com") || url.includes("github.com")) {
    return url;
  }
  return `/assets/${url}`;
}

const displayUpvotes = upvotes;
const postSlug =
  slug ||
  heading
    .toLowerCase()
    .replace(/[^\w ]+/g, "")
    .replace(/ +/g, "-");

const authorAvatar = getMediaUrl(avatar);
---

<div class="post-card" data-id={id} data-slug={postSlug} data-heading={heading}>
  <!-- HEADER -->
  <div class="post-header">
    <img src={authorAvatar} alt={name} class="avatar" />
    <div class="header-main">
      <div class="header-top">
        <a href={`/user?name=${name}`} class="name">{name}</a>
        {
          follow_enabled && (
            <button
              class="follow-btn"
              data-author={name}
              onclick="window.toggleFollow(this)"
              type="button"
            >
              Follow
            </button>
          )
        }
      </div>
      <div class="header-sub">
        <span class="role">{role_name}</span>
        <span class="dot">•</span>
        <span class="time">{updated_time}</span>
      </div>
    </div>
  </div>

  <!-- BODY -->
  <div class="post-body">
    <a href={`/question/${postSlug}`} class="heading-link">
      <h2 class="heading" set:html={formatContent(heading)} />
    </a>
    <div class="description">
      <p class="description-text" set:html={formatContent(description)} />
      <button class="read-more" type="button" data-action="expand"
        >Read more</button
      >
      <button class="read-less hidden" type="button" data-action="collapse"
        >Show less</button
      >
    </div>
  </div>

  <!-- IMAGE GRID -->
  {
    images && images.length > 0 && (
      <div class={`post-images-grid grid-${Math.min(images.length, 4)}`}>
        {images.slice(0, 4).map((img: string, index: number) => {
          // ✅ FIX: Use getMediaUrl for post images
          const imgUrl = getMediaUrl(img);
          if (index === 3 && images.length > 4) {
            return (
              <div class="grid-item with-overlay">
                <img src={imgUrl} alt="" />
                <div class="more-count">+{images.length - 3}</div>
              </div>
            );
          }
          return (
            <div class="grid-item">
              <img src={imgUrl} alt="" />
            </div>
          );
        })}
      </div>
    )
  }

  <!-- FOOTER -->
  <div class="post-footer">
    <div class="vote-group">
      <button
        class="upvote-btn"
        data-count={displayUpvotes}
        aria-label="Upvote"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"></path></svg
        >
        <span class="btn-text"
          >Upvote · <span class="upvote-count"
            >{
              displayUpvotes >= 1000
                ? (displayUpvotes / 1000).toFixed(1) + "K"
                : displayUpvotes
            }</span
          ></span
        >
      </button>
      <button class="downvote-btn" aria-label="Downvote">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7"></path></svg
        >
      </button>
    </div>

    <button class="action-btn comment-toggle" aria-label="Comment">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
        ></path></svg
      >
      <span class="action-count">{comments}</span>
    </button>

    <button class="action-btn share-toggle" aria-label="Share">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline
          points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"
        ></line></svg
      >
      <span class="action-count">{shares}</span>
    </button>

    <button class="action-btn more-btn" aria-label="More options">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><circle cx="12" cy="12" r="1"></circle><circle cx="19" cy="12" r="1"
        ></circle><circle cx="5" cy="12" r="1"></circle></svg
      >
    </button>
  </div>

  <!-- COMMENTS DROPDOWN -->
  <div class="comments-section hidden">
    <div class="comments-list"></div>
    <div class="add-comment">
      <img src="/assets/icon.png" class="comment-avatar" alt="You" />
      <input type="text" class="comment-input" placeholder="Add a comment..." />
      <button class="comment-submit" type="button">Post</button>
    </div>
  </div>

  <!-- SHARE DROPDOWN -->
  <div class="share-section hidden">
    <div class="share-row">
      <button class="share-option" data-share="copy">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
          ></path><path
            d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
          ></path></svg
        >
        <span>Copy link</span>
      </button>
      <button class="share-option" data-share="twitter">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"
          ></path></svg
        >
        <span>Twitter</span>
      </button>
    </div>
    <div class="share-toast hidden">Link copied to clipboard!</div>
  </div>

  <!-- MORE OPTIONS DROPDOWN -->
  <div class="more-section hidden">
    <button class="more-option" data-action="save">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"
        ></path></svg
      >
      <span>Save</span>
    </button>
    <div class="more-divider"></div>
    <button class="more-option danger" data-action="report">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"
        ></path><line x1="4" y1="22" x2="4" y2="15"></line></svg
      >
      <span>Report</span>
    </button>
  </div>
</div>

<style is:global>
  /* 1. CONTAINER */
  .description-text .code-block {
    background: #1e1e1e;
    color: #d4d4d4;
    padding: 14px 18px;
    border-radius: 8px;
    overflow-x: auto;
    font-family: "Courier New", Courier, monospace;
    font-size: 13px;
    line-height: 1.5;
    margin: 10px 0;
    white-space: pre;
    border: 1px solid #333;
  }
  .description-text .inline-code {
    background: #f1f2f2;
    color: #b92b27;
    padding: 2px 6px;
    border-radius: 4px;
    font-family: "Courier New", Courier, monospace;
    font-size: 13px;
    font-weight: 500;
  }
  .post-card {
    background: white;
    border: 1px solid #e3e6ea;
    border-radius: 8px;
    padding: 16px;
    margin-bottom: 12px;
    transition: border-color 0.2s;
    overflow: hidden;
  }
  .post-card:hover {
    border-color: #ccd0d1;
  }

  /* 2. HEADER */
  .post-header {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 10px;
  }
  .avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background-color: #f7f7f7;
    object-fit: cover;
    flex-shrink: 0;
  }
  .header-main {
    flex: 1;
    min-width: 0;
  }
  .header-top {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .post-card[data-guest="true"] .upvote-btn,
  .post-card[data-guest="true"] .comment-toggle {
    position: relative;
  }
  .post-card[data-guest="true"] .upvote-btn::after,
  .post-card[data-guest="true"] .comment-toggle::after {
    content: "Login to interact";
    position: absolute;
    bottom: -25px;
    left: 50%;
    transform: translateX(-50%);
    background: #333;
    color: white;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 11px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
    z-index: 10;
  }
  .post-card[data-guest="true"] .upvote-btn:hover::after,
  .post-card[data-guest="true"] .comment-toggle:hover::after {
    opacity: 1;
  }
  .name {
    font-weight: 650;
    font-size: 13px;
    color: #2b2d31;
    cursor: pointer;
    text-decoration: none;
  }
  .name:hover {
    text-decoration: underline;
    color: #1f57f0;
  }
  .header-sub {
    margin-top: 3px;
    display: flex;
    align-items: center;
    gap: 8px;
    color: #7a7f87;
    font-size: 12px;
  }
  .dot {
    opacity: 0.6;
  }
  .follow-btn {
    border: 1px solid rgba(46, 105, 255, 0.35);
    background: #eef3ff;
    color: #1f57f0;
    font-weight: 700;
    font-size: 13px;
    padding: 7px 12px;
    border-radius: 999px;
    cursor: pointer !important;
    line-height: 1;
    transition:
      transform 0.05s ease,
      background 0.15s ease,
      border-color 0.15s ease;
  }
  .follow-btn:hover {
    background: #e2ebff;
    border-color: rgba(46, 105, 255, 0.5);
  }
  .follow-btn.following {
    background: #2e69ff;
    border-color: #2e69ff;
    color: #fff;
  }

  /* 3. BODY */
  .heading-link {
    text-decoration: none;
    color: inherit;
  }
  .heading {
    font-size: 18px;
    font-weight: 800;
    margin: 6px 0 8px;
    line-height: 1.25;
    color: #15171a;
    cursor: pointer;
  }
  .heading:hover {
    text-decoration: underline;
  }
  .description {
    font-size: 14.5px;
    color: #2a2d32;
    line-height: 1.55;
    margin-bottom: 6px;
  }
  .description-text {
    margin: 0;
  }
  .description.collapsed .description-text {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .read-more,
  .read-less {
    margin-top: 6px;
    background: none;
    border: none;
    padding: 0;
    color: #2e69ff;
    cursor: pointer;
    font-weight: 650;
  }
  .read-more:hover,
  .read-less:hover {
    text-decoration: underline;
  }
  .hidden {
    display: none !important;
  }

  /* 4. IMAGES */
  .post-images-grid {
    display: grid;
    gap: 4px;
    margin: 12px 0;
    border-radius: 8px;
    overflow: hidden;
    background: #f1f2f2;
    max-height: 400px;
  }
  .grid-item {
    position: relative;
    overflow: hidden;
    background: #e0e0e0;
  }
  .grid-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .grid-1 {
    grid-template-columns: 1fr;
  }
  .grid-1 .grid-item {
    height: 350px;
  }
  .grid-2 {
    grid-template-columns: 1fr 1fr;
  }
  .grid-2 .grid-item {
    height: 250px;
  }
  .grid-3 {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }
  .grid-3 .grid-item:nth-child(1) {
    grid-row: 1 / 3;
  }
  .grid-3 .grid-item {
    height: 100%;
  }
  .grid-4 {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }
  .grid-4 .grid-item {
    height: 180px;
  }
  .with-overlay {
    position: relative;
  }
  .more-count {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    font-weight: bold;
  }

  /* 5. FOOTER */
  .post-footer {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 12px;
    flex-wrap: wrap;
  }
  .vote-group {
    display: inline-flex;
    align-items: center;
    background: #f3f4f6;
    border: 1px solid #e3e6ea;
    border-radius: 999px;
    overflow: hidden;
  }
  .upvote-btn,
  .downvote-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    border: none;
    padding: 9px 14px;
    font-size: 13.5px;
    font-weight: 650;
    color: #525862;
    cursor: pointer;
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }
  .upvote-btn {
    border-right: 1px solid #e3e6ea;
  }
  .upvote-btn:hover,
  .downvote-btn:hover {
    background: #e9edf3;
  }
  .upvote-btn.active {
    background: #ebf0ff;
    color: #2e69ff;
  }
  .downvote-btn.active {
    color: #cb2027;
  }
  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    border: 1px solid transparent;
    color: #525862;
    font-size: 13.5px;
    font-weight: 650;
    cursor: pointer;
    padding: 9px 12px;
    border-radius: 999px;
    transition:
      background 0.15s ease,
      border-color 0.15s ease;
  }
  .action-btn:hover {
    background: #f3f4f6;
    border-color: #e3e6ea;
  }
  .more-btn {
    margin-left: auto;
  }

  /* 7. SHARE SECTION */
  .share-section {
    margin-top: 15px;
    padding: 15px;
    background: #fafafa;
    border-radius: 8px;
    position: relative;
  }
  .share-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .share-option {
    display: flex;
    align-items: center;
    gap: 8px;
    background: white;
    border: 1px solid #dee0e1;
    padding: 8px 14px;
    border-radius: 20px;
    cursor: pointer;
    font-size: 13px;
    color: #333;
    transition: all 0.2s;
  }
  .share-option:hover {
    background: #f0f0f0;
    border-color: #2e69ff;
  }
  .share-toast {
    position: absolute;
    top: -10px;
    right: 15px;
    background: #2b7a3a;
    color: white;
    padding: 5px 12px;
    border-radius: 12px;
    font-size: 12px;
    animation: fadeIn 0.3s;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-5px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* 8. MORE OPTIONS */
  .more-section {
    position: absolute;
    bottom: 50px;
    right: 15px;
    background: white;
    border: 1px solid #e3e6ea;
    border-radius: 8px;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.12);
    z-index: 100;
    min-width: 210px;
    overflow: hidden;
    padding: 4px 0;
  }
  .more-option {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    text-align: left;
    background: transparent;
    border: none;
    padding: 10px 16px;
    font-size: 13.5px;
    cursor: pointer;
    color: #282829;
    transition: background 0.15s;
  }
  .more-option:hover {
    background: #f5f6f7;
  }
  .more-option.danger {
    color: #cb2027;
  }
  .more-divider {
    height: 1px;
    background: #e3e6ea;
    margin: 4px 0;
  }

  /* 6. COMMENTS SECTION */
  .comments-section {
    margin-top: 15px !important;
    padding-top: 15px !important;
    border-top: 1px solid #eee !important;
  }
  .comment-item {
    display: flex !important;
    gap: 10px !important;
    padding: 12px 0 !important;
  }
  .comment-avatar {
    width: 32px !important;
    height: 32px !important;
    border-radius: 50% !important;
    background: #e3e6ea !important;
    flex-shrink: 0 !important;
    object-fit: cover !important;
  }
  .comment-content {
    flex: 1 !important;
    min-width: 0 !important;
  }
  .comment-meta {
    display: flex !important;
    align-items: center !important;
    gap: 6px !important;
    margin-bottom: 4px !important;
  }
  .comment-name {
    font-weight: 700 !important;
    font-size: 13px !important;
    color: #282829 !important;
  }
  .comment-dot {
    color: #939598 !important;
    font-size: 10px !important;
  }
  .comment-time {
    font-size: 12px !important;
    color: #939598 !important;
  }
  .comment-text {
    font-size: 14px !important;
    color: #282829 !important;
    margin: 0 0 8px 0 !important;
    line-height: 1.4 !important;
    word-wrap: break-word !important;
  }
  .comment-actions {
    display: flex !important;
    gap: 12px !important;
  }
  .comment-action-btn {
    background: none !important;
    border: none !important;
    color: #636466 !important;
    font-size: 12px !important;
    font-weight: 600 !important;
    cursor: pointer !important;
    padding: 0 !important;
    transition: color 0.15s !important;
  }
  .comment-action-btn:hover {
    color: #2e69ff !important;
  }
  .add-comment {
    display: flex !important;
    gap: 8px !important;
    align-items: center !important;
    margin-top: 10px !important;
    padding-top: 10px !important;
    border-top: 1px solid #f5f5f5 !important;
  }
  .comment-input {
    flex: 1 !important;
    border: 1px solid #dee0e1 !important;
    border-radius: 20px !important;
    padding: 8px 12px !important;
    font-size: 13px !important;
    outline: none !important;
    min-width: 0 !important;
  }
  .comment-input:focus {
    border-color: #2e69ff !important;
  }
  .comment-submit {
    background: #2e69ff !important;
    color: white !important;
    border: none !important;
    padding: 7px 18px !important;
    border-radius: 20px !important;
    font-size: 13px !important;
    font-weight: 500 !important;
    cursor: pointer !important;
    flex-shrink: 0 !important;
    transition:
      opacity 0.2s,
      background 0.2s !important;
  }
  .comment-submit:hover:not([disabled]) {
    background: #1e5ae6 !important;
  }
  .comment-submit:disabled {
    opacity: 0.4 !important;
    cursor: not-allowed !important;
  }
  .comment-replies {
    margin-left: 42px !important;
    margin-top: 10px !important;
    padding-left: 12px !important;
    border-left: 2px solid #e3e6ea !important;
  }
  .like-btn {
    display: inline-flex !important;
    align-items: center !important;
    gap: 4px !important;
    transition: all 0.2s !important;
  }
  .like-btn.liked {
    color: #cb2027 !important;
  }
  .like-btn:hover {
    transform: scale(1.1) !important;
  }
  .like-icon {
    font-size: 14px !important;
  }
  .reply-form {
    display: flex !important;
    gap: 8px !important;
    margin-top: 10px !important;
  }
  .reply-input {
    flex: 1 !important;
    border: 1px solid #dee0e1 !important;
    border-radius: 20px !important;
    padding: 6px 12px !important;
    font-size: 12px !important;
    outline: none !important;
  }
  .reply-submit {
    background: #2e69ff !important;
    color: white !important;
    border: none !important;
    padding: 6px 14px !important;
    border-radius: 20px !important;
    font-size: 12px !important;
    font-weight: 600 !important;
    cursor: pointer !important;
  }
  .reply-submit:hover {
    background: #1e5ae6 !important;
  }
</style>

<script>
  const SCRIPT_URL =
    "https://script.google.com/macros/s/AKfycbywCeoEu7CNLZtgRKyy4wsnvGw8B6wpNrP5ke0RoJ6XrVfwgsmBKAlIKvli79IVAWQJxQ/exec";

  // ✅ Helper for comment avatars/images rendered dynamically
  function getMediaUrl(url: string | null | undefined): string {
    if (!url || url === "icon.png" || url === "null" || url === "")
      return "/assets/icon.png";
    if (url.startsWith("data:")) return url;
    if (url.startsWith("http://") || url.startsWith("https://")) return url;
    if (url.startsWith("iVBOR") || url.startsWith("/9j/"))
      return `data:image/png;base64,${url}`;
    if (url.includes("googleusercontent.com") || url.includes("github.com"))
      return url;
    return `/assets/${url}`;
  }

  function isUserLoggedIn(): boolean {
    return localStorage.getItem("userId") !== null;
  }
  function showLoginModal() {
    const loginModal = document.getElementById("loginModal");
    if (loginModal) loginModal.classList.add("active");
    else window.dispatchEvent(new CustomEvent("show-login-modal"));
  }
  function getCurrentUser() {
    return {
      email: localStorage.getItem("userId") || "",
      name: localStorage.getItem("currentUser") || "Anonymous",
      avatar: localStorage.getItem("userAvatar") || "/assets/icon.png",
    };
  }
  function getTimeAgo(date: Date): string {
    const seconds = Math.floor((new Date().getTime() - date.getTime()) / 1000);
    if (seconds < 60) return "Just now";
    if (seconds < 3600) return Math.floor(seconds / 60) + "m ago";
    if (seconds < 86400) return Math.floor(seconds / 3600) + "h ago";
    if (seconds < 604800) return Math.floor(seconds / 86400) + "d ago";
    return Math.floor(seconds / 604800) + "w ago";
  }

  function initPostLogic() {
    const postCards = document.querySelectorAll(".post-card");

    postCards.forEach((card) => {
      const cardEl = card as HTMLElement;
      const postId = cardEl.getAttribute("data-id");
      if (!postId) return;

      const upBtn = card.querySelector(".upvote-btn") as HTMLButtonElement;
      const downBtn = card.querySelector(".downvote-btn") as HTMLButtonElement;
      const countDisplay = card.querySelector(".upvote-count") as HTMLElement;

      if (upBtn && downBtn && countDisplay) {
        let upvotes = parseInt(upBtn.getAttribute("data-count") || "0");
        let isUpvoted = false,
          isDownvoted = false,
          isProcessing = false;

        const updateUI = () => {
          countDisplay.textContent =
            upvotes >= 1000
              ? (upvotes / 1000).toFixed(1) + "K"
              : upvotes.toString();
        };

        const syncUpvoteToSheet = async (increment: boolean) => {
          if (isProcessing) return;
          isProcessing = true;
          const user = getCurrentUser();
          try {
            const response = await fetch(SCRIPT_URL, {
              method: "POST",
              body: JSON.stringify({
                action: "updateUpvote",
                postId,
                increment,
                actorEmail: user.email,
                actorName: user.name,
              }),
            });
            const result = await response.json();
            if (result.status === "success") {
              upvotes = result.newCount;
              updateUI();
            } else {
              isUpvoted = !isUpvoted;
              upvotes = isUpvoted ? upvotes + 1 : upvotes - 1;
              upBtn.classList.toggle("active", isUpvoted);
              updateUI();
            }
          } catch (error) {
            isUpvoted = !isUpvoted;
            upvotes = isUpvoted ? upvotes + 1 : upvotes - 1;
            upBtn.classList.toggle("active", isUpvoted);
            updateUI();
          } finally {
            isProcessing = false;
          }
        };

        upBtn.addEventListener("click", async (e) => {
          e.preventDefault();
          e.stopPropagation();
          if (!isUserLoggedIn()) return showLoginModal();
          if (isProcessing) return;
          if (isUpvoted) {
            isUpvoted = false;
            upBtn.classList.remove("active");
            await syncUpvoteToSheet(false);
          } else {
            isUpvoted = true;
            upBtn.classList.add("active");
            if (isDownvoted) {
              isDownvoted = false;
              downBtn.classList.remove("active");
            }
            await syncUpvoteToSheet(true);
          }
        });

        downBtn.addEventListener("click", async (e) => {
          e.preventDefault();
          e.stopPropagation();
          if (!isUserLoggedIn()) return showLoginModal();
          if (isProcessing) return;
          if (isDownvoted) {
            isDownvoted = false;
            downBtn.classList.remove("active");
          } else {
            isDownvoted = true;
            downBtn.classList.add("active");
            if (isUpvoted) {
              isUpvoted = false;
              upBtn.classList.remove("active");
              await syncUpvoteToSheet(false);
            }
          }
        });
      }

      // COMMENTS SYSTEM
      const commentToggle = card.querySelector(
        ".comment-toggle",
      ) as HTMLButtonElement;
      const commentsSection = card.querySelector(
        ".comments-section",
      ) as HTMLElement;
      const commentInput = card.querySelector(
        ".comment-input",
      ) as HTMLInputElement;
      const commentSubmit = card.querySelector(
        ".comment-submit",
      ) as HTMLButtonElement;
      const commentCountDisplay = card.querySelector(
        ".comment-toggle .action-count",
      ) as HTMLElement;
      const commentsList = card.querySelector(".comments-list") as HTMLElement;

      async function loadComments() {
        if (!postId || !commentsList) return;
        const userEmail = localStorage.getItem("userId") || "";
        try {
          const response = await fetch(
            `${SCRIPT_URL}?action=getComments&postId=${postId}&userEmail=${encodeURIComponent(userEmail)}`,
          );
          const comments = await response.json();
          commentsList.innerHTML = "";
          let totalCount = 0;
          comments.forEach((comment: any) => {
            totalCount += 1 + (comment.replies?.length || 0);
            renderCommentWithReplies(comment, commentsList);
          });
          if (commentCountDisplay)
            commentCountDisplay.textContent = totalCount.toString();
        } catch (error) {
          console.error("Error loading comments:", error);
        }
      }

      function renderCommentWithReplies(comment: any, container: HTMLElement) {
        const commentEl = createCommentElement(comment, null);
        container.appendChild(commentEl);
        if (comment.replies && comment.replies.length > 0) {
          const repliesContainer = document.createElement("div");
          repliesContainer.className = "comment-replies";
          comment.replies.forEach((reply: any) => {
            const replyEl = createCommentElement(reply, comment.id);
            repliesContainer.appendChild(replyEl);
          });
          commentEl.appendChild(repliesContainer);
        }
      }

      function createCommentElement(
        comment: any,
        parentID: string | null,
      ): HTMLElement {
        const div = document.createElement("div");
        div.className = "comment-item";
        div.setAttribute("data-comment-id", comment.id);

        // ✅ FIX: Use getMediaUrl for dynamically loaded comment avatars
        const avatarUrl = getMediaUrl(comment.userAvatar);
        const timeStr = comment.timestamp
          ? getTimeAgo(new Date(comment.timestamp))
          : "Just now";
        const likeClass = comment.userLiked ? "liked" : "";
        const isReply = parentID !== null;

        div.innerHTML = `
          <img src="${avatarUrl}" class="comment-avatar" alt="${comment.userName}" />
          <div class="comment-content">
            <div class="comment-meta">
              <span class="comment-name">${comment.userName}</span>
              <span class="comment-dot">•</span>
              <span class="comment-time">${timeStr}</span>
            </div>
            <p class="comment-text">${comment.text || ""}</p>
            <div class="comment-actions">
              ${!isReply ? '<button class="comment-action-btn reply-btn">Reply</button>' : ""}
              <button class="comment-action-btn like-btn ${likeClass}" data-comment-id="${comment.id}">
                <span class="like-icon">${comment.userLiked ? "❤️" : "🤍"}</span>
                <span class="like-count">${comment.likes || 0}</span>
              </button>
            </div>
            ${!isReply ? `<div class="reply-form hidden"><input type="text" class="reply-input" placeholder="Write a reply..." /><button class="reply-submit">Reply</button></div>` : ""}
          </div>
        `;

        const likeBtn = div.querySelector(".like-btn");
        likeBtn?.addEventListener("click", () =>
          handleCommentLike(comment.id, likeBtn as HTMLButtonElement),
        );

        if (!isReply) {
          const replyBtn = div.querySelector(".reply-btn");
          const replyForm = div.querySelector(".reply-form");
          const replyInput = div.querySelector(
            ".reply-input",
          ) as HTMLInputElement;
          const replySubmit = div.querySelector(".reply-submit");

          replyBtn?.addEventListener("click", () => {
            if (!isUserLoggedIn()) return showLoginModal();
            replyForm?.classList.toggle("hidden");
            setTimeout(() => replyInput?.focus(), 100);
          });

          const submitReply = async () => {
            if (!isUserLoggedIn()) return showLoginModal();
            const text = replyInput.value.trim();
            if (!text) return;
            await postComment(text, comment.id);
            replyInput.value = "";
            replyForm?.classList.add("hidden");
          };

          replySubmit?.addEventListener("click", submitReply);
          replyInput?.addEventListener("keypress", (e) => {
            if (e.key === "Enter") {
              e.preventDefault();
              submitReply();
            }
          });
        }
        return div;
      }

      async function handleCommentLike(
        commentId: string,
        btn: HTMLButtonElement,
      ) {
        if (!isUserLoggedIn()) return showLoginModal();
        const userEmail = localStorage.getItem("userId") || "";
        const likeCountSpan = btn.querySelector(".like-count");
        const likeIcon = btn.querySelector(".like-icon");
        try {
          const response = await fetch(SCRIPT_URL, {
            method: "POST",
            body: JSON.stringify({
              action: "toggleCommentLike",
              commentId,
              userEmail,
            }),
          });
          const result = await response.json();
          if (result.status === "success") {
            if (likeCountSpan)
              likeCountSpan.textContent = result.likes.toString();
            if (likeIcon) likeIcon.textContent = result.liked ? "❤️" : "🤍";
            btn.classList.toggle("liked", result.liked);
          }
        } catch (error) {
          console.error("Error toggling like:", error);
        }
      }

      async function postComment(text: string, parentID: string | null = null) {
        if (!isUserLoggedIn()) return showLoginModal();
        const user = getCurrentUser();
        try {
          const response = await fetch(SCRIPT_URL, {
            method: "POST",
            body: JSON.stringify({
              action: "addComment",
              postId,
              parentID: parentID || "",
              userEmail: user.email,
              userName: user.name,
              userAvatar: user.avatar,
              commentText: text,
            }),
          });
          const result = await response.json();
          if (result.status === "success") await loadComments();
        } catch (error) {
          console.error("Error posting comment:", error);
          alert("Could not post comment. Please try again.");
        }
      }

      loadComments();

      if (commentToggle && commentsSection) {
        commentToggle.addEventListener("click", () => {
          if (!isUserLoggedIn()) return showLoginModal();
          commentsSection.classList.toggle("hidden");
        });
      }

      if (commentInput && commentSubmit) {
        commentInput.addEventListener("input", () => {
          commentSubmit.disabled = commentInput.value.trim().length === 0;
        });
        const handleMainSubmit = async () => {
          const text = commentInput.value.trim();
          if (!text) return;
          await postComment(text, null);
          commentInput.value = "";
          commentSubmit.disabled = true;
        };
        commentSubmit.addEventListener("click", handleMainSubmit);
        commentInput.addEventListener("keypress", (e) => {
          if (e.key === "Enter") {
            e.preventDefault();
            handleMainSubmit();
          }
        });
      }

      // SHARE SYSTEM
      const shareToggle = card.querySelector(
        ".share-toggle",
      ) as HTMLButtonElement;
      const shareSection = card.querySelector(".share-section") as HTMLElement;
      const shareToast = card.querySelector(".share-toast") as HTMLElement;
      const shareCountDisplay = card.querySelector(
        ".share-toggle .action-count",
      ) as HTMLElement;

      const syncShareCount = async () => {
        try {
          const response = await fetch(SCRIPT_URL, {
            method: "POST",
            body: JSON.stringify({
              action: "updateShareCount",
              postId,
              actorEmail: localStorage.getItem("userId") || "",
              actorName: localStorage.getItem("currentUser") || "Someone",
            }),
          });
          const result = await response.json();
          if (result.status === "success" && shareCountDisplay)
            shareCountDisplay.textContent = result.newCount.toString();
        } catch (error) {
          console.error("Error syncing share count:", error);
        }
      };

      if (shareToggle && shareSection) {
        shareToggle.addEventListener("click", () => {
          if (!isUserLoggedIn()) return showLoginModal();
          shareSection.classList.toggle("hidden");
        });
      }

      card.querySelectorAll(".share-option").forEach((btn) => {
        btn.addEventListener("click", () => {
          if (!isUserLoggedIn()) return showLoginModal();
          const action = btn.getAttribute("data-share");
          const slug = cardEl.getAttribute("data-slug");
          const heading = cardEl.getAttribute("data-heading") || "";
          const url = `${window.location.origin}/question/${slug}`;
          syncShareCount();
          if (action === "copy") {
            navigator.clipboard.writeText(url);
            if (shareToast) {
              shareToast.classList.remove("hidden");
              setTimeout(() => shareToast.classList.add("hidden"), 2000);
            }
          } else if (action === "twitter") {
            window.open(
              `https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(heading)}`,
              "_blank",
            );
          }
        });
      });

      // MORE OPTIONS
      const moreBtn = card.querySelector(".more-btn") as HTMLButtonElement;
      const moreSection = card.querySelector(".more-section") as HTMLElement;

      if (moreBtn && moreSection) {
        moreBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          document.querySelectorAll(".more-section").forEach((s) => {
            if (s !== moreSection) s.classList.add("hidden");
          });
          moreSection.classList.toggle("hidden");
        });
      }

      document.addEventListener("click", (e) => {
        if (
          moreSection &&
          !moreSection.contains(e.target as Node) &&
          e.target !== moreBtn
        ) {
          moreSection.classList.add("hidden");
        }
      });

      card.querySelectorAll(".more-option").forEach((opt) => {
        opt.addEventListener("click", () => {
          const action = opt.getAttribute("data-action");
          const slug = cardEl.getAttribute("data-slug");
          const url = `${window.location.origin}/question/${slug}`;
          if (
            action === "save" ||
            action === "hide" ||
            action === "report" ||
            action === "not-interested"
          ) {
            if (!isUserLoggedIn()) return showLoginModal();
          }
          if (action === "save") alert("Post saved!");
          else if (action === "hide") cardEl.style.display = "none";
          else if (action === "report") alert("Post reported. Thank you!");
          else if (action === "not-interested") cardEl.style.display = "none";
          else if (action === "copy-link") {
            navigator.clipboard.writeText(url);
            alert("Link copied!");
          }
          if (moreSection) moreSection.classList.add("hidden");
        });
      });

      // EXPAND/COLLAPSE
      const desc = card.querySelector(".description") as HTMLElement;
      const readMore = card.querySelector(".read-more") as HTMLElement;
      const readLess = card.querySelector(".read-less") as HTMLElement;

      if (desc && readMore && readLess) {
        desc.classList.add("collapsed");
        readMore.addEventListener("click", () => {
          desc.classList.remove("collapsed");
          readMore.classList.add("hidden");
          readLess.classList.remove("hidden");
        });
        readLess.addEventListener("click", () => {
          desc.classList.add("collapsed");
          readMore.classList.remove("hidden");
          readLess.classList.add("hidden");
        });
      }
    });
  }

  (window as any).initPostLogic = initPostLogic;
  initPostLogic();
  document.addEventListener("astro:after-swap", initPostLogic);

  (window as any).toggleFollow = function (btn: HTMLButtonElement) {
    if (!isUserLoggedIn()) return showLoginModal();
    const author = btn.getAttribute("data-author") || "";
    const user = getCurrentUser();

    if (btn.classList.contains("following")) {
      btn.classList.remove("following");
      btn.innerText = "Follow";
      fetch(SCRIPT_URL, {
        method: "POST",
        body: JSON.stringify({
          action: "unfollowUser",
          followerEmail: user.email,
          targetEmail: author,
        }),
      }).catch((err) => console.error("Unfollow error:", err));
    } else {
      btn.classList.add("following");
      btn.innerText = "Following";
      fetch(SCRIPT_URL, {
        method: "POST",
        body: JSON.stringify({
          action: "followUser",
          followerEmail: user.email,
          followerName: user.name,
          targetEmail: author,
        }),
      }).catch((err) => console.error("Follow error:", err));
    }
  };

  window.addEventListener("load", () => {
    document.querySelectorAll(".follow-btn").forEach((btn) => {
      const author = btn.getAttribute("data-author");
      if (author) {
        btn.classList.remove("following");
        btn.textContent = "Follow";
      }
    });
  });
</script>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const isGuest = !localStorage.getItem("userId");
    if (isGuest) {
      document.querySelectorAll(".post-card").forEach((card) => {
        card.setAttribute("data-guest", "true");
      });
    }
  });
</script>
