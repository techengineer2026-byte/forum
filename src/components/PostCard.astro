<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const currentUser = localStorage.getItem("currentUser") || "";
    const isGuest = !localStorage.getItem("userId");

    document.querySelectorAll(".post-card").forEach((card) => {
      // ✅ Guest state
      if (isGuest) {
        card.setAttribute("data-guest", "true");
      }

      // ✅ AUTHOR CHECK: Show delete button only to post owner
      const authorName = card.getAttribute("data-author-name") || "";
      if (currentUser && authorName && currentUser === authorName) {
        const deleteBtn = card.querySelector(".delete-post-btn");
        if (deleteBtn) deleteBtn.classList.remove("hidden");
      }

      // ✅ COMMENT INPUT: Replace guest prompt with real input if logged in
      if (!isGuest) {
        const addComment = card.querySelector(".add-comment");
        if (addComment) {
          addComment.innerHTML = `
            <img src="/assets/icon.png" class="comment-avatar" alt="You" />
            <input type="text" class="comment-input" placeholder="Add a comment..." />
            <button class="comment-submit" type="button">Post</button>
          `;
        }
      } else {
        // Guest: attach login handler to prompt button
        const loginBtn = card.querySelector(".guest-login-prompt");
        if (loginBtn) {
          loginBtn.addEventListener("click", () => {
            const loginModal = document.getElementById("loginModal");
            if (loginModal) loginModal.classList.add("active");
            else window.dispatchEvent(new CustomEvent("show-login-modal"));
          });
        }
      }
    });
  });
</script>
