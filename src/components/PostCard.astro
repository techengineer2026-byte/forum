---
const {
    id,
    avatar,
    name,
    follow_enabled,
    role_name,
    updated_time,
    heading,
    description,
    images,
    upvotes,
    comments,
    shares,
    slug,
} = Astro.props;
import { formatContent } from "../utils/formatContent";

const displayUpvotes = upvotes;
const postSlug =
    slug ||
    heading
        .toLowerCase()
        .replace(/[^\w ]+/g, "")
        .replace(/ +/g, "-");
---

<div class="post-card" data-id={id} data-slug={postSlug} data-heading={heading}>
    <!-- HEADER -->
    <div class="post-header">
        <img src={`/assets/${avatar}`} alt={name} class="avatar" />
        <div class="header-main">
            <div class="header-top">
                <a href={`/user?name=${name}`} class="name">{name}</a>
                {
                    follow_enabled && (
                        <button
                            class="follow-btn"
                            data-author={name}
                            onclick="window.toggleFollow(this)"
                            type="button"
                        >
                            Follow
                        </button>
                    )
                }
            </div>
            <div class="header-sub">
                <span class="role">{role_name}</span>
                <span class="dot">•</span>
                <span class="time">{updated_time}</span>
            </div>
        </div>
    </div>

    <!-- BODY -->
    <div class="post-body">
        <a href={`/question/${postSlug}`} class="heading-link">
            <h2 class="heading" set:html={formatContent(heading)} />
        </a>
        <div class="description">
            <p class="description-text" set:html={formatContent(description)} />
            <button class="read-more" type="button" data-action="expand"
                >Read more</button
            >
            <button
                class="read-less hidden"
                type="button"
                data-action="collapse">Show less</button
            >
        </div>
    </div>

    <!-- IMAGE GRID -->
    {
        images && images.length > 0 && (
            <div class={`post-images-grid grid-${Math.min(images.length, 4)}`}>
                {images.slice(0, 4).map((img: string, index: number) => {
                    if (index === 3 && images.length > 4) {
                        return (
                            <div class="grid-item with-overlay">
                                <img src={`/assets/${img}`} alt="" />
                                <div class="more-count">
                                    +{images.length - 3}
                                </div>
                            </div>
                        );
                    }
                    return (
                        <div class="grid-item">
                            <img src={`/assets/${img}`} alt="" />
                        </div>
                    );
                })}
            </div>
        )
    }

    <!-- FOOTER -->
    <div class="post-footer">
        <div class="vote-group">
            <button
                class="upvote-btn"
                data-count={displayUpvotes}
                aria-label="Upvote"
            >
                <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M12 19V5M5 12l7-7 7 7"></path></svg
                >
                <span class="btn-text"
                    >Upvote · <span class="upvote-count"
                        >{
                            displayUpvotes >= 1000
                                ? (displayUpvotes / 1000).toFixed(1) + "K"
                                : displayUpvotes
                        }</span
                    ></span
                >
            </button>
            <button class="downvote-btn" aria-label="Downvote">
                <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M12 5v14M19 12l-7 7-7-7"></path></svg
                >
            </button>
        </div>

        <button class="action-btn comment-toggle" aria-label="Comment">
            <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                    d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                ></path></svg
            >
            <span class="action-count">{comments}</span>
        </button>

        <button class="action-btn share-toggle" aria-label="Share">
            <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"
                ></path><polyline points="16 6 12 2 8 6"></polyline><line
                    x1="12"
                    y1="2"
                    x2="12"
                    y2="15"></line></svg
            >
            <span class="action-count">{shares}</span>
        </button>

        <button class="action-btn more-btn" aria-label="More options">
            <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="12" cy="12" r="1"></circle><circle
                    cx="19"
                    cy="12"
                    r="1"></circle><circle cx="5" cy="12" r="1"></circle></svg
            >
        </button>
    </div>

    <!-- COMMENTS DROPDOWN -->
    <div class="comments-section hidden">
        <div class="comments-list"></div>
        <div class="add-comment">
            <img src="/assets/icon.png" class="comment-avatar" alt="You" />
            <input
                type="text"
                class="comment-input"
                placeholder="Add a comment..."
            />
            <button class="comment-submit" type="button">Post</button>
        </div>
    </div>

    <!-- SHARE DROPDOWN -->
    <div class="share-section hidden">
        <div class="share-row">
            <button class="share-option" data-share="copy">
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                        d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
                    ></path><path
                        d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
                    ></path></svg
                >
                <span>Copy link</span>
            </button>
            <button class="share-option" data-share="twitter">
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                        d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"
                    ></path></svg
                >
                <span>Twitter</span>
            </button>
            <button class="share-option" data-share="facebook">
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                        d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                    ></path></svg
                >
                <span>Facebook</span>
            </button>
            <button class="share-option" data-share="whatsapp">
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                        d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
                    ></path></svg
                >
                <span>WhatsApp</span>
            </button>
        </div>
        <div class="share-toast hidden">Link copied to clipboard!</div>
    </div>

    <!-- MORE OPTIONS DROPDOWN -->
    <div class="more-section hidden">
        <button class="more-option" data-action="save">
            <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"
                ></path></svg
            >
            <span>Save</span>
        </button>
        <button class="more-option" data-action="copy-link">
            <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                    d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
                ></path><path
                    d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
                ></path></svg
            >
            <span>Copy link</span>
        </button>
        <div class="more-divider"></div>
        <button class="more-option" data-action="hide">
            <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                    d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"
                ></path><path
                    d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"
                ></path><line x1="1" y1="1" x2="23" y2="23"></line></svg
            >
            <span>Hide</span>
        </button>
        <button class="more-option" data-action="not-interested">
            <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                    d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3zm7-13h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"
                ></path></svg
            >
            <span>Not interested</span>
        </button>
        <button class="more-option danger" data-action="report">
            <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                    d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"
                ></path><line x1="4" y1="22" x2="4" y2="15"></line></svg
            >
            <span>Report</span>
        </button>
    </div>
</div>

<style is:global>
    /* 1. CONTAINER */
    /* ===== CODE BLOCK STYLES ===== */
    .description-text .code-block {
        background: #1e1e1e; /* Dark editor background */
        color: #d4d4d4; /* Light grey text */
        padding: 14px 18px;
        border-radius: 8px;
        overflow-x: auto;
        font-family: "Courier New", Courier, monospace;
        font-size: 13px;
        line-height: 1.5;
        margin: 10px 0;
        white-space: pre;
        border: 1px solid #333;
    }

    .description-text .inline-code {
        background: #f1f2f2;
        color: #b92b27; /* Brand red for inline code */
        padding: 2px 6px;
        border-radius: 4px;
        font-family: "Courier New", Courier, monospace;
        font-size: 13px;
        font-weight: 500;
    }
    .post-card {
        background: white;
        border: 1px solid #e3e6ea;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 12px;
        transition: border-color 0.2s;
        position: relative;
        overflow: hidden;
    }
    .post-card:hover {
        border-color: #ccd0d1;
    }

    /* 2. HEADER */
    .post-header {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 10px;
    }
    .avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background-color: #f7f7f7;
        object-fit: cover;
        flex-shrink: 0;
    }
    .header-main {
        flex: 1;
        min-width: 0;
    }
    .header-top {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }
    .name {
        font-weight: 650;
        font-size: 13px;
        color: #2b2d31;
        cursor: pointer;
        text-decoration: none; /* Remove default underline */
    }
    .name:hover {
        text-decoration: underline;
        color: #1f57f0; /* Make it blue on hover */
    }
    .header-sub {
        margin-top: 3px;
        display: flex;
        align-items: center;
        gap: 8px;
        color: #7a7f87;
        font-size: 12px;
    }
    .role,
    .time {
        color: inherit;
    }
    .dot {
        opacity: 0.6;
    }
    .follow-btn {
        border: 1px solid rgba(46, 105, 255, 0.35);
        background: #eef3ff;
        color: #1f57f0;
        font-weight: 700;
        font-size: 13px;
        padding: 7px 12px;
        border-radius: 999px;
        cursor: pointer !important;
        line-height: 1;
        transition:
            transform 0.05s ease,
            background 0.15s ease,
            border-color 0.15s ease;
    }
    .follow-btn:hover {
        background: #e2ebff;
        border-color: rgba(46, 105, 255, 0.5);
    }
    .follow-btn:active {
        transform: translateY(1px);
    }
    .follow-btn.following {
        background: #2e69ff;
        border-color: #2e69ff;
        color: #fff;
    }

    /* 3. BODY */
    .heading-link {
        text-decoration: none;
        color: inherit;
    }
    .heading {
        font-size: 18px;
        font-weight: 800;
        margin: 6px 0 8px;
        line-height: 1.25;
        color: #15171a;
        cursor: pointer;
    }
    .heading:hover {
        text-decoration: underline;
    }
    .description {
        font-size: 14.5px;
        color: #2a2d32;
        line-height: 1.55;
        margin-bottom: 6px;
    }
    .description-text {
        margin: 0;
    }
    .description.collapsed .description-text {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .read-more,
    .read-less {
        margin-top: 6px;
        background: none;
        border: none;
        padding: 0;
        color: #2e69ff;
        cursor: pointer;
        font-weight: 650;
    }
    .read-more:hover,
    .read-less:hover {
        text-decoration: underline;
    }
    .hidden {
        display: none !important;
    }

    /* 4. IMAGES */
    .post-images-grid {
        display: grid;
        gap: 4px;
        margin: 12px 0;
        border-radius: 8px;
        overflow: hidden;
        background: #f1f2f2;
        max-height: 400px;
    }
    .grid-item {
        position: relative;
        overflow: hidden;
        background: #e0e0e0;
    }
    .grid-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
    .grid-1 {
        grid-template-columns: 1fr;
    }
    .grid-1 .grid-item {
        height: 350px;
    }
    .grid-2 {
        grid-template-columns: 1fr 1fr;
    }
    .grid-2 .grid-item {
        height: 250px;
    }
    .grid-3 {
        grid-template-columns: 1fr 1fr;
        grid-template-rows: 1fr 1fr;
    }
    .grid-3 .grid-item:nth-child(1) {
        grid-row: 1 / 3;
    }
    .grid-3 .grid-item {
        height: 100%;
    }
    .grid-4 {
        grid-template-columns: 1fr 1fr;
        grid-template-rows: 1fr 1fr;
    }
    .grid-4 .grid-item {
        height: 180px;
    }
    .with-overlay {
        position: relative;
    }
    .more-count {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        font-weight: bold;
    }

    /* 5. FOOTER */
    .post-footer {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 12px;
        flex-wrap: wrap;
    }
    .vote-group {
        display: inline-flex;
        align-items: center;
        background: #f3f4f6;
        border: 1px solid #e3e6ea;
        border-radius: 999px;
        overflow: hidden;
    }
    .upvote-btn,
    .downvote-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: transparent;
        border: none;
        padding: 9px 14px;
        font-size: 13.5px;
        font-weight: 650;
        color: #525862;
        cursor: pointer;
        transition:
            background 0.15s ease,
            color 0.15s ease;
    }
    .upvote-btn {
        border-right: 1px solid #e3e6ea;
    }
    .upvote-btn:hover,
    .downvote-btn:hover {
        background: #e9edf3;
    }
    .upvote-btn.active {
        background: #ebf0ff;
        color: #2e69ff;
    }
    .downvote-btn.active {
        color: #cb2027;
    }
    .action-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: transparent;
        border: 1px solid transparent;
        color: #525862;
        font-size: 13.5px;
        font-weight: 650;
        cursor: pointer;
        padding: 9px 12px;
        border-radius: 999px;
        transition:
            background 0.15s ease,
            border-color 0.15s ease;
    }
    .action-btn:hover {
        background: #f3f4f6;
        border-color: #e3e6ea;
    }
    .more-btn {
        margin-left: auto;
    }

    /* 7. SHARE SECTION */
    .share-section {
        margin-top: 15px;
        padding: 15px;
        background: #fafafa;
        border-radius: 8px;
        position: relative;
    }
    .share-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }
    .share-option {
        display: flex;
        align-items: center;
        gap: 8px;
        background: white;
        border: 1px solid #dee0e1;
        padding: 8px 14px;
        border-radius: 20px;
        cursor: pointer;
        font-size: 13px;
        color: #333;
        transition: all 0.2s;
    }
    .share-option:hover {
        background: #f0f0f0;
        border-color: #2e69ff;
    }
    .share-toast {
        position: absolute;
        top: -10px;
        right: 15px;
        background: #2b7a3a;
        color: white;
        padding: 5px 12px;
        border-radius: 12px;
        font-size: 12px;
        animation: fadeIn 0.3s;
    }
    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-5px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* 8. MORE OPTIONS */
    .more-section {
        position: absolute;
        bottom: 50px;
        right: 15px;
        background: white;
        border: 1px solid #e3e6ea;
        border-radius: 8px;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.12);
        z-index: 100;
        min-width: 210px;
        overflow: hidden;
        padding: 4px 0;
    }
    .more-option {
        display: flex;
        align-items: center;
        gap: 10px;
        width: 100%;
        text-align: left;
        background: transparent;
        border: none;
        padding: 10px 16px;
        font-size: 13.5px;
        cursor: pointer;
        color: #282829;
        transition: background 0.15s;
    }
    .more-option:hover {
        background: #f5f6f7;
    }
    .more-option.danger {
        color: #cb2027;
    }
    .more-option.danger:hover {
        background: #fff0f0;
    }
    .more-divider {
        height: 1px;
        background: #e3e6ea;
        margin: 4px 0;
    }

    /* 6. COMMENTS SECTION */
    .comments-section {
        margin-top: 15px !important;
        padding-top: 15px !important;
        border-top: 1px solid #eee !important;
    }
    .comment-item {
        display: flex !important;
        gap: 10px !important;
        padding: 12px 0 !important;
    }
    .comment-avatar {
        width: 32px !important;
        height: 32px !important;
        border-radius: 50% !important;
        background: #e3e6ea !important;
        flex-shrink: 0 !important;
        object-fit: cover !important;
    }
    .comment-content {
        flex: 1 !important;
        min-width: 0 !important;
    }
    .comment-meta {
        display: flex !important;
        align-items: center !important;
        gap: 6px !important;
        margin-bottom: 4px !important;
    }
    .comment-name {
        font-weight: 700 !important;
        font-size: 13px !important;
        color: #282829 !important;
    }
    .comment-dot {
        color: #939598 !important;
        font-size: 10px !important;
    }
    .comment-time {
        font-size: 12px !important;
        color: #939598 !important;
    }
    .comment-text {
        font-size: 14px !important;
        color: #282829 !important;
        margin: 0 0 8px 0 !important;
        line-height: 1.4 !important;
        word-wrap: break-word !important;
    }
    .comment-image-wrapper {
        margin-top: 4px !important;
        margin-bottom: 8px !important;
    }
    .comment-image {
        max-height: 180px !important;
        max-width: 100% !important;
        border-radius: 8px !important;
        object-fit: cover !important;
        border: 1px solid #e3e6ea !important;
    }
    .comment-actions {
        display: flex !important;
        gap: 12px !important;
    }
    .comment-action-btn {
        background: none !important;
        border: none !important;
        color: #636466 !important;
        font-size: 12px !important;
        font-weight: 600 !important;
        cursor: pointer !important;
        padding: 0 !important;
        transition: color 0.15s !important;
    }
    .comment-action-btn:hover {
        color: #2e69ff !important;
    }
    .add-comment {
        display: flex !important;
        gap: 8px !important;
        align-items: center !important;
        margin-top: 10px !important;
        padding-top: 10px !important;
        border-top: 1px solid #f5f5f5 !important;
    }
    .comment-input {
        flex: 1 !important;
        border: 1px solid #dee0e1 !important;
        border-radius: 20px !important;
        padding: 8px 12px !important;
        font-size: 13px !important;
        outline: none !important;
        min-width: 0 !important;
    }
    .comment-input:focus {
        border-color: #2e69ff !important;
    }
    .comment-submit {
        background: #2e69ff !important;
        color: white !important;
        border: none !important;
        padding: 7px 18px !important;
        border-radius: 20px !important;
        font-size: 13px !important;
        font-weight: 500 !important;
        cursor: pointer !important;
        flex-shrink: 0 !important;
        transition:
            opacity 0.2s,
            background 0.2s !important;
    }
    .comment-submit:hover:not([disabled]) {
        background: #1e5ae6 !important;
    }
    .comment-submit:disabled {
        opacity: 0.4 !important;
        cursor: not-allowed !important;
    }
</style>
<script>
    function initPostLogic() {
        const postCards = document.querySelectorAll(".post-card");

        postCards.forEach((card) => {
            const cardEl = card as HTMLElement;
            const upBtn = card.querySelector(
                ".upvote-btn",
            ) as HTMLButtonElement;
            const downBtn = card.querySelector(
                ".downvote-btn",
            ) as HTMLButtonElement;
            const countDisplay = card.querySelector(
                ".upvote-count",
            ) as HTMLElement;

            if (!upBtn || !downBtn || !countDisplay) return;

            let upvotes = parseInt(upBtn.getAttribute("data-count") || "0");
            let isUpvoted = false;
            let isDownvoted = false;

            const updateUI = () => {
                countDisplay.textContent =
                    upvotes >= 1000
                        ? (upvotes / 1000).toFixed(1) + "K"
                        : upvotes.toString();
            };

            upBtn.addEventListener("click", () => {
                if (isUpvoted) {
                    isUpvoted = false;
                    upvotes--;
                    upBtn.classList.remove("active");
                } else {
                    isUpvoted = true;
                    upvotes++;
                    upBtn.classList.add("active");
                    isDownvoted = false;
                    downBtn.classList.remove("active");
                }
                updateUI();
            });

            downBtn.addEventListener("click", () => {
                if (isDownvoted) {
                    isDownvoted = false;
                    downBtn.classList.remove("active");
                } else {
                    isDownvoted = true;
                    downBtn.classList.add("active");
                    if (isUpvoted) {
                        isUpvoted = false;
                        upvotes--;
                        upBtn.classList.remove("active");
                    }
                }
                updateUI();
            });

            // ===== 1. EXPAND/COLLAPSE DESCRIPTION =====
            const desc = card.querySelector(".description") as HTMLElement;
            const descText = card.querySelector(
                ".description-text",
            ) as HTMLElement;
            const readMore = card.querySelector(".read-more") as HTMLElement;
            const readLess = card.querySelector(".read-less") as HTMLElement;

            if (desc && descText && readMore && readLess) {
                desc.classList.add("collapsed");

                readMore.addEventListener("click", () => {
                    desc.classList.remove("collapsed");
                    readMore.classList.add("hidden");
                    readLess.classList.remove("hidden");
                });

                readLess.addEventListener("click", () => {
                    desc.classList.add("collapsed");
                    readMore.classList.remove("hidden");
                    readLess.classList.add("hidden");
                });
            }

            // ===== 2. COMMENTS TOGGLE =====
            const commentToggle = card.querySelector(
                ".comment-toggle",
            ) as HTMLButtonElement;
            const commentsSection = card.querySelector(
                ".comments-section",
            ) as HTMLElement;
            const commentInput = card.querySelector(
                ".comment-input",
            ) as HTMLInputElement;
            const commentSubmit = card.querySelector(
                ".comment-submit",
            ) as HTMLButtonElement;
            const commentCountDisplay = card.querySelector(
                ".comment-toggle .action-count",
            ) as HTMLElement;
            const commentsList = card.querySelector(
                ".comments-list",
            ) as HTMLElement;
            let commentCount = parseInt(
                commentCountDisplay?.textContent || "0",
            );

            const cardHeading = cardEl.getAttribute("data-heading") || "";

            const postSlug = cardEl.getAttribute("data-slug");
            if (postSlug && commentsList) {
                const saved = JSON.parse(
                    localStorage.getItem(`comments_${postSlug}`) || "[]",
                );
                saved.forEach((c: any) => {
                    addCommentToUI(c.name, c.text, c.time, commentsList);
                });
            }

            function addCommentToUI(
                name: string,
                text: string,
                time: string,
                list: HTMLElement,
            ) {
                const div = document.createElement("div");
                div.className = "comment-item";
                const timeAgo = time || "Just now";

                // Handle image URLs if posted
                let imageHtml = "";
                let cleanText = text;
                const urlRegex = /\.(jpeg|jpg|gif|png|webp)(\?.*)?$/i;
                if (urlRegex.test(text)) {
                    imageHtml = `<div class="comment-image-wrapper"><img src="${text}" class="comment-image" alt="Comment image" /></div>`;
                    cleanText = "";
                } else {
                    cleanText = `<p class="comment-text">${text}</p>`;
                }

                div.innerHTML = `
                    <img src="/assets/icon.png" class="comment-avatar" alt="User" />
                    <div class="comment-content">
                        <div class="comment-meta">
                            <span class="comment-name">${name}</span>
                            <span class="comment-dot">•</span>
                            <span class="comment-time">${timeAgo}</span>
                        </div>
                        ${cleanText}
                        ${imageHtml}
                        <div class="comment-actions">
                            <button class="comment-action-btn">Reply</button>
                            <button class="comment-action-btn">Like</button>
                        </div>
                    </div>
                `;
                list.appendChild(div);
            }

            if (commentToggle && commentsSection) {
                commentToggle.addEventListener("click", () => {
                    commentsSection.classList.toggle("hidden");
                });
            }

            if (
                commentInput &&
                commentSubmit &&
                commentsList &&
                commentCountDisplay &&
                postSlug
            ) {
                commentSubmit.disabled = false;

                commentInput.addEventListener("input", () => {
                    const hasText = commentInput.value.trim().length > 0;
                    commentSubmit.disabled = !hasText;
                });

                const handleSubmit = () => {
                    const text = commentInput.value.trim();
                    if (!text) return;

                    const name = "You";
                    const time = "Just now";
                    addCommentToUI(name, text, time, commentsList);

                    try {
                        const saved = JSON.parse(
                            localStorage.getItem(`comments_${postSlug}`) ||
                                "[]",
                        );
                        saved.push({ name, text, time });
                        localStorage.setItem(
                            `comments_${postSlug}`,
                            JSON.stringify(saved),
                        );
                    } catch (e) {
                        console.error("localStorage error:", e);
                    }

                    commentCount++;
                    commentCountDisplay.textContent = commentCount.toString();

                    commentInput.value = "";
                    commentSubmit.disabled = true;
                };

                commentSubmit.addEventListener("click", handleSubmit);
                commentInput.addEventListener("keypress", (e) => {
                    if (e.key === "Enter") {
                        e.preventDefault();
                        handleSubmit();
                    }
                });
            }

            // ===== 3. SHARE TOGGLE =====
            const shareToggle = card.querySelector(
                ".share-toggle",
            ) as HTMLButtonElement;
            const shareSection = card.querySelector(
                ".share-section",
            ) as HTMLElement;
            const shareToast = card.querySelector(
                ".share-toast",
            ) as HTMLElement;

            if (shareToggle && shareSection) {
                shareToggle.addEventListener("click", () => {
                    shareSection.classList.toggle("hidden");
                });
            }

            card.querySelectorAll(".share-option").forEach((btn) => {
                btn.addEventListener("click", () => {
                    const action = btn.getAttribute("data-share");
                    const slug = cardEl.getAttribute("data-slug");
                    const url = `${window.location.origin}/question/${slug}`;

                    if (action === "copy") {
                        navigator.clipboard.writeText(url);
                        if (shareToast) {
                            shareToast.classList.remove("hidden");
                            setTimeout(
                                () => shareToast.classList.add("hidden"),
                                2000,
                            );
                        }
                    } else if (action === "twitter") {
                        window.open(
                            `https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(cardHeading)}`,
                            "_blank",
                        );
                    } else if (action === "facebook") {
                        window.open(
                            `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`,
                            "_blank",
                        );
                    } else if (action === "whatsapp") {
                        window.open(
                            `https://wa.me/?text=${encodeURIComponent(url)}`,
                            "_blank",
                        );
                    }
                });
            });

            // ===== 4. MORE OPTIONS =====
            const moreBtn = card.querySelector(
                ".more-btn",
            ) as HTMLButtonElement;
            const moreSection = card.querySelector(
                ".more-section",
            ) as HTMLElement;

            if (moreBtn && moreSection) {
                moreBtn.addEventListener("click", (e) => {
                    e.stopPropagation();
                    document.querySelectorAll(".more-section").forEach((s) => {
                        if (s !== moreSection) s.classList.add("hidden");
                    });
                    moreSection.classList.toggle("hidden");
                });
            }

            document.addEventListener("click", (e) => {
                if (
                    moreSection &&
                    !moreSection.contains(e.target as Node) &&
                    e.target !== moreBtn
                ) {
                    moreSection.classList.add("hidden");
                }
            });

            card.querySelectorAll(".more-option").forEach((opt) => {
                opt.addEventListener("click", () => {
                    const action = opt.getAttribute("data-action");
                    const slug = cardEl.getAttribute("data-slug");
                    const url = `${window.location.origin}/question/${slug}`;

                    if (action === "save") {
                        alert("Post saved!");
                    } else if (action === "hide") {
                        cardEl.style.display = "none";
                    } else if (action === "report") {
                        alert("Post reported. Thank you!");
                    } else if (action === "not-interested") {
                        cardEl.style.display = "none";
                    } else if (action === "copy-link") {
                        navigator.clipboard.writeText(url);
                        alert("Link copied!");
                    }
                    if (moreSection) moreSection.classList.add("hidden");
                });
            });
        });
    }
    (window as any).initPostLogic = initPostLogic;

    initPostLogic();
    document.addEventListener("astro:after-swap", initPostLogic);

    (window as any).toggleFollow = function (btn: HTMLButtonElement) {
        const author = btn.getAttribute("data-author") || "";
        let followed: string[] = JSON.parse(
            localStorage.getItem("followed_authors") || "[]",
        );

        if (btn.classList.contains("following")) {
            btn.classList.remove("following");
            btn.innerText = "Follow";
            followed = followed.filter((name) => name !== author);
        } else {
            btn.classList.add("following");
            btn.innerText = "Following";
            if (!followed.includes(author)) followed.push(author);
        }

        localStorage.setItem("followed_authors", JSON.stringify(followed));
    };

    window.addEventListener("load", () => {
        const followed: string[] = JSON.parse(
            localStorage.getItem("followed_authors") || "[]",
        );
        document.querySelectorAll(".follow-btn").forEach((btn) => {
            const author = btn.getAttribute("data-author");
            if (author && followed.includes(author)) {
                btn.classList.add("following");
                btn.textContent = "Following";
            }
        });
    });
</script>
