---
const {
  id,
  avatar,
  name,
  follow_enabled,
  role_name,
  updated_time,
  heading,
  description,
  images: rawImages,
  upvotes,
  comments,
  shares,
  slug,
} = Astro.props;

import { formatContent } from "../utils/formatContent";

// 1. Convert any data type into a clean string array
let cleanedImages: string[] = [];
if (rawImages) {
  if (typeof rawImages === "string") {
    const trimmed = rawImages.trim();
    if (trimmed.startsWith("[") && trimmed.endsWith("]")) {
      try {
        cleanedImages = JSON.parse(trimmed);
      } catch (e) {
        cleanedImages = [trimmed];
      }
    } else {
      cleanedImages = trimmed.split(",").map((i) => i.trim());
    }
  } else if (Array.isArray(rawImages)) {
    cleanedImages = rawImages.map((i) => String(i).trim());
  }
}

// 2. THE AGGRESSIVE FILTER
// This removes duplicates and ONLY keeps strings long enough to be real images
const images = [...new Set(cleanedImages)].filter((img) => {
  return (
    img && img !== "null" && img !== "undefined" && img.length > 30 // A real base64 image is thousands of characters long.
  );
});

// 3. DEBUG LOG - Check your Terminal/VS Code console
console.log(`POST [${heading}]: Found ${images.length} valid images.`);

// 4. THE ULTIMATE MEDIA HELPER
function getMediaUrl(url: string | null | undefined): string {
  // If no data, return fallback logo immediately
  if (!url || url.length < 5 || url === "null") {
    return "/assets/icon.png";
  }

  // Already a full URL or already has the data: header? Return as is.
  if (url.startsWith("http") || url.startsWith("data:")) {
    return url;
  }

  // If it's a raw Base64 string, add the correct header
  const pngHead = "iVBOR";
  const jpgHead = "/9j/";
  const webpHead = "UklG"; // This is the 'UklGR' header for WebP

  if (url.startsWith(pngHead)) return `data:image/png;base64,${url}`;
  if (url.startsWith(jpgHead)) return `data:image/jpeg;base64,${url}`;
  if (url.startsWith(webpHead)) return `data:image/webp;base64,${url}`;

  // If it matches nothing else, assume it's a local filename
  return `/assets/${url}`;
}

const displayUpvotes = upvotes;
const authorAvatar = getMediaUrl(avatar);
const postSlug =
  (slug || heading || String(id || ""))
    .toLowerCase()
    .replace(/[^\w -]+/g, "")
    .replace(/ +/g, "-")
    .replace(/-+/g, "-")
    .replace(/^-+|-+$/g, "") || String(id || "");
---

<div
  class="post-card"
  data-id={id}
  data-slug={postSlug}
  data-heading={heading}
  data-author-name={name}
>
  <!-- HEADER -->
  <div class="post-header">
    <img src={authorAvatar} alt={name} class="avatar" />
    <div class="header-main">
      <div class="header-top">
        <a href={`/user?name=${name}`} class="name">{name}</a>
        {
          follow_enabled && (
            <button
              class="follow-btn"
              data-author={name}
              onclick="window.toggleFollow(this)"
              type="button"
            >
              Follow
            </button>
          )
        }
      </div>
      <div class="header-sub">
        <span class="role">{role_name}</span>
        <span class="dot">•</span>
        <span class="time">{updated_time}</span>
      </div>
    </div>
  </div>

  <!-- BODY -->
  <div class="post-body">
    <a href={`/question/${postSlug}`} class="heading-link">
      <h2 class="heading" set:html={formatContent(heading)} />
    </a>
    <div class="description">
      <p class="description-text" set:html={formatContent(description)} />
      <button class="read-more" type="button" data-action="expand"
        >Read more</button
      >
      <button class="read-less hidden" type="button" data-action="collapse"
        >Show less</button
      >
    </div>
  </div>

  <!-- IMAGE GRID -->
  {
    images && images.length > 0 && (
      <div class={`post-images-grid grid-${Math.min(images.length, 4)}`}>
        {images.slice(0, 4).map((img: string, index: number) => {
          // ✅ FIX: Use getMediaUrl for post images
          const imgUrl = getMediaUrl(img);
          if (index === 3 && images.length > 4) {
            return (
              <div class="grid-item with-overlay">
                <img src={imgUrl} alt="" />
                <div class="more-count">+{images.length - 3}</div>
              </div>
            );
          }
          return (
            <div class="grid-item">
              <img src={imgUrl} alt="" />
            </div>
          );
        })}
      </div>
    )
  }

  <!-- FOOTER -->
  <div class="post-footer">
    <div class="vote-group">
      <button
        class="upvote-btn"
        data-count={displayUpvotes}
        aria-label="Upvote"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"></path></svg
        >
        <span class="btn-text"
          >Upvote · <span class="upvote-count"
            >{
              displayUpvotes >= 1000
                ? (displayUpvotes / 1000).toFixed(1) + "K"
                : displayUpvotes
            }</span
          ></span
        >
      </button>
      <button class="downvote-btn" aria-label="Downvote">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7"></path></svg
        >
      </button>
    </div>

    <button class="action-btn comment-toggle" aria-label="Comment">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
        ></path></svg
      >
      <span class="action-count">{comments}</span>
    </button>

    <button class="action-btn share-toggle" aria-label="Share">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline
          points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"
        ></line></svg
      >
      <span class="action-count">{shares}</span>
    </button>

    <button class="action-btn more-btn" aria-label="More options">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><circle cx="12" cy="12" r="1"></circle><circle cx="19" cy="12" r="1"
        ></circle><circle cx="5" cy="12" r="1"></circle></svg
      >
    </button>
  </div>

  <!-- COMMENTS DROPDOWN -->
  <div class="comments-section hidden">
    <div class="comments-list"></div>
    <div class="add-comment">
      <img src="/assets/icon.png" class="comment-avatar" alt="You" />
      <button class="guest-login-prompt" type="button">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path
            d="M7 11V7a5 5 0 0110 0v4"></path></svg
        >
        Login to post a comment
      </button>
    </div>
  </div>

  <!-- SHARE DROPDOWN -->
  <div class="share-section hidden">
    <div class="share-row">
      <button class="share-option" data-share="copy">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
          ></path><path
            d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
          ></path></svg
        >
        <span>Copy link</span>
      </button>
      <button class="share-option" data-share="twitter">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"
          ></path></svg
        >
        <span>Twitter</span>
      </button>
    </div>
    <div class="share-toast hidden">Link copied to clipboard!</div>
  </div>

  <!-- MORE OPTIONS DROPDOWN -->
  <div class="more-section hidden">
    <button class="more-option" data-action="save">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"
        ></path></svg
      >
      <span>Save</span>
    </button>
    <div class="more-divider"></div>
    <button class="more-option danger" data-action="report">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"
        ></path><line x1="4" y1="22" x2="4" y2="15"></line></svg
      >
      <span>Report</span>
    </button>
    <div class="more-divider"></div>
    <!-- ✅ DELETE — hidden by default, shown only to post author via JS -->
    <button
      class="more-option danger delete-post-btn hidden"
      data-action="delete"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><polyline points="3 6 5 6 21 6"></polyline><path
          d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"
        ></path></svg
      >
      <span>Delete Post</span>
    </button>
  </div>
</div>
.
<style is:global>
  /* 1. CONTAINER */
  .description-text .code-block {
    background: #1e1e1e;
    color: #d4d4d4;
    padding: 14px 18px;
    border-radius: 8px;
    overflow-x: auto;
    font-family: "Courier New", Courier, monospace;
    font-size: 13px;
    line-height: 1.5;
    margin: 10px 0;
    white-space: pre;
    border: 1px solid #333;
  }
  .description-text .inline-code {
    background: #f1f2f2;
    color: #b92b27;
    padding: 2px 6px;
    border-radius: 4px;
    font-family: "Courier New", Courier, monospace;
    font-size: 13px;
    font-weight: 500;
  }
  .post-card {
    background: white;
    border: 1px solid #e3e6ea;
    border-radius: 8px;
    padding: 16px;
    margin-bottom: 12px;
    transition: border-color 0.2s;
    overflow: hidden;
  }
  .post-card:hover {
    border-color: #ccd0d1;
  }

  /* 2. HEADER */
  .post-header {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 10px;
  }
  .avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background-color: #f7f7f7;
    object-fit: cover;
    flex-shrink: 0;
  }
  .header-main {
    flex: 1;
    min-width: 0;
  }
  .header-top {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .post-card[data-guest="true"] .upvote-btn,
  .post-card[data-guest="true"] .comment-toggle {
    position: relative;
  }
  .post-card[data-guest="true"] .upvote-btn::after,
  .post-card[data-guest="true"] .comment-toggle::after {
    content: "Login to interact";
    position: absolute;
    bottom: -25px;
    left: 50%;
    transform: translateX(-50%);
    background: #333;
    color: white;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 11px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
    z-index: 10;
  }
  .post-card[data-guest="true"] .upvote-btn:hover::after,
  .post-card[data-guest="true"] .comment-toggle:hover::after {
    opacity: 1;
  }
  .name {
    font-weight: 650;
    font-size: 13px;
    color: #2b2d31;
    cursor: pointer;
    text-decoration: none;
  }
  .name:hover {
    text-decoration: underline;
    color: #1f57f0;
  }
  .header-sub {
    margin-top: 3px;
    display: flex;
    align-items: center;
    gap: 8px;
    color: #7a7f87;
    font-size: 12px;
  }
  .dot {
    opacity: 0.6;
  }
  .follow-btn {
    border: 1px solid rgba(46, 105, 255, 0.35);
    background: #eef3ff;
    color: #1f57f0;
    font-weight: 700;
    font-size: 13px;
    padding: 7px 12px;
    border-radius: 999px;
    cursor: pointer !important;
    line-height: 1;
    transition:
      transform 0.05s ease,
      background 0.15s ease,
      border-color 0.15s ease;
  }
  .follow-btn:hover {
    background: #e2ebff;
    border-color: rgba(46, 105, 255, 0.5);
  }
  .follow-btn.following {
    background: #2e69ff;
    border-color: #2e69ff;
    color: #fff;
  }
  .guest-login-prompt {
    flex: 1;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #f3f4f6;
    border: 1px dashed #d1d5db;
    color: #6b7280;
    padding: 8px 14px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
  }
  .guest-login-prompt:hover {
    background: #eef3ff;
    border-color: #2e69ff;
    color: #2e69ff;
  }
  /* 3. BODY */
  .heading-link {
    text-decoration: none;
    color: inherit;
  }
  .heading {
    font-size: 18px;
    font-weight: 800;
    margin: 6px 0 8px;
    line-height: 1.25;
    color: #15171a;
    cursor: pointer;
  }
  .heading:hover {
    text-decoration: underline;
  }
  .description {
    font-size: 14.5px;
    color: #2a2d32;
    line-height: 1.55;
    margin-bottom: 6px;
  }
  .description-text {
    margin: 0;
  }
  .description.collapsed .description-text {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .read-more,
  .read-less {
    margin-top: 6px;
    background: none;
    border: none;
    padding: 0;
    color: #2e69ff;
    cursor: pointer;
    font-weight: 650;
  }
  .read-more:hover,
  .read-less:hover {
    text-decoration: underline;
  }
  .hidden {
    display: none !important;
  }

  /* 4. IMAGES */
  .post-images-grid {
    display: grid;
    gap: 4px;
    margin: 12px 0;
    border-radius: 8px;
    overflow: hidden;
    background: #f1f2f2;
    max-height: 400px;
  }
  .grid-item {
    position: relative;
    overflow: hidden;
    background: #e0e0e0;
  }
  .grid-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .grid-1 {
    grid-template-columns: 1fr;
  }
  .grid-1 .grid-item {
    height: 350px;
  }
  .grid-2 {
    grid-template-columns: 1fr 1fr;
  }
  .grid-2 .grid-item {
    height: 250px;
  }
  .grid-3 {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }
  .grid-3 .grid-item:nth-child(1) {
    grid-row: 1 / 3;
  }
  .grid-3 .grid-item {
    height: 100%;
  }
  .grid-4 {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }
  .grid-4 .grid-item {
    height: 180px;
  }
  .with-overlay {
    position: relative;
  }
  .more-count {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    font-weight: bold;
  }

  /* 5. FOOTER */
  .post-footer {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 12px;
    flex-wrap: wrap;
  }
  .vote-group {
    display: inline-flex;
    align-items: center;
    background: #f3f4f6;
    border: 1px solid #e3e6ea;
    border-radius: 999px;
    overflow: hidden;
  }
  .upvote-btn,
  .downvote-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    border: none;
    padding: 9px 14px;
    font-size: 13.5px;
    font-weight: 650;
    color: #525862;
    cursor: pointer;
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }
  .upvote-btn {
    border-right: 1px solid #e3e6ea;
  }
  .upvote-btn:hover,
  .downvote-btn:hover {
    background: #e9edf3;
  }
  .upvote-btn.active {
    background: #ebf0ff;
    color: #2e69ff;
  }
  .downvote-btn.active {
    color: #cb2027;
  }
  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    border: 1px solid transparent;
    color: #525862;
    font-size: 13.5px;
    font-weight: 650;
    cursor: pointer;
    padding: 9px 12px;
    border-radius: 999px;
    transition:
      background 0.15s ease,
      border-color 0.15s ease;
  }
  .action-btn:hover {
    background: #f3f4f6;
    border-color: #e3e6ea;
  }
  .more-btn {
    margin-left: auto;
  }

  /* 7. SHARE SECTION */
  .share-section {
    margin-top: 15px;
    padding: 15px;
    background: #fafafa;
    border-radius: 8px;
    position: relative;
  }
  .share-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .share-option {
    display: flex;
    align-items: center;
    gap: 8px;
    background: white;
    border: 1px solid #dee0e1;
    padding: 8px 14px;
    border-radius: 20px;
    cursor: pointer;
    font-size: 13px;
    color: #333;
    transition: all 0.2s;
  }
  .share-option:hover {
    background: #f0f0f0;
    border-color: #2e69ff;
  }
  .share-toast {
    position: absolute;
    top: -10px;
    right: 15px;
    background: #2b7a3a;
    color: white;
    padding: 5px 12px;
    border-radius: 12px;
    font-size: 12px;
    animation: fadeIn 0.3s;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-5px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* 8. MORE OPTIONS */
  .more-section {
    position: absolute;
    bottom: 50px;
    right: 15px;
    background: white;
    border: 1px solid #e3e6ea;
    border-radius: 8px;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.12);
    z-index: 100;
    min-width: 210px;
    overflow: hidden;
    padding: 4px 0;
  }
  .more-option {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    text-align: left;
    background: transparent;
    border: none;
    padding: 10px 16px;
    font-size: 13.5px;
    cursor: pointer;
    color: #282829;
    transition: background 0.15s;
  }
  .more-option:hover {
    background: #f5f6f7;
  }
  .more-option.danger {
    color: #cb2027;
  }
  .more-divider {
    height: 1px;
    background: #e3e6ea;
    margin: 4px 0;
  }

  /* 6. COMMENTS SECTION */
  .comments-section {
    margin-top: 15px !important;
    padding-top: 15px !important;
    border-top: 1px solid #eee !important;
  }
  .comment-item {
    display: flex !important;
    gap: 10px !important;
    padding: 12px 0 !important;
  }
  .comment-avatar {
    width: 32px !important;
    height: 32px !important;
    border-radius: 50% !important;
    background: #e3e6ea !important;
    flex-shrink: 0 !important;
    object-fit: cover !important;
  }
  .comment-content {
    flex: 1 !important;
    min-width: 0 !important;
  }
  .comment-meta {
    display: flex !important;
    align-items: center !important;
    gap: 6px !important;
    margin-bottom: 4px !important;
  }
  .comment-name {
    font-weight: 700 !important;
    font-size: 13px !important;
    color: #282829 !important;
  }
  .comment-dot {
    color: #939598 !important;
    font-size: 10px !important;
  }
  .comment-time {
    font-size: 12px !important;
    color: #939598 !important;
  }
  .comment-text {
    font-size: 14px !important;
    color: #282829 !important;
