  }
  .check-btn.checked {
    background: #2e69ff;
    border-color: #2e69ff;
    color: white;
  }

  /* Footer Action */
  .done-btn {
    background: #2e69ff;
    color: white;
    border: none;
    padding: 10px 24px;
    border-radius: 20px;
    font-weight: 700;
