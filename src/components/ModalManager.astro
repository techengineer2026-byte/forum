---
// src/components/ModalManager.astro
---

<dialog id="question-modal" class="modal">
  <!-- STEP 1 -->
  <div id="step-1" class="modal-content">
    <div class="modal-header">
      <button
        class="close-btn"
        id="close-modal"
        type="button"
        aria-label="Close"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="18" y1="6" x2="6" y2="18"></line><line
            x1="6"
            y1="6"
            x2="18"
            y2="18"></line></svg
        >
      </button>
      <div class="top-privacy">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          ><circle cx="12" cy="12" r="10"></circle><line
            x1="2"
            y1="12"
            x2="22"
            y2="12"></line><path
            d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
          ></path></svg
        >
        <span>Everyone</span>
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="6 9 12 15 18 9"></polyline></svg
        >
      </div>
      <div class="tabs">
        <button class="tab-btn active" id="tab-add-question" type="button"
          >Add Question</button
        >
        <button class="tab-btn" id="tab-create-post" type="button"
          >Create Post</button
        >
      </div>
    </div>

    <!-- ADD QUESTION VIEW -->
    <div id="add-question-view" class="view">
      <div class="modal-body">
        <div class="user-row">
          <div class="avatar-small" id="user-avatar-letter">U</div>
        </div>
        <div class="question-input-wrapper">
          <textarea
            id="question-textarea"
            placeholder='Start your question with "What", "How", "Why", etc.'
          ></textarea>
          <div
            id="similar-dropdown"
            class="similar-dropdown"
            style="display:none;"
          >
            <div class="similar-header">Similar Questions</div>
            <div id="similar-list" class="similar-list"></div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="cancel-btn" id="cancel-btn" type="button">Cancel</button>
        <button class="submit-btn" id="to-step-2" disabled type="button"
          >Add question</button
        >
      </div>
    </div>

    <!-- CREATE POST VIEW -->
    <div id="create-post-view" class="view hidden">
      <div class="modal-body">
        <div class="post-user-info">
          <div class="avatar-small" id="post-avatar-letter">U</div>
          <div class="user-details">
            <p class="user-name" id="post-user-name">Guest Engineer</p>
          </div>
        </div>

        <!-- RICH TEXT EDITOR -->
        <div
          id="post-editor"
          class="post-editor"
          contenteditable="true"
          data-placeholder="Say something..."
        >
        </div>

        <!-- FORMATTING TOOLBAR -->
        <div class="format-toolbar">
          <button
            class="fmt-btn"
            data-cmd="bold"
            title="Bold (Ctrl+B)"
            type="button"><strong>B</strong></button
          >
          <button
            class="fmt-btn"
            data-cmd="italic"
            title="Italic (Ctrl+I)"
            type="button"><em>I</em></button
          >
          <button
            class="fmt-btn"
            data-cmd="code"
            title="Inline Code"
            type="button"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><polyline points="16 18 22 12 16 6"></polyline><polyline
                points="8 6 2 12 8 18"></polyline></svg
            >
          </button>
          <button
            class="fmt-btn"
            data-cmd="link"
            title="Insert Link"
            type="button"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
              ></path><path
                d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
              ></path></svg
            >
          </button>
          <button class="fmt-btn" data-cmd="h2" title="Heading" type="button"
            ><span style="font-weight:800;font-size:12px">H2</span></button
          >
          <button
            class="fmt-btn"
            data-cmd="quote"
            title="Block Quote"
            type="button"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21z"
              ></path><path
                d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3z"
              ></path></svg
            >
          </button>
          <button
            class="fmt-btn"
            data-cmd="ul"
            title="Bullet List"
            type="button"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><line x1="8" y1="6" x2="21" y2="6"></line><line
                x1="8"
                y1="12"
                x2="21"
                y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line
                x1="3"
                y1="6"
                x2="3.01"
                y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"
              ></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg
            >
          </button>
        </div>

        <!-- INLINE LINK INPUT (replaces prompt()) -->
        <div id="link-input-row" class="link-input-row" style="display:none;">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#6b7280"
            stroke-width="2"
            ><path
              d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
            ></path><path
              d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
            ></path></svg
          >
          <input
            type="url"
            id="link-url-input"
            placeholder="Paste URL and press Enter..."
          />
          <button id="link-confirm-btn" class="link-confirm" type="button">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><polyline points="20 6 9 17 4 12"></polyline></svg
            >
          </button>
          <button id="link-cancel-btn" class="link-cancel" type="button">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><line x1="18" y1="6" x2="6" y2="18"></line><line
                x1="6"
                y1="6"
                x2="18"
                y2="18"></line></svg
            >
          </button>
        </div>

        <!-- IMAGE UPLOAD -->
        <div class="post-image-section">
          <input type="file" id="post-image-input" accept="image/*" multiple />
          <div id="post-image-grid" class="image-grid" style="display:none;">
          </div>
          <button class="add-image-btn" id="trigger-photo" type="button">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><rect x="3" y="3" width="18" height="18" rx="2" ry="2"
              ></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline
                points="21 15 16 10 5 21"></polyline></svg
            >
            Add Images
          </button>
        </div>
      </div>
      <div class="modal-footer post-footer">
        <div class="footer-icons">
          <button
            class="icon-btn"
            id="trigger-upload"
            type="button"
            title="Upload image"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><rect x="3" y="3" width="18" height="18" rx="2" ry="2"
              ></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline
                points="21 15 16 10 5 21"></polyline></svg
            >
          </button>
        </div>
        <button
          class="post-submit-btn"
          id="post-submit-btn"
          disabled
          type="button">Post</button
        >
      </div>
    </div>
  </div>

  <!-- STEP 2: REQUEST ANSWERS -->
  <div id="step-2" class="modal-content hidden">
    <div class="modal-toast" id="toast" style="display:none;">
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline
          points="22 4 12 14.01 9 11.01"></polyline></svg
      >
      <span class="toast-text"></span>
      <button class="close-toast" type="button">
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="18" y1="6" x2="6" y2="18"></line><line
            x1="6"
            y1="6"
            x2="18"
            y2="18"></line></svg
        >
      </button>
    </div>
    <div class="modal-header">
      <button
        class="close-btn"
        id="close-modal-2"
        type="button"
        aria-label="Close"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="18" y1="6" x2="6" y2="18"></line><line
            x1="6"
            y1="6"
            x2="18"
            y2="18"></line></svg
        >
      </button>
      <div class="request-title">
        <h3>Request Answers:</h3>
        <p id="display-question"></p>
      </div>
    </div>
    <div class="tabs-red">
      <button class="tab-red active" data-tab="suggested" type="button"
        >Suggested Writers (<span id="suggested-count">0</span>/25)</button
      >
    </div>
    <div class="search-bar">
      <input
        type="text"
        id="writer-search"
        placeholder="Search for people or Spaces"
      />
    </div>
    <div class="modal-body-split">
      <div class="side-topics">
        <p>Topics</p>
        <ul class="topic-list" id="topic-list">
          <li class="active" data-topic="all">All Topics</li>
        </ul>
      </div>
      <div class="people-list" id="people-list"></div>
    </div>
    <div class="modal-footer">
      <button class="done-btn" id="finish-btn" type="button">Done</button>
    </div>
  </div>
</dialog>

<style>
  .modal {
    border: none;
    border-radius: 12px;
    padding: 0;
    width: 680px;
    max-width: 94vw;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
    overflow: hidden;
    max-height: 90vh;
  }
  .modal::backdrop {
    background: rgba(0, 0, 0, 0.6);
  }
  .modal-content {
    max-height: 90vh;
    overflow-y: auto;
  }
  .search-bar {
    padding: 12px 20px;
    background: #fafafa;
    border-bottom: 1px solid #eee;
  }
  .search-bar input {
    width: 100%;
    padding: 9px 14px;
    border: 1px solid #dee0e1;
    border-radius: 999px;
    box-sizing: border-box;
    outline: none;
    font-size: 14px;
  }
  .search-bar input:focus {
    border-color: #2e69ff;
    box-shadow: 0 0 0 3px rgba(46, 105, 255, 0.1);
  }

  @media (max-width: 600px) {
    .modal {
      width: 100%;
      max-width: 100vw;
      max-height: 100vh;
      border-radius: 0;
      margin: 0;
    }
    .modal-content {
      max-height: 100vh;
    }
    .modal-body-split {
      height: 300px;
    }
    .side-topics {
      width: 140px;
    }
    .format-toolbar {
      flex-wrap: wrap;
    }
    .link-input-row {
      flex-wrap: wrap;
    }
    .link-input-row input {
      min-width: 0;
    }
  }
</style>

<style is:global>
  .modal-header {
    padding: 14px 20px;
    border-bottom: 1px solid #eee;
    position: relative;
    min-height: 50px;
  }
  .close-btn {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    color: #6b7280;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: all 0.15s;
  }
  .close-btn:hover {
    background: #f3f4f6;
    color: #111827;
  }
  .tabs {
    display: flex;
    justify-content: center;
    width: 100%;
    border-bottom: 1px solid #eee;
  }
  .tab-btn {
    flex: 1;
    background: none;
    border: none;
    padding: 14px;
    font-weight: 700;
    font-size: 14px;
    color: #6b7280;
    cursor: pointer;
    border-bottom: 3px solid transparent;
    transition: all 0.15s;
  }
  .tab-btn.active {
    color: #111827;
    border-bottom-color: #2e69ff;
  }
  .top-privacy {
    position: absolute;
    left: 50%;
    top: 16px;
    transform: translateX(-50%);
    font-size: 13px;
    color: #6b7280;
    display: flex;
    align-items: center;
    gap: 5px;
    cursor: pointer;
  }
  .modal-body {
    padding: 20px;
    min-height: 180px;
  }
  .user-row,
  .post-user-info {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .avatar-small {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #b92b27;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
    overflow: hidden;
  }
  .avatar-small img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .user-name {
    font-weight: 700;
    margin: 0;
    font-size: 14px;
    color: #111827;
  }
  textarea {
    width: 100%;
    border: none;
    outline: none;
    font-size: 17px;
    resize: none;
    min-height: 90px;
    box-sizing: border-box;
    font-family: inherit;
    color: #111827;
  }
  .modal-footer {
    padding: 12px 20px;
    border-top: 1px solid #eee;
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    background: #fafafa;
  }
  .post-footer {
    justify-content: space-between;
    align-items: center;
    padding: 10px 16px;
  }
  .footer-icons {
    display: flex;
    gap: 12px;
  }
  .icon-btn {
    background: none;
    border: none;
    color: #6b7280;
    cursor: pointer;
    padding: 6px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    transition: all 0.15s;
  }
  .icon-btn:hover {
    background: #f3f4f6;
    color: #111827;
  }
  .cancel-btn {
    background: none;
    border: none;
    color: #6b7280;
    font-weight: 700;
    cursor: pointer;
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 14px;
    transition: background 0.15s;
  }
  .cancel-btn:hover {
    background: #f3f4f6;
  }
  .submit-btn {
    background: #2e69ff;
    color: white;
    border: none;
    padding: 8px 22px;
    border-radius: 999px;
    font-weight: 700;
    cursor: pointer;
    font-size: 14px;
    opacity: 0.5;
    transition: all 0.15s;
  }
  .submit-btn:not([disabled]) {
    opacity: 1;
  }
  .submit-btn:not([disabled]):hover {
    background: #1e5ae6;
  }
  .post-submit-btn {
    background: #2e69ff;
    color: white;
    border: none;
    padding: 8px 24px;
    border-radius: 999px;
    font-weight: 700;
    font-size: 14px;
    opacity: 0.5;
    transition: all 0.15s;
  }
  .post-submit-btn:not([disabled]) {
    opacity: 1;
  }
  .post-submit-btn:not([disabled]):hover {
    background: #1e5ae6;
  }
  .request-title {
    padding: 0 20px;
    text-align: center;
  }
  .request-title h3 {
    margin: 14px 0 5px;
    font-size: 13px;
    color: #6b7280;
    font-weight: 600;
  }
  .request-title p {
    font-weight: 700;
    font-size: 17px;
    color: #111827;
    margin: 0 0 14px;
  }
  .tabs-red {
    display: flex;
    border-bottom: 1px solid #eee;
  }
  .tab-red {
    flex: 1;
    padding: 12px 15px;
    background: none;
    border: none;
    cursor: pointer;
    font-weight: 500;
    color: #6b7280;
    border-bottom: 3px solid transparent;
    font-size: 14px;
  }
  .tab-red.active {
    color: #2e69ff;
    border-bottom-color: #2e69ff;
    font-weight: 700;
  }
  .modal-body-split {
    display: flex;
    height: 360px;
  }
  .side-topics {
    width: 170px;
    border-right: 1px solid #eee;
    background: #fafafa;
    overflow-y: auto;
  }
  .side-topics p {
    margin: 0;
    padding: 12px 14px 8px;
    font-size: 11px;
    color: #9ca3af;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .topic-list {
    list-style: none;
    padding: 0 6px;
    margin: 0;
  }
  .topic-list li {
    padding: 8px 10px;
    cursor: pointer;
    font-size: 13px;
    border-radius: 6px;
    margin-bottom: 2px;
    color: #374151;
    transition: all 0.1s;
  }
  .topic-list li:hover {
    background: #f3f4f6;
  }
  .topic-list li.active {
    color: #2e69ff;
    background: #eef3ff;
    font-weight: 600;
  }
  .people-list {
    flex: 1;
    overflow-y: auto;
    background: white;
  }
  .people-list-header {
    padding: 12px 16px 8px;
    font-size: 11px;
    color: #9ca3af;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 1px solid #f3f4f6;
  }
  .person-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    border-bottom: 1px solid #f9fafb;
    gap: 12px;
  }
  .person-info {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
    min-width: 0;
  }
  .person-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #b92b27;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
  }
  .person-details {
    flex: 1;
    min-width: 0;
  }
  .p-name {
    font-weight: 600;
    font-size: 14px;
    margin: 0;
    color: #111827;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .p-sub {
    font-size: 12px;
    color: #9ca3af;
    margin: 2px 0 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .check-btn {
    width: 30px;
    height: 30px;
    border: 2px solid #d1d5db;
    background: white;
    cursor: pointer;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    flex-shrink: 0;
  }
  .check-btn:hover {
    border-color: #2e69ff;
  }
  .check-btn.checked {
    background: #2e69ff;
    border-color: #2e69ff;
    color: white;
  }
  .modal-toast {
    background: #059669;
    color: white;
    padding: 10px 16px;
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .close-toast {
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    padding: 2px;
    display: flex;
    margin-left: auto;
    opacity: 0.7;
  }
  .close-toast:hover {
    opacity: 1;
  }
  .no-results {
    padding: 40px 20px;
    text-align: center;
    color: #9ca3af;
    font-size: 14px;
  }
  .done-btn {
    background: #2e69ff;
    color: white;
    border: none;
    padding: 10px 32px;
    border-radius: 999px;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .done-btn:hover {
    background: #1e5ae6;
  }
  .view.hidden,
  .hidden {
    display: none !important;
  }

  /* ===== SIMILAR QUESTIONS ===== */
  .question-input-wrapper {
    position: relative;
  }
  .similar-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    z-index: 100;
    max-height: 260px;
    overflow-y: auto;
    margin-top: 4px;
  }
  .similar-header {
    padding: 10px 14px;
    font-size: 11px;
    font-weight: 700;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 1px solid #f3f4f6;
    position: sticky;
    top: 0;
    background: white;
  }
  .similar-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    cursor: pointer;
    transition: background 0.1s;
    border-bottom: 1px solid #f9fafb;
  }
  .similar-item:hover {
    background: #f8faff;
  }
  .similar-item:last-child {
    border-bottom: none;
  }
  .similar-item-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #b92b27;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
    overflow: hidden;
  }
  .similar-item-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }
  .similar-item-text {
    flex: 1;
    min-width: 0;
  }
  .similar-item-q {
    font-size: 13px;
    font-weight: 600;
    color: #111827;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .similar-item-meta {
    font-size: 11px;
    color: #9ca3af;
    margin: 2px 0 0;
  }
  .similar-item-badge {
    font-size: 10px;
    background: #fef3c7;
    color: #92400e;
    padding: 2px 8px;
    border-radius: 10px;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* ===== RICH TEXT EDITOR ===== */
  .post-editor {
    min-height: 140px;
    padding: 12px;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    outline: none;
    font-size: 15px;
    line-height: 1.6;
    color: #111827;
    overflow-y: auto;
    max-height: 280px;
    font-family: inherit;
  }
  .post-editor:empty::before {
    content: attr(data-placeholder);
    color: #9ca3af;
    pointer-events: none;
  }
  .post-editor pre {
    background: #1e1e2e;
    color: #cdd6f4;
    padding: 12px 16px;
    border-radius: 6px;
    font-size: 13px;
    overflow-x: auto;
    font-family: "Courier New", monospace;
    margin: 8px 0;
  }
  .post-editor code {
    background: #f1f2f2;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 13px;
    font-family: "Courier New", monospace;
    color: #b92b27;
  }
  .post-editor pre code {
    background: none;
    color: inherit;
    padding: 0;
  }
  .post-editor blockquote {
    border-left: 3px solid #2e69ff;
    padding-left: 12px;
    margin: 8px 0;
    color: #6b7280;
    font-style: italic;
  }
  .post-editor h2 {
    font-size: 20px;
    font-weight: 700;
    margin: 12px 0 6px;
  }
  .post-editor ul,
  .post-editor ol {
    padding-left: 24px;
    margin: 6px 0;
  }

  /* FORMAT TOOLBAR */
  .format-toolbar {
    display: flex;
    gap: 4px;
    padding: 8px 0;
    border-top: 1px solid #f3f4f6;
    margin-top: 8px;
  }
  .fmt-btn {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    color: #6b7280;
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    -webkit-tap-highlight-color: transparent;
  }
  .fmt-btn:hover {
    background: #eef3ff;
    color: #2e69ff;
    border-color: rgba(46, 105, 255, 0.3);
  }
  .fmt-btn.active {
    background: #2e69ff;
    color: white;
    border-color: #2e69ff;
  }

  /* ===== LINK INPUT ROW ===== */
  .link-input-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 0;
    border-top: 1px solid #f3f4f6;
    margin-top: 4px;
  }
  .link-input-row input {
    flex: 1;
    padding: 7px 12px;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    font-size: 14px;
    outline: none;
    min-width: 0;
  }
  .link-input-row input:focus {
    border-color: #2e69ff;
    box-shadow: 0 0 0 3px rgba(46, 105, 255, 0.1);
  }
  .link-confirm,
  .link-cancel {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    transition: background 0.15s;
  }
  .link-confirm {
    color: #059669;
  }
  .link-confirm:hover {
    background: #ecfdf5;
  }
  .link-cancel {
    color: #6b7280;
  }
  .link-cancel:hover {
    background: #f3f4f6;
  }

  /* ===== IMAGE GRID ===== */
  .post-image-section {
    margin-top: 10px;
  }
  .post-image-section input[type="file"] {
    display: none;
  }
  .add-image-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: 1px dashed #d1d5db;
    color: #6b7280;
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .add-image-btn:hover {
    border-color: #2e69ff;
    color: #2e69ff;
    background: #f8faff;
  }
  .image-grid {
    display: grid;
    gap: 6px;
    margin-bottom: 8px;
  }
  .image-grid.g1 {
    grid-template-columns: 1fr;
  }
  .image-grid.g2 {
    grid-template-columns: 1fr 1fr;
  }
  .image-grid.g3 {
    grid-template-columns: 1fr 1fr 1fr;
  }
  .image-grid.g4 {
    grid-template-columns: 1fr 1fr;
  }
  .image-grid-item {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 1;
    background: #f1f2f2;
  }
  .image-grid-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .image-grid-item .remove-img {
    position: absolute;
    top: 4px;
    right: 4px;
    background: rgba(0, 0, 0, 0.6);
    color: white;
    border: none;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .image-grid-item:hover .remove-img {
    opacity: 1;
  }
  .image-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 24px;
    font-weight: 800;
  }

  /* LOADING */
  .submit-btn.loading,
  .post-submit-btn.loading {
    opacity: 0.6;
    pointer-events: none;
    position: relative;
    color: transparent;
  }
  .submit-btn.loading::after,
  .post-submit-btn.loading::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 16px;
    height: 16px;
    margin: -8px 0 0 -8px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: btn-spin 0.5s linear infinite;
  }
  @keyframes btn-spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script>
  const GOOGLE_SHEET_URL =
    "https://script.google.com/macros/s/AKfycbywCeoEu7CNLZtgRKyy4wsnvGw8B6wpNrP5ke0RoJ6XrVfwgsmBKAlIKvli79IVAWQJxQ/exec";

  // ========== DOM ==========
  const modal = document.getElementById(
    "question-modal",
  ) as HTMLDialogElement | null;
  const addQuestionTab = document.getElementById(
    "tab-add-question",
  ) as HTMLButtonElement | null;
  const createPostTab = document.getElementById(
    "tab-create-post",
  ) as HTMLButtonElement | null;
  const addQuestionView = document.getElementById(
    "add-question-view",
  ) as HTMLElement | null;
  const createPostView = document.getElementById(
    "create-post-view",
  ) as HTMLElement | null;
  const questionTextarea = document.getElementById(
    "question-textarea",
  ) as HTMLTextAreaElement | null;
  const submitBtn = document.getElementById(
    "to-step-2",
  ) as HTMLButtonElement | null;
  const postSubmitBtn = document.getElementById(
    "post-submit-btn",
  ) as HTMLButtonElement | null;
  const displayQuestion = document.getElementById(
    "display-question",
  ) as HTMLElement | null;
  const toast = document.getElementById("toast") as HTMLElement | null;
  const step1 = document.getElementById("step-1") as HTMLElement | null;
  const step2 = document.getElementById("step-2") as HTMLElement | null;
  const cancelBtn = document.getElementById(
    "cancel-btn",
  ) as HTMLButtonElement | null;
  const closeModalBtn = document.getElementById(
    "close-modal",
  ) as HTMLButtonElement | null;
  const closeModalBtn2 = document.getElementById(
    "close-modal-2",
  ) as HTMLButtonElement | null;
  const finishBtn = document.getElementById(
    "finish-btn",
  ) as HTMLButtonElement | null;
  const postImageInput = document.getElementById(
    "post-image-input",
  ) as HTMLInputElement | null;
  const postImageGrid = document.getElementById(
    "post-image-grid",
  ) as HTMLElement | null;
  const triggerPhoto = document.getElementById(
    "trigger-photo",
  ) as HTMLButtonElement | null;
  const triggerUpload = document.getElementById(
    "trigger-upload",
  ) as HTMLButtonElement | null;
  const postUserName = document.getElementById(
    "post-user-name",
  ) as HTMLElement | null;
  const userAvatarLetter = document.getElementById(
    "user-avatar-letter",
  ) as HTMLElement | null;
  const postAvatarLetter = document.getElementById(
    "post-avatar-letter",
  ) as HTMLElement | null;
  const postEditor = document.getElementById(
    "post-editor",
  ) as HTMLElement | null;
  const similarDropdown = document.getElementById(
    "similar-dropdown",
  ) as HTMLElement | null;
  const similarList = document.getElementById(
    "similar-list",
  ) as HTMLElement | null;
  const linkInputRow = document.getElementById(
    "link-input-row",
  ) as HTMLElement | null;
  const linkUrlInput = document.getElementById(
    "link-url-input",
  ) as HTMLInputElement | null;
  const linkConfirmBtn = document.getElementById(
    "link-confirm-btn",
  ) as HTMLButtonElement | null;
  const linkCancelBtn = document.getElementById(
    "link-cancel-btn",
  ) as HTMLButtonElement | null;

  let uploadedImages: string[] = [];
  let allExistingQuestions: any[] = [];
  let savedSelection: Range | null = null;

  // ========== LOAD USER ==========
  function loadUserProfile() {
    const savedName = localStorage.getItem("currentUser") || "Guest Engineer";
    const savedAvatar = localStorage.getItem("userAvatar") || "";
    const savedRole = localStorage.getItem("userRole") || "Tech Engineer";
    const savedEmail = localStorage.getItem("userId") || "";

    (window as any).currentUserName = savedName;
    (window as any).currentUserAvatar = savedAvatar;
    (window as any).currentUserRole = savedRole;
    (window as any).currentUserId = savedEmail;

    if (postUserName) postUserName.innerText = savedName;

    [userAvatarLetter, postAvatarLetter].forEach((el) => {
      if (!el) return;
      if (savedAvatar && savedAvatar !== "icon.png" && savedAvatar !== "null") {
        let avatarUrl = savedAvatar;
        if (avatarUrl.startsWith("iVBOR") || avatarUrl.startsWith("/9j/"))
          avatarUrl = `data:image/png;base64,${avatarUrl}`;
        el.innerHTML = `<img src="${avatarUrl}" alt="" style="width:100%;height:100%;object-fit:cover;border-radius:50%" />`;
        el.style.backgroundColor = "transparent";
      } else {
        el.innerHTML = "";
        el.style.backgroundColor = "#b92b27";
        el.innerText = savedName.charAt(0).toUpperCase();
      }
    });
  }

  function slugify(text: string): string {
    return text
      .toLowerCase()
      .trim()
      .replace(/[^\w ]+/g, "")
      .replace(/ +/g, "-");
  }

  // ========== DUPLICATE CHECK ==========
  async function loadExistingQuestions() {
    try {
      const res = await fetch(`${GOOGLE_SHEET_URL}?action=getPosts`);
      allExistingQuestions = await res.json();
    } catch (err) {
      console.error("Failed to load questions for duplicate check:", err);
    }
  }

  function showSimilarQuestions(query: string) {
    if (!similarDropdown || !similarList || !query || query.length < 3) {
      if (similarDropdown) similarDropdown.style.display = "none";
      return;
    }

    const lowerQuery = query.toLowerCase();
    const matches = allExistingQuestions
      .filter((p: any) => {
        const heading = (p.heading || "").toLowerCase();
        return (
          heading.includes(lowerQuery) && (p.type === "Question" || !p.type)
        );
      })
      .slice(0, 5);

    if (matches.length === 0) {
      if (similarDropdown) similarDropdown.style.display = "none";
      return;
    }

    similarList.innerHTML = matches
      .map((q: any) => {
        const avatar = q.avatar || "";
        let avatarSrc = "";
        if (avatar && avatar !== "icon.png" && avatar !== "null") {
          if (
            avatar.startsWith("data:") ||
            avatar.startsWith("http://") ||
            avatar.startsWith("https://")
          )
            avatarSrc = avatar;
          else if (avatar.startsWith("iVBOR") || avatar.startsWith("/9j/"))
            avatarSrc = `data:image/png;base64,${avatar}`;
          else avatarSrc = `/assets/${avatar}`;
        }
        const avatarHtml = avatarSrc
          ? `<img src="${avatarSrc}" alt="" />`
          : (q.name || "U").charAt(0).toUpperCase();
        return `
        <div class="similar-item" data-slug="${q.slug || ""}">
          <div class="similar-item-avatar">${avatarHtml}</div>
          <div class="similar-item-text">
            <p class="similar-item-q">${q.heading}</p>
            <p class="similar-item-meta">${q.name || "Anonymous"} · ${q.comments || 0} answers</p>
          </div>
          <span class="similar-item-badge">Exists</span>
        </div>`;
      })
      .join("");

    similarDropdown.style.display = "block";

    similarList.querySelectorAll(".similar-item").forEach((item) => {
      item.addEventListener("click", () => {
        const slug = item.getAttribute("data-slug");
        if (slug) window.location.href = `/question/${slug}`;
        if (modal) modal.close();
      });
    });
  }

  questionTextarea?.addEventListener("input", () => {
    if (submitBtn && questionTextarea)
      submitBtn.disabled = questionTextarea.value.trim().length === 0;
    showSimilarQuestions(questionTextarea.value.trim());
  });

  document.addEventListener("click", (e) => {
    if (
      similarDropdown &&
      !similarDropdown.contains(e.target as Node) &&
      e.target !== questionTextarea
    )
      similarDropdown.style.display = "none";
  });

  // ========== SUBMIT QUESTION ==========
  submitBtn?.addEventListener("click", async () => {
    if (!questionTextarea) return;
    const questionText = questionTextarea.value.trim();
    if (!questionText) return;

    submitBtn.classList.add("loading");

    const slug = slugify(questionText);
    const userName = localStorage.getItem("currentUser") || "Guest Engineer";
    const userAvatar = localStorage.getItem("userAvatar") || "icon.png";
    const userRole = localStorage.getItem("userRole") || "Tech Engineer";

    try {
      await fetch(GOOGLE_SHEET_URL, {
        method: "POST",
        body: JSON.stringify({
          action: "create",
          type: "Question",
          avatar: userAvatar,
          name: userName,
          follow_enabled: false,
          role_name: userRole,
          updated_time: "Just now",
          heading: questionText,
          description: "",
          images: [],
          upvotes: 0,
          comments: 0,
          shares: 0,
          slug,
        }),
      });
    } catch (err) {
      console.error("Sheet save error:", err);
    }

    window.dispatchEvent(new CustomEvent("post-added"));

    if (displayQuestion) displayQuestion.innerText = questionText;

    if (toast) {
      toast.style.display = "flex";
      toast.querySelector(".toast-text")!.textContent =
        "Question saved successfully!";
      toast.querySelector(".close-toast")?.addEventListener("click", () => {
        toast.style.display = "none";
      });
    }

    submitBtn.classList.remove("loading");
    submitBtn.innerText = "Add question";

    if (step1 && step2) {
      step1.classList.add("hidden");
      step2.classList.remove("hidden");
    }
  });

  // ========== RICH TEXT FORMATTING ==========
  document.querySelectorAll(".fmt-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      if (!postEditor) return;
      const cmd = btn.getAttribute("data-cmd");

      if (cmd === "bold") document.execCommand("bold");
      else if (cmd === "italic") document.execCommand("italic");
      else if (cmd === "code") {
        const sel = window.getSelection();
        if (sel && sel.toString().length > 0) {
          const range = sel.getRangeAt(0);
          const code = document.createElement("code");
          range.surroundContents(code);
        } else {
          document.execCommand(
            "insertHTML",
            false,
            "<code>code here</code>&nbsp;",
          );
        }
      } else if (cmd === "link") {
        // Save selection before showing link input
        const sel = window.getSelection();
        if (sel && sel.rangeCount > 0)
          savedSelection = sel.getRangeAt(0).cloneRange();
        if (linkInputRow) linkInputRow.style.display = "flex";
        if (linkUrlInput) linkUrlInput.value = "";
        setTimeout(() => linkUrlInput?.focus(), 50);
        return; // Don't refocus editor
      } else if (cmd === "h2")
        document.execCommand("formatBlock", false, "<h2>");
      else if (cmd === "quote")
        document.execCommand("formatBlock", false, "<blockquote>");
      else if (cmd === "ul") document.execCommand("insertUnorderedList");

      postEditor.focus();
      btn.classList.toggle("active");
      setTimeout(() => btn.classList.remove("active"), 200);
    });
  });

  // Link insertion logic
  function insertLink() {
    if (!linkUrlInput || !postEditor) return;
    const url = linkUrlInput.value.trim();
    if (!url) return;

    postEditor.focus();
    if (savedSelection) {
      const sel = window.getSelection();
      sel?.removeAllRanges();
      sel?.addRange(savedSelection);
    }
    document.execCommand("createLink", false, url);
    if (linkInputRow) linkInputRow.style.display = "none";
    linkUrlInput.value = "";
    savedSelection = null;
  }

  linkConfirmBtn?.addEventListener("click", insertLink);
  linkUrlInput?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      insertLink();
    }
    if (e.key === "Escape") {
      if (linkInputRow) linkInputRow.style.display = "none";
    }
  });
  linkCancelBtn?.addEventListener("click", () => {
    if (linkInputRow) linkInputRow.style.display = "none";
    postEditor?.focus();
  });

  // Enable/disable post button
  postEditor?.addEventListener("input", () => {
    if (postSubmitBtn)
      postSubmitBtn.disabled = (postEditor.innerText || "").trim().length === 0;
  });

  // ========== IMAGE GRID ==========
  triggerPhoto?.addEventListener("click", () => postImageInput?.click());
  triggerUpload?.addEventListener("click", () => postImageInput?.click());

  postImageInput?.addEventListener("change", (e) => {
    const files = (e.target as HTMLInputElement).files;
    if (!files || files.length === 0) return;
    Array.from(files).forEach((file) => {
      const reader = new FileReader();
      reader.onload = () => {
        uploadedImages.push(reader.result as string);
        renderImageGrid();
      };
      reader.readAsDataURL(file);
    });
  });

  function renderImageGrid() {
    if (!postImageGrid) return;
    if (uploadedImages.length === 0) {
      postImageGrid.style.display = "none";
      return;
    }

    postImageGrid.style.display = "grid";
    const count = uploadedImages.length;
    postImageGrid.className = "image-grid";
    if (count === 1) postImageGrid.classList.add("g1");
    else if (count === 2) postImageGrid.classList.add("g2");
    else if (count === 3) postImageGrid.classList.add("g3");
    else postImageGrid.classList.add("g4");

    const maxShow = 4;
    const visible = uploadedImages.slice(0, maxShow);
    const extra = count - maxShow;

    postImageGrid.innerHTML = visible
      .map((img, idx) => {
        const isLast = idx === maxShow - 1 && extra > 0;
        const overlay = isLast
          ? `<div class="image-overlay">+${extra}</div>`
          : "";
        return `
        <div class="image-grid-item" data-index="${idx}">
          <img src="${img}" alt="Upload ${idx + 1}" />
          <button class="remove-img" data-index="${idx}" type="button">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
          ${overlay}
        </div>`;
      })
      .join("");

    postImageGrid.querySelectorAll(".remove-img").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const idx = parseInt(
          (btn as HTMLButtonElement).getAttribute("data-index") || "0",
        );
        uploadedImages.splice(idx, 1);
        renderImageGrid();
      });
    });
  }

  // ========== POST SUBMIT ==========
  postSubmitBtn?.addEventListener("click", async () => {
    if (!postEditor) return;
    const postText = postEditor.innerText.trim();
    if (!postText) return;

    postSubmitBtn.classList.add("loading");
    postSubmitBtn.innerText = "Posting...";

    const userName = localStorage.getItem("currentUser") || "Guest Engineer";
    const userAvatar = localStorage.getItem("userAvatar") || "icon.png";
    const userRole = localStorage.getItem("userRole") || "Tech Engineer";

    const slug = slugify(postText);
    const htmlContent = postEditor.innerHTML;

    try {
      await fetch(GOOGLE_SHEET_URL, {
        method: "POST",
        body: JSON.stringify({
          action: "create",
          type: "Post",
          avatar: userAvatar,
          name: userName,
          follow_enabled: false,
          role_name: userRole,
          updated_time: "Just now",
          heading: postText,
          description: htmlContent,
          images: uploadedImages,
          upvotes: 0,
          comments: 0,
          shares: 0,
          slug,
        }),
      });
    } catch (err) {
      console.error("Sheet save error:", err);
    }

    window.dispatchEvent(new CustomEvent("post-added"));

    setTimeout(() => {
      modal?.close();
      postSubmitBtn.classList.remove("loading");
      postSubmitBtn.innerText = "Post";
    }, 500);
  });

  // ========== TAB SWITCHING ==========
  createPostTab?.addEventListener("click", () => {
    createPostTab.classList.add("active");
    addQuestionTab?.classList.remove("active");
    createPostView?.classList.remove("hidden");
    addQuestionView?.classList.add("hidden");
  });
  addQuestionTab?.addEventListener("click", () => {
    addQuestionTab.classList.add("active");
    createPostTab?.classList.remove("active");
    addQuestionView?.classList.remove("hidden");
    createPostView?.classList.add("hidden");
  });

  // ========== CLOSE ==========
  cancelBtn?.addEventListener("click", () => modal?.close());
  closeModalBtn?.addEventListener("click", () => modal?.close());
  closeModalBtn2?.addEventListener("click", () => modal?.close());
  finishBtn?.addEventListener("click", () => modal?.close());

  modal?.addEventListener("close", () => {
    if (step1 && step2) {
      step1.classList.remove("hidden");
      step2.classList.add("hidden");
    }
    if (questionTextarea) questionTextarea.value = "";
    if (postEditor) postEditor.innerHTML = "";
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.classList.remove("loading");
      submitBtn.innerText = "Add question";
    }
    if (postSubmitBtn) {
      postSubmitBtn.disabled = true;
      postSubmitBtn.classList.remove("loading");
      postSubmitBtn.innerText = "Post";
    }
    if (postImageInput) postImageInput.value = "";
    uploadedImages = [];
    if (postImageGrid) postImageGrid.style.display = "none";
    if (similarDropdown) similarDropdown.style.display = "none";
    if (linkInputRow) linkInputRow.style.display = "none";
    if (addQuestionTab && createPostTab) {
      addQuestionTab.classList.add("active");
      createPostTab.classList.remove("active");
    }
    if (addQuestionView && createPostView) {
      addQuestionView.classList.remove("hidden");
      createPostView.classList.add("hidden");
    }
  });

  loadUserProfile();
  loadExistingQuestions();

  // ========== WRITER ENGINE ==========
  import {
    searchWriters,
    filterByTopic,
    getAllTopics,
    renderWriters,
  } from "../scripts/writerEngine";

  const writerSearch = document.getElementById(
    "writer-search",
  ) as HTMLInputElement | null;
  const peopleList = document.getElementById(
    "people-list",
  ) as HTMLElement | null;
  const topicList = document.getElementById("topic-list") as HTMLElement | null;
  const suggestedCount = document.getElementById("suggested-count");

  async function renderTopics() {
    if (!topicList) return;
    const topics = await getAllTopics();
    topicList.innerHTML = '<li class="active" data-topic="all">All Topics</li>';
    topics.forEach((topic) => {
      const li = document.createElement("li");
      li.setAttribute("data-topic", topic.toLowerCase());
      li.innerText = topic;
      topicList.appendChild(li);
    });
  }

  function renderPeople(list: any[]) {
    if (!peopleList) return;
    peopleList.innerHTML = "";
    const header = document.createElement("div");
    header.className = "people-list-header";
    header.innerText =
      list.length > 0 ? `${list.length} writers found` : "No writers";
    peopleList.appendChild(header);
    if (list.length === 0) {
      const empty = document.createElement("div");
      empty.className = "no-results";
      empty.innerText = "Try a different search or topic";
      peopleList.appendChild(empty);
      if (suggestedCount) suggestedCount.innerText = "0";
      return;
    }
    const writers = renderWriters(list);
    writers.forEach((el) => peopleList.appendChild(el));
    if (suggestedCount) suggestedCount.innerText = list.length.toString();

    peopleList.querySelectorAll(".check-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const target = e.currentTarget as HTMLButtonElement;
        target.classList.toggle("checked");
        target.innerHTML = target.classList.contains("checked")
          ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>'
          : "";
      });
    });
  }

  async function initWriters() {
    await renderTopics();
    const allWriters = await searchWriters("");
    renderPeople(allWriters);
  }
  initWriters();

  writerSearch?.addEventListener("input", async (e) => {
    const results = await searchWriters((e.target as HTMLInputElement).value);
    renderPeople(results);
  });

  topicList?.addEventListener("click", async (e) => {
    const target = e.target as HTMLElement;
    if (!target.matches("li")) return;
    topicList
      .querySelectorAll("li")
      .forEach((li) => li.classList.remove("active"));
    target.classList.add("active");
    const topic = target.getAttribute("data-topic") || "all";
    const results = await filterByTopic(topic);
    renderPeople(results);
  });
</script>
