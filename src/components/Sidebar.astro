---
// src/components/Sidebar.astro
import CreateSpaceModal from "./CreateSpaceModal.astro";
---

<div class="sidebar-container">
  <button class="create-space-btn" id="createSpaceBtn" type="button">
    <span class="plus-icon">+</span>
    Create Space
  </button>

  <nav class="spaces-list">
    <ul id="spaces-ul">
      <li class="loading-spaces">Loading spaces...</li>
    </ul>
  </nav>

  <button id="toggle-spaces-btn" class="toggle-btn hidden" type="button">
    Show All Spaces
  </button>

  <footer class="sidebar-footer">
    <p>
      About · Careers · Terms · Privacy · Acceptable Use · Advertise · Ad
      Choices · Grievance Officer
    </p>
  </footer>
</div>

<CreateSpaceModal />

<style>
  .sidebar-container {
    width: 100%;
    max-width: 170px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    position: sticky;
    top: 80px;
  }

  .create-space-btn {
    display: flex;
    align-items: center;
    background-color: #f1f2f2;
    border: 1px solid #dee0e1;
    border-radius: 4px;
    padding: 8px 12px;
    color: #636466;
    font-size: 13px;
    cursor: pointer;
    margin-bottom: 8px;
    transition: background 0.2s;
    width: 100%;
    text-align: left;
  }
  .create-space-btn:hover {
    background-color: #e3e5e5;
  }
  .plus-icon {
    font-size: 18px;
    margin-right: 8px;
    font-weight: 300;
    line-height: 1;
  }

  .spaces-list ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .space-item {
    display: flex;
    align-items: center;
    padding: 8px;
    border-radius: 4px;
    cursor: pointer;
    transition:
      background 0.2s,
      opacity 0.3s;
  }
  .space-item:hover {
    background-color: #e6e6e6;
  }
  .space-item.filtered-out {
    display: none;
  }

  .icon-wrapper {
    position: relative;
    width: 22px;
    height: 22px;
    margin-right: 12px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }
  .icon-wrapper img {
    width: 100%;
    height: 100%;
    border-radius: 4px;
    object-fit: cover;
  }
  .letter-icon {
    font-size: 13px;
    font-weight: 700;
    color: white;
    line-height: 1;
    user-select: none;
  }

  .member-count {
    margin-left: auto;
    background: #e3e6ea;
    color: #6b7280;
    font-size: 11px;
    font-weight: 700;
    padding: 1px 7px;
    border-radius: 10px;
  }

  .space-name {
    font-size: 13px;
    color: #636466;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .toggle-btn {
    background: none;
    border: none;
    color: #2e69ff;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    padding: 8px;
    text-align: left;
    width: 100%;
  }
  .toggle-btn:hover {
    text-decoration: underline;
  }

  .sidebar-footer {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid #dee0e1;
  }
  .sidebar-footer p {
    font-size: 12px;
    color: #939598;
    line-height: 1.5;
    cursor: pointer;
  }

  .loading-spaces {
    padding: 12px 8px;
    font-size: 12px;
    color: #9ca3af;
    text-align: center;
  }

  .hidden {
    display: none !important;
  }
</style>

<script>
  const SCRIPT_URL =
    "https://script.google.com/macros/s/AKfycbxlZOW0AuGlzMPuNZ5bGKYiK_DNZp8geGUwrYopvp-lezOxlIjb761sS7aDLPJlRrqDHg/exec";

  // ✅ CORS-safe fetch helper
  async function fetchScript(
    action: string,
    params: Record<string, any> = {},
    method: "GET" | "POST" = "GET",
  ) {
    const url = new URL(SCRIPT_URL);
    url.searchParams.append("action", action);

    if (method === "GET") {
      Object.keys(params).forEach((key) => {
        if (params[key] !== undefined && params[key] !== null) {
          url.searchParams.append(key, String(params[key]));
        }
      });
    }

    const options: RequestInit = {
      method,
      redirect: "follow",
      headers: {
        "Content-Type": "text/plain;charset=utf-8",
      },
    };

    if (method === "POST") {
      options.body = JSON.stringify(params);
    }

    const response = await fetch(url.toString(), options);
    return response.json();
  }

  // ✅ Load spaces from server
  async function loadSpaces() {
    const userEmail = localStorage.getItem("userId") || "";
    const ul = document.getElementById("spaces-ul");
    if (!ul) return;

    try {
      const spaces = await fetchScript(
        "getSpaces",
        { email: userEmail },
        "GET",
      );

      ul.innerHTML = "";

      if (!spaces || spaces.length === 0) {
        ul.innerHTML =
          '<li class="loading-spaces">No spaces yet. Create one!</li>';
        return;
      }

      spaces.forEach((space: any) => {
        const li = document.createElement("li");
        li.className = "space-item";
        li.setAttribute("data-topic", space.name);
        li.setAttribute("data-space-id", space.id);

        const initial = space.name.charAt(0).toUpperCase();
        const color = space.color || "#2e69ff";

        li.innerHTML = `
          <div class="icon-wrapper" style="background-color: ${color}; border-radius: 4px;">
            ${
              space.icon
                ? `<img src="/assets/${space.icon}" alt="${space.name}" onerror="this.style.display='none';" />`
                : `<span class="letter-icon">${initial}</span>`
            }
          </div>
          <span class="space-name">${escapeHtml(space.name)}</span>
          ${space.members > 0 ? `<span class="member-count">${space.members}</span>` : ""}
        `;

        li.addEventListener("click", () => {
          window.location.href = `/space/${space.id}`;
        });

        ul.appendChild(li);
      });

      filterSidebar();
    } catch (err) {
      console.error("Load spaces error:", err);
      if (ul)
        ul.innerHTML = '<li class="loading-spaces">Could not load spaces</li>';
    }
  }

  // ✅ Escape HTML to prevent XSS
  function escapeHtml(text: string): string {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  // ✅ Normalize strings for better matching
  function normalize(str: string): string {
    return str
      .toLowerCase()
      .replace(/[&]/g, "and")
      .replace(/[-_]/g, " ")
      .replace(/[^\w\s]/g, "")
      .replace(/\s+/g, " ")
      .trim();
  }

  function topicMatches(spaceTopic: string, userInterests: string[]): boolean {
    const normalizedSpace = normalize(spaceTopic);

    for (const interest of userInterests) {
      const normalizedInterest = normalize(interest);

      if (normalizedSpace === normalizedInterest) return true;
      if (
        normalizedSpace.length > 3 &&
        normalizedInterest.includes(normalizedSpace)
      )
        return true;
      if (
        normalizedInterest.length > 3 &&
        normalizedSpace.includes(normalizedInterest)
      )
        return true;

      const interestWords = normalizedInterest
        .split(" ")
        .filter((w) => w.length > 3);
      const spaceWords = normalizedSpace.split(" ").filter((w) => w.length > 3);

      for (const word of interestWords) {
        if (spaceWords.includes(word)) return true;
      }
    }

    return false;
  }

  function filterSidebar() {
    const userInterests = localStorage.getItem("userInterests") || "";
    const spaceItems = document.querySelectorAll(".space-item");
    const toggleBtn = document.getElementById("toggle-spaces-btn");

    if (!userInterests || userInterests.trim().length === 0) {
      spaceItems.forEach((item) => item.classList.remove("filtered-out"));
      if (toggleBtn) toggleBtn.classList.add("hidden");
      return;
    }

    const interestsArray = userInterests
      .split(",")
      .map((t) => t.trim())
      .filter(Boolean);
    let hiddenCount = 0;

    spaceItems.forEach((item) => {
      const topic = item.getAttribute("data-topic") || "";

      if (topicMatches(topic, interestsArray)) {
        item.classList.remove("filtered-out");
      } else {
        item.classList.add("filtered-out");
        hiddenCount++;
      }
    });

    if (toggleBtn) {
      if (hiddenCount > 0) {
        toggleBtn.classList.remove("hidden");
        toggleBtn.innerText = `Show All Spaces (${hiddenCount} more)`;
      } else {
        toggleBtn.classList.add("hidden");
      }
    }
  }

  // Run on load
  loadSpaces();

  // Re-run on events
  window.addEventListener("user-logged-in", loadSpaces);
  window.addEventListener("interests-updated", loadSpaces);
  window.addEventListener("space-created", loadSpaces);
  window.addEventListener("storage", (e) => {
    if (e.key === "userInterests") filterSidebar();
  });

  // Toggle button
  const toggleBtn = document.getElementById("toggle-spaces-btn");
  let showingAll = false;

  toggleBtn?.addEventListener("click", () => {
    const spaceItems = document.querySelectorAll(".space-item");
    showingAll = !showingAll;

    if (showingAll) {
      spaceItems.forEach((item) => item.classList.remove("filtered-out"));
      if (toggleBtn) toggleBtn.innerText = "Show Only My Interests";
    } else {
      filterSidebar();
    }
  });
</script>
