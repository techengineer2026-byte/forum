---
import CreateSpaceModal from "./CreateSpaceModal.astro";
---

<div class="sidebar-container">
  <button class="create-space-btn" id="createSpaceBtn" type="button">
    <span class="plus-icon">+</span>
    Create Space
  </button>

  <nav class="spaces-list">
    <ul id="spaces-ul">
      <li class="loading-spaces">Loading spaces...</li>
    </ul>
  </nav>

  <button id="toggle-spaces-btn" class="toggle-btn hidden" type="button">
    Show All Spaces
  </button>

  <footer class="sidebar-footer">
    <p>About · Terms · Privacy · Contact · Advertise</p>
  </footer>
</div>

<CreateSpaceModal />

<style is:global>
  .sidebar-container {
    width: 100%;
    max-width: 170px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    position: sticky;
    top: 80px;
  }

  .create-space-btn {
    display: flex;
    align-items: center;
    background-color: #f1f2f2;
    border: 1px solid #dee0e1;
    border-radius: 4px;
    padding: 8px 12px;
    color: #636466;
    font-size: 13px;
    cursor: pointer;
    margin-bottom: 8px;
    transition: background 0.2s;
    width: 100%;
    text-align: left;
  }
  .create-space-btn:hover {
    background-color: #e3e5e5;
  }
  .plus-icon {
    font-size: 18px;
    margin-right: 8px;
    font-weight: 300;
    line-height: 1;
  }

  .spaces-list ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .space-item {
    display: flex;
    align-items: center;
    padding: 8px;
    border-radius: 4px;
    cursor: pointer;
    transition:
      background 0.2s,
      opacity 0.3s;
  }
  .space-item:hover {
    background-color: #e6e6e6;
  }
  .space-item.filtered-out {
    display: none;
  }

  .icon-wrapper {
    position: relative;
    width: 22px;
    height: 22px;
    margin-right: 12px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }
  .icon-wrapper img {
    width: 100%;
    height: 100%;
    border-radius: 4px;
    object-fit: cover;
  }
  .letter-icon {
    font-size: 13px;
    font-weight: 700;
    color: white;
    line-height: 1;
    user-select: none;
  }

  .member-count {
    margin-left: auto;
    background: #e3e6ea;
    color: #6b7280;
    font-size: 11px;
    font-weight: 700;
    padding: 1px 7px;
    border-radius: 10px;
  }

  .space-name {
    font-size: 13px;
    color: #636466;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .toggle-btn {
    background: none;
    border: none;
    color: #2e69ff;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    padding: 8px;
    text-align: left;
    width: 100%;
  }
  .toggle-btn:hover {
    text-decoration: underline;
  }

  .sidebar-footer {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid #dee0e1;
  }
  .sidebar-footer p {
    font-size: 12px;
    color: #939598;
    line-height: 1.5;
    cursor: pointer;
  }

  .loading-spaces {
    padding: 12px 8px;
    font-size: 12px;
    color: #9ca3af;
    text-align: center;
  }

  .hidden {
    display: none !important;
  }
</style>
<script>
  // ✅ NOW POINTING TO YOUR LOCAL SURVER, NOT GOOGLE DIRECTLY
  async function loadSpaces() {
    const userEmail = localStorage.getItem("userId") || "";
    const ul = document.getElementById("spaces-ul");
    if (!ul) return;

    try {
      // ✅ Call your local Astro API route
      const response = await fetch(
        `/api/get-spaces?userEmail=${encodeURIComponent(userEmail)}`,
      );
      const spaces = await response.json();

      if (!spaces || !Array.isArray(spaces)) {
        ul.innerHTML = '<li class="loading-spaces">No spaces found.</li>';
        return;
      }

      ul.innerHTML = "";

      spaces.forEach((space) => {
        const li = document.createElement("li");
        li.className = "space-item";
        li.setAttribute("data-topic", space.name || "");
        li.setAttribute("data-is-member", String(space.isMember));

        const initial = space.name ? space.name.charAt(0).toUpperCase() : "?";
        const color = space.color || "#2e69ff";
        const slug = space.slug || "space";

        li.innerHTML = `
          <div class="icon-wrapper" style="background-color: ${color}; border-radius: 4px;">
            ${space.icon ? `<img src="/assets/${space.icon}" alt="" onerror="this.style.display='none';" />` : `<span class="letter-icon">${initial}</span>`}
          </div>
          <span class="space-name">${space.name}</span>
          ${space.members > 0 ? `<span class="member-count">${space.members}</span>` : ""}
        `;

        li.addEventListener("click", () => {
          window.location.href = `/space/${slug}`;
        });

        ul.appendChild(li);
      });

      // Import and run your filter logic here if needed
      filterSidebar();
    } catch (err) {
      console.error("❌ SideBar Error:", err);
      ul.innerHTML = '<li class="loading-spaces">Error loading sidebar</li>';
    }
  }

  // Reuse your filterSidebar function from before...
  function filterSidebar() {
    const userInterests = localStorage.getItem("userInterests") || "";
    const spaceItems = document.querySelectorAll(".space-item");
    if (!userInterests || userInterests.trim() === "") {
      spaceItems.forEach((item) => item.classList.remove("filtered-out"));
      return;
    }
    const interestsArray = userInterests
      .toLowerCase()
      .split(",")
      .map((i) => i.trim());
    spaceItems.forEach((item) => {
      const topic = (item.getAttribute("data-topic") || "").toLowerCase();
      const isMember = item.getAttribute("data-is-member") === "true";
      const matchesInterest = interestsArray.some((interest) =>
        topic.includes(interest),
      );
      if (isMember || matchesInterest) item.classList.remove("filtered-out");
      else item.classList.add("filtered-out");
    });
  }

  // Initial load
  loadSpaces();

  // Listen for events
  window.addEventListener("user-logged-in", loadSpaces);
  window.addEventListener("space-created", loadSpaces);
</script>
