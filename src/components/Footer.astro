<footer class="footer">
    <div class="footer-container">
        <div class="footer-links">
            <a href="https://techengineer.co">Main Website</a>
            <a href="/about">About Forum</a>
            <a href="/guidelines">Community Guidelines</a>
            <a href="/privacy">Privacy</a>
            <a href="/terms">Terms</a>
        </div>

        <div class="footer-copy">
            <p>
                &copy; {new Date().getFullYear()} TechEngineer. Built for Developers.
            </p>
        </div>
    </div>
</footer>

<style>
    .footer {
        background: white;
        border-top: 1px solid #e0e0e0;
        padding: 40px 0;
        color: #666;
        font-size: 14px;
    }

    .footer-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 15px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
    }

    .footer-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 20px;
    }

    .footer-links a {
        color: #666;
        padding: 4px 0; /* adds vertical tap area */

        text-decoration: none;
        transition: color 0.2s;
    }

    .footer-links a:hover {
        color: #1a4a7c;
        text-decoration: underline;
    }

    .footer-copy {
        text-align: center;
        opacity: 0.8;
    }

    /* Mobile Responsive */
    @media (max-width: 600px) {
        .footer {
            padding: 25px 0;
        }
        .footer-links {
            gap: 12px;
            flex-direction: column;
            align-items: center;
        }
        .footer-links a {
            font-size: 13px;
        }
    }
</style>
