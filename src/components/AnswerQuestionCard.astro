---
const { id, question, stats, slug, answerCount, authorName, authorAvatar } =
  Astro.props;
---

<div class="answer-card" data-id={id} data-slug={slug}>
  <div class="answer-card-body">
    <h3 class="answer-question">{question}</h3>
    <p class="answer-stats">{stats}</p>
  </div>
  <div class="answer-card-actions">
    <button class="answer-btn" type="button" data-slug={slug}>
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
        ></path></svg
      >
      Answer
    </button>
    <button class="follow-btn-sm" type="button">
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"
        ></path></svg
      >
      Follow
    </button>
  </div>
</div>

<style>
  .answer-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 18px;
    border-bottom: 1px solid #f0f0f0;
    gap: 16px;
    transition: background 0.15s;
  }
  .answer-card:hover {
    background: #fafbfd;
  }
  .answer-card:last-child {
    border-bottom: none;
  }
  .answer-card-body {
    flex: 1;
    min-width: 0;
  }
  .answer-question {
    font-size: 15px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 5px;
    line-height: 1.35;
    cursor: pointer;
  }
  .answer-question:hover {
    color: #2e69ff;
  }
  .answer-stats {
    font-size: 12px;
    color: #939598;
    margin: 0;
  }
  .answer-card-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }
  .answer-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #eef3ff;
    color: #2e69ff;
    border: 1px solid rgba(46, 105, 255, 0.25);
    padding: 7px 16px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.15s;
  }
  .answer-btn:hover {
    background: #e2ebff;
    border-color: rgba(46, 105, 255, 0.5);
  }
  .follow-btn-sm {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: white;
    color: #636466;
    border: 1px solid #dee0e1;
    padding: 7px 14px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }
  .follow-btn-sm:hover {
    border-color: #b92b27;
    color: #b92b27;
    background: #fef7f7;
  }
  .follow-btn-sm.following {
    background: #b92b27;
    color: white;
    border-color: #b92b27;
  }

  @media (max-width: 600px) {
    .answer-card {
      flex-direction: column;
      align-items: flex-start;
    }
    .answer-card-actions {
      width: 100%;
    }
    .answer-btn,
    .follow-btn-sm {
      flex: 1;
      justify-content: center;
    }
  }
</style>

<script>
  const SCRIPT_URL =
    "https://script.google.com/macros/s/AKfycbywCeoEu7CNLZtgRKyy4wsnvGw8B6wpNrP5ke0RoJ6XrVfwgsmBKAlIKvli79IVAWQJxQ/exec";

  document.querySelectorAll(".answer-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const slug = btn.getAttribute("data-slug");
      if (slug) {
        window.location.href = `/question/${slug}`;
      }
    });
  });

  document.querySelectorAll(".answer-question").forEach((q) => {
    q.addEventListener("click", () => {
      const card = q.closest(".answer-card");
      const slug = card?.getAttribute("data-slug");
      if (slug) {
        window.location.href = `/question/${slug}`;
      }
    });
  });

  // Follow buttons
  document.querySelectorAll(".follow-btn-sm").forEach((btn) => {
    btn.addEventListener("click", () => {
      if (!localStorage.getItem("userId")) {
        window.dispatchEvent(new CustomEvent("show-login-modal"));
        return;
      }

      if (btn.classList.contains("following")) {
        btn.classList.remove("following");
        btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg> Follow`;
      } else {
        btn.classList.add("following");
        btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg> Following`;
      }
    });
  });
</script>
