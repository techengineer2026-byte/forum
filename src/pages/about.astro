---
import Layout from "../layouts/Layout.astro";
import { getWriters } from "../data/writers";

const writers = await getWriters();
const topWriters = writers.slice(0, 6);
---

<Layout title="About - Tech Engineer" showFooter={false}>
  <div class="about-page">
    <!-- HERO -->
    <section class="hero">
      <div class="hero-badge">🚀 Built for Engineers</div>
      <h1>
        Where Engineers <span class="highlight">Share, Learn</span> & Grow Together
      </h1>
      <p class="hero-sub">
        TechEngineer is a community-driven platform where tech professionals ask
        questions, share knowledge, and level up their careers.
      </p>
      <div class="hero-actions">
        <a href="/" class="btn-primary">Explore Spaces</a>
        <a href="/notifications" class="btn-ghost">Read Discussions</a>
      </div>
    </section>

    <!-- LIVE STATS -->
    <section class="stats-section">
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-number" id="stat-posts">0</span>
          <span class="stat-label">Questions & Posts</span>
        </div>
        <div class="stat-card">
          <span class="stat-number" id="stat-users">0</span>
          <span class="stat-label">Engineers</span>
        </div>
        <div class="stat-card">
          <span class="stat-number" id="stat-spaces">0</span>
          <span class="stat-label">Spaces</span>
        </div>
        <div class="stat-card">
          <span class="stat-number" id="stat-answers">0</span>
          <span class="stat-label">Answers Given</span>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="how-section">
      <h2>How It Works</h2>
      <div class="how-grid">
        <div class="how-card">
          <div class="how-icon" style="background:#eef3ff; color:#2e69ff;">
            ❓
          </div>
          <h3>Ask a Question</h3>
          <p>
            Stuck on a problem? Post your question and get help from experienced
            engineers worldwide.
          </p>
        </div>
        <div class="how-card">
          <div class="how-icon" style="background:#e6f4ea; color:#1e8e3e;">
            💡
          </div>
          <h3>Share Knowledge</h3>
          <p>
            Answer questions, write posts, and share your expertise with the
            community.
          </p>
        </div>
        <div class="how-card">
          <div class="how-icon" style="background:#fce4ec; color:#b92b27;">
            📈
          </div>
          <h3>Grow Together</h3>
          <p>
            Join Spaces, follow topics, upvote the best answers, and build your
            reputation.
          </p>
        </div>
      </div>
    </section>

    <!-- TOP CONTRIBUTORS -->
    {
      topWriters.length > 0 && (
        <section class="contributors-section">
          <h2>Top Contributors</h2>
          <p class="section-sub">Meet the engineers shaping our community</p>
          <div class="contributors-grid">
            {topWriters.map((w) => (
              <div class="contributor-card">
                <div
                  class="contributor-avatar"
                  style={`background-color: ${w.color}`}
                >
                  {w.avatar && w.avatar.startsWith("http") ? (
                    <img src={w.avatar} alt={w.name} />
                  ) : (
                    <span>{w.initials}</span>
                  )}
                </div>
                <p class="contributor-name">{w.name}</p>
                <p class="contributor-expertise">{w.expertise}</p>
                {w.topics.length > 0 && (
                  <div class="contributor-topics">
                    {w.topics.map((t) => (
                      <span class="topic-tag">{t}</span>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </section>
      )
    }

    <!-- COMMUNITY VALUES -->
    <section class="values-section">
      <h2>Our Community Values</h2>
      <div class="values-grid">
        <div class="value-item">
          <span class="value-icon">🤝</span>
          <div>
            <h3>Be Respectful</h3>
            <p>
              Treat everyone with respect. Diverse perspectives make us
              stronger.
            </p>
          </div>
        </div>
        <div class="value-item">
          <span class="value-icon">🎯</span>
          <div>
            <h3>Stay On Topic</h3>
            <p>
              Keep discussions relevant and focused to help others find answers
              faster.
            </p>
          </div>
        </div>
        <div class="value-item">
          <span class="value-icon">💎</span>
          <div>
            <h3>Share Quality</h3>
            <p>Back your answers with experience, code, or reliable sources.</p>
          </div>
        </div>
        <div class="value-item">
          <span class="value-icon">🌱</span>
          <div>
            <h3>Help Others Grow</h3>
            <p>
              Upvote great answers, mentor newcomers, and celebrate wins
              together.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <h2>Ready to Join?</h2>
      <p>Start asking, answering, and connecting with engineers today.</p>
      <a href="/space" class="btn-primary btn-large">Get Started →</a>
    </section>
  </div>
</Layout>

<style>
  .about-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px 60px;
  }

  /* HERO */
  .hero {
    text-align: center;
    padding: 60px 0 50px;
  }
  .hero-badge {
    display: inline-block;
    background: #eef3ff;
    color: #2e69ff;
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 20px;
  }
  .hero h1 {
    font-size: 42px;
    font-weight: 800;
    color: #1a1a1a;
    margin: 0 0 18px;
    line-height: 1.15;
  }
  .highlight {
    background: linear-gradient(135deg, #b92b27, #2e69ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub {
    font-size: 18px;
    color: #636466;
    max-width: 560px;
    margin: 0 auto 30px;
    line-height: 1.5;
  }
  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: #2e69ff;
    color: white;
    padding: 12px 28px;
    border-radius: 24px;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .btn-primary:hover {
    opacity: 0.85;
  }
  .btn-ghost {
    background: white;
    color: #2e69ff;
    padding: 12px 28px;
    border-radius: 24px;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    border: 1px solid #dee0e1;
    transition: all 0.2s;
  }
  .btn-ghost:hover {
    border-color: #2e69ff;
    background: #f8faff;
  }
  .btn-large {
    padding: 14px 36px;
    font-size: 16px;
  }

  /* STATS */
  .stats-section {
    margin-bottom: 60px;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .stat-card {
    background: white;
    border: 1px solid #e3e6ea;
    border-radius: 12px;
    padding: 24px 16px;
    text-align: center;
  }
  .stat-number {
    display: block;
    font-size: 32px;
    font-weight: 800;
    color: #1a1a1a;
    margin-bottom: 4px;
  }
  .stat-label {
    font-size: 13px;
    color: #939598;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* HOW IT WORKS */
  .how-section {
    margin-bottom: 60px;
  }
  .how-section h2 {
    text-align: center;
    font-size: 28px;
    font-weight: 800;
    color: #1a1a1a;
    margin: 0 0 30px;
  }
  .how-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .how-card {
    background: white;
    border: 1px solid #e3e6ea;
    border-radius: 12px;
    padding: 28px 22px;
    text-align: center;
  }
  .how-icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    margin: 0 auto 16px;
  }
  .how-card h3 {
    font-size: 17px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 8px;
  }
  .how-card p {
    font-size: 14px;
    color: #636466;
    line-height: 1.5;
    margin: 0;
  }

  /* CONTRIBUTORS */
  .contributors-section {
    margin-bottom: 60px;
    text-align: center;
  }
  .contributors-section h2 {
    font-size: 28px;
    font-weight: 800;
    color: #1a1a1a;
    margin: 0 0 6px;
  }
  .section-sub {
    color: #939598;
    font-size: 15px;
    margin: 0 0 28px;
  }
  .contributors-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .contributor-card {
    background: white;
    border: 1px solid #e3e6ea;
    border-radius: 12px;
    padding: 24px 16px;
    text-align: center;
    transition: border-color 0.2s;
  }
  .contributor-card:hover {
    border-color: #c8cdd3;
  }
  .contributor-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 12px;
    color: white;
    font-weight: 700;
    font-size: 18px;
    overflow: hidden;
  }
  .contributor-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }
  .contributor-name {
    font-weight: 700;
    font-size: 15px;
    color: #1a1a1a;
    margin: 0 0 4px;
  }
  .contributor-expertise {
    font-size: 12px;
    color: #939598;
    margin: 0 0 10px;
  }
  .contributor-topics {
    display: flex;
    gap: 4px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .topic-tag {
    background: #f1f2f2;
    color: #636466;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
  }

  /* VALUES */
  .values-section {
    margin-bottom: 60px;
  }
  .values-section h2 {
    text-align: center;
    font-size: 28px;
    font-weight: 800;
    color: #1a1a1a;
    margin: 0 0 28px;
  }
  .values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .value-item {
    display: flex;
    gap: 16px;
    background: white;
    border: 1px solid #e3e6ea;
    border-radius: 12px;
    padding: 20px;
    align-items: flex-start;
  }
  .value-icon {
    font-size: 28px;
    flex-shrink: 0;
    width: 40px;
    text-align: center;
  }
  .value-item h3 {
    font-size: 15px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 4px;
  }
  .value-item p {
    font-size: 13px;
    color: #636466;
    line-height: 1.4;
    margin: 0;
  }

  /* CTA */
  .cta-section {
    text-align: center;
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    border-radius: 16px;
    padding: 50px 30px;
    color: white;
  }
  .cta-section h2 {
    font-size: 28px;
    font-weight: 800;
    margin: 0 0 10px;
  }
  .cta-section p {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.7);
    margin: 0 0 24px;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .hero h1 {
      font-size: 28px;
    }
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .how-grid {
      grid-template-columns: 1fr;
    }
    .contributors-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .values-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr 1fr;
    }
    .contributors-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const SHEET_URL =
    "https://script.google.com/macros/s/AKfycbwfpjk3Y2gzDt0T_JS7c2OhQajr_UildmeqEgQVPQxIFAjYnYG8alaQF0XmGjeI-_uzkQ/exec";

  // Animate counter
  function animateCounter(element: HTMLElement, target: number) {
    if (target === 0) {
      element.textContent = "0";
      return;
    }
    const duration = 1500;
    const start = performance.now();

    function update(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3); // ease out cubic
      const current = Math.floor(eased * target);
      element.textContent = current.toLocaleString();
      if (progress < 1) requestAnimationFrame(update);
    }

    requestAnimationFrame(update);
  }

  async function loadStats() {
    try {
      const res = await fetch(`${SHEET_URL}?action=getStats`);
      const stats = await res.json();

      const postsEl = document.getElementById("stat-posts");
      const usersEl = document.getElementById("stat-users");
      const spacesEl = document.getElementById("stat-spaces");
      const answersEl = document.getElementById("stat-answers");

      if (postsEl) animateCounter(postsEl, stats.posts || 0);
      if (usersEl) animateCounter(usersEl, stats.users || 0);
      if (spacesEl) animateCounter(spacesEl, stats.spaces || 0);
      if (answersEl)
        animateCounter(answersEl, Math.floor((stats.posts || 0) * 2.4)); // estimated answers
    } catch (err) {
      console.error("Failed to load stats:", err);
    }
  }

  loadStats();
</script>
