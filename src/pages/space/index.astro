---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Spaces - Tech Engineer">
  <div class="spaces-page">
    <div class="spaces-header">
      <h1>Spaces</h1>
      <p>Discover and join communities</p>
    </div>

    <div id="spacesLoader" class="spaces-loader">
      <div class="skel-card"></div>
      <div class="skel-card"></div>
      <div class="skel-card"></div>
      <div class="skel-card"></div>
    </div>

    <div id="spacesGrid" class="spaces-grid" style="display:none;"></div>

    <div id="spacesEmpty" class="spaces-empty" style="display:none;">
      <p>No spaces found</p>
    </div>
  </div>
</Layout>

<style>
  .spaces-page {
    max-width: 680px;
    margin: 0 auto;
    padding: 24px 16px;
  }
  .spaces-header {
    margin-bottom: 24px;
  }
  .spaces-header h1 {
    font-size: 28px;
    font-weight: 800;
    color: #111827;
    margin: 0 0 4px;
  }
  .spaces-header p {
    color: #6b7280;
    font-size: 15px;
    margin: 0;
  }

  .spaces-loader {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .skel-card {
    background: linear-gradient(90deg, #e5e7eb 25%, #f3f4f6 50%, #e5e7eb 75%);
    background-size: 200% 100%;
    animation: skelPulse 1.5s ease-in-out infinite;
    border-radius: 12px;
    height: 80px;
  }
  @keyframes skelPulse {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  .spaces-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .space-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 18px 20px;
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .space-card:hover {
    border-color: #2e69ff;
  }
  .space-card-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 800;
    color: white;
    flex-shrink: 0;
  }
  .space-card-info {
    flex: 1;
    min-width: 0;
  }
  .space-card-name {
    font-size: 16px;
    font-weight: 700;
    color: #111827;
    margin: 0 0 3px;
  }
  .space-card-desc {
    font-size: 13px;
    color: #6b7280;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .space-card-meta {
    font-size: 12px;
    color: #9ca3af;
    margin-top: 4px;
  }

  .spaces-empty {
    text-align: center;
    padding: 60px 20px;
    color: #9ca3af;
  }

  @media (max-width: 600px) {
    .spaces-page {
      padding: 12px;
    }
    .spaces-header h1 {
      font-size: 22px;
    }
  }
</style>

<script>
  const SCRIPT_URL =
    "https://script.google.com/macros/s/AKfycbwfpjk3Y2gzDt0T_JS7c2OhQajr_UildmeqEgQVPQxIFAjYnYG8alaQF0XmGjeI-_uzkQ/exec";

  const loaderEl = document.getElementById("spacesLoader");
  const gridEl = document.getElementById("spacesGrid");
  const emptyEl = document.getElementById("spacesEmpty");

  async function loadSpaces() {
    if (!loaderEl || !gridEl) return;

    try {
      const email = localStorage.getItem("userId") || "";
      const res = await fetch(
        `${SCRIPT_URL}?action=getSpaces&userEmail=${encodeURIComponent(email)}`,
      );
      const spaces = await res.json();

      loaderEl.style.display = "none";

      if (!spaces || spaces.length === 0) {
        emptyEl!.style.display = "block";
        return;
      }

      gridEl.style.display = "flex";
      gridEl.innerHTML = spaces
        .map((s: any) => {
          const slug =
            s.slug ||
            s.name
              .toLowerCase()
              .replace(/[^\w -]+/g, "")
              .replace(/ +/g, "-");
          const initial = s.icon || s.name.charAt(0).toUpperCase();
          return `
          <a href="/space/${slug}" class="space-card">
            <div class="space-card-icon" style="background:${s.color || "#2e69ff"}">${initial}</div>
            <div class="space-card-info">
              <div class="space-card-name">${s.name}</div>
              <div class="space-card-desc">${s.description || ""}</div>
              <div class="space-card-meta">${s.members || 0} members · ${s.posts || 0} posts${s.isMember ? " · ✓ Joined" : ""}</div>
            </div>
          </a>`;
        })
        .join("");
    } catch (err) {
      console.error("Error loading spaces:", err);
      loaderEl.style.display = "none";
    }
  }

  loadSpaces();
</script>
