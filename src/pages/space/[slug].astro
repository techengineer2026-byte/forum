    font-size: 14px;
    color: #2e69ff;
    text-decoration: none;
  }
  .owner-name:hover {
    text-decoration: underline;
  }

  </style>
  <style is:global>
  .section-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 12px;
  }
  .section-title {
    font-size: 16px;
    font-weight: 700;
    color: #111827;
    margin: 0 0 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .section-title svg {
    color: #6b7280;
  }

  .post-item {
    padding: 14px 0;
    border-bottom: 1px solid #f3f4f6;
  }
  .post-item:last-child {
    border-bottom: none;
  }
  .post-item-link {
    font-size: 15px;
    font-weight: 700;
    color: #111827;
    text-decoration: none;
    line-height: 1.4;
    display: block;
  }
  .post-item-link:hover {
    color: #2e69ff;
