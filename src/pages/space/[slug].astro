  }
  .stat-item span {
    font-weight: 800;
    color: #111827;
  }

  .owner-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 16px 20px;
    margin-bottom: 12px;
  }
  .owner-label {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 700;
    color: #6b7280;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 10px;
  }
  .owner-info {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .owner-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #b92b27;
