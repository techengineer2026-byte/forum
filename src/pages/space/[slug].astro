  }

  .space-toast {
    position: fixed;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    background: #111827;
    color: white;
    padding: 12px 24px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transition: all 0.3s ease;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
  }
  .space-toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 600px) {
    .space-page {
      padding: 12px;
    }
    .space-header {
      flex-direction: column;
      align-items: flex-start;
      padding: 16px;
    }
    .space-icon {
      width: 48px;
      height: 48px;
      font-size: 20px;
    }
    .space-name {
      font-size: 20px;
    }
    .join-btn {
      align-self: flex-start;
    }
    .stats-bar {
      gap: 16px;
      padding: 12px 16px;
    }
  }
</style>

<script>
  const SCRIPT_URL =
    "https://script.google.com/macros/s/AKfycbywCeoEu7CNLZtgRKyy4wsnvGw8B6wpNrP5ke0RoJ6XrVfwgsmBKAlIKvli79IVAWQJxQ/exec";

  // ✅ Extract SLUG from URL, not ID
  const pathParts = window.location.pathname.split("/").filter(Boolean);
  const spaceSlug = pathParts[pathParts.length - 1];

  const loaderEl = document.getElementById("spaceLoader");
  const notFoundEl = document.getElementById("spaceNotFound");
  const contentEl = document.getElementById("spaceContent");
  const joinBtn = document.getElementById("joinBtn");
  const toastEl = document.getElementById("spaceToast");

  let spaceData: any = null;

  function showToast(msg: string, duration = 2500) {
    if (!toastEl) return;
    toastEl.textContent = msg;
    toastEl.classList.add("show");
    setTimeout(() => toastEl.classList.remove("show"), duration);
  }

  function timeAgo(dateStr: string | null | undefined): string {
    if (!dateStr) return "";
    try {
      const date = new Date(dateStr);
      if (isNaN(date.getTime())) return dateStr;
      const seconds = Math.floor(
        (new Date().getTime() - date.getTime()) / 1000,
      );
      if (seconds < 60) return "Just now";
      if (seconds < 3600) return Math.floor(seconds / 60) + "m ago";
      if (seconds < 86400) return Math.floor(seconds / 3600) + "h ago";
      if (seconds < 604800) return Math.floor(seconds / 86400) + "d ago";
      return date.toLocaleDateString();
    } catch (e) {
      return dateStr || "";
    }
  }

  async function loadSpace() {
    if (!loaderEl || !notFoundEl || !contentEl) return;

    try {
      // ✅ Fetch by SLUG instead of ID
      const res = await fetch(
        `${SCRIPT_URL}?action=getSpaceDetailsBySlug&slug=${encodeURIComponent(spaceSlug)}`,
      );
      const space = await res.json();

      if (!space || space.error || space === null) {
        loaderEl.style.display = "none";
        notFoundEl.style.display = "block";
        return;
      }

      spaceData = space;
      loaderEl.style.display = "none";
      contentEl.style.display = "block";

      document.title = `${space.name} - Tech Engineer`;

      const iconEl = document.getElementById("spaceIcon") as HTMLDivElement;
      iconEl.style.backgroundColor = space.color || "#2e69ff";
      iconEl.textContent = space.icon || space.name.charAt(0).toUpperCase();

      (document.getElementById("spaceName") as HTMLElement).innerText =
        space.name;
      (document.getElementById("spaceDesc") as HTMLElement).innerText =
        space.description || "No description available.";

      const metaEl = document.getElementById("spaceMeta") as HTMLDivElement;
      let metaHtml = "";
      if (space.isPrivate)
        metaHtml += '<span class="meta-tag private">Private</span>';
      if (space.category && space.category !== "General")
        metaHtml += `<span class="meta-tag category">${space.category}</span>`;
      metaEl.innerHTML = metaHtml;

      (document.getElementById("statMembers") as HTMLElement).innerText =
        String(space.members || 0);
      (document.getElementById("statPosts") as HTMLElement).innerText = String(
        space.posts || 0,
      );

      if (space.category && space.category !== "General") {
        (document.getElementById("statCategory") as HTMLElement).style.display =
          "inline-flex";
        (document.getElementById("statCategoryText") as HTMLElement).innerText =
          space.category;
      }

      updateJoinButton(space);

      if (space.ownerName) {
        (document.getElementById("ownerCard") as HTMLDivElement).style.display =
          "block";
        (document.getElementById("ownerAvatar") as HTMLElement).innerText =
          space.ownerName.charAt(0).toUpperCase();
        const ownerLink = document.getElementById(
          "ownerName",
        ) as HTMLAnchorElement;
        ownerLink.innerText = space.ownerName;
        ownerLink.href = `/user?name=${encodeURIComponent(space.ownerName)}`;
      }

      loadSpacePosts();
    } catch (err) {
      console.error("Error loading space:", err);
      loaderEl.style.display = "none";
      notFoundEl.style.display = "block";
    }
  }

  async function updateJoinButton(space: any) {
    const email = localStorage.getItem("userId") || "";
    if (!email || !joinBtn) return;

    try {
      const res = await fetch(
        `${SCRIPT_URL}?action=getSpaces&userEmail=${encodeURIComponent(email)}`,
      );
      const spaces = await res.json();
      const thisSpace = spaces.find((s: any) => s.id === space.id);
      if (thisSpace && thisSpace.isMember) {
        space.isMember = true;
        joinBtn.className = "join-btn joined";
        joinBtn.textContent = "Joined";
      } else {
        space.isMember = false;
        joinBtn.className = "join-btn not-joined";
        joinBtn.textContent = "Join";
      }
    } catch (e) {
      space.isMember = false;
    }
  }

  joinBtn?.addEventListener("click", async () => {
    if (!localStorage.getItem("userId")) {
      const loginModal = document.getElementById(
        "loginModal",
      ) as HTMLDivElement;
      if (loginModal) loginModal.classList.add("active");
      else window.dispatchEvent(new CustomEvent("show-login-modal"));
      return;
    }

    if (!spaceData) return;

    joinBtn.classList.add("loading");
    const isJoining = !spaceData.isMember;
    const action = isJoining ? "joinSpace" : "leaveSpace";

    try {
      const res = await fetch(SCRIPT_URL, {
        method: "POST",
        body: JSON.stringify({
          action: action,
          spaceId: spaceData.id, // ← still UUID internally
          userEmail: localStorage.getItem("userId"),
          userName: localStorage.getItem("currentUser") || "Anonymous",
        }),
      });
      const result = await res.json();

      if (result.status === "success") {
        spaceData.isMember = !spaceData.isMember;
        joinBtn.className = `join-btn ${spaceData.isMember ? "joined" : "not-joined"}`;
        joinBtn.textContent = spaceData.isMember ? "Joined" : "Join";

        const membersEl = document.getElementById("statMembers") as HTMLElement;
        const current = parseInt(membersEl.innerText) || 0;
        membersEl.innerText = String(
          spaceData.isMember ? current + 1 : Math.max(0, current - 1),
        );

        showToast(
          spaceData.isMember
            ? `Joined ${spaceData.name}`
            : `Left ${spaceData.name}`,
        );
      } else {
        joinBtn.textContent = spaceData.isMember ? "Joined" : "Join";
        showToast(result.message || "Action failed");
      }
    } catch (err) {
      joinBtn.textContent = spaceData.isMember ? "Joined" : "Join";
      showToast("Something went wrong. Try again.");
    } finally {
      joinBtn.classList.remove("loading");
    }
  });

  async function loadSpacePosts() {
    const container = document.getElementById("spacePosts") as HTMLDivElement;
    if (!container || !spaceData) return;

    try {
      const res = await fetch(`${SCRIPT_URL}?action=getPosts`);
      const allPosts = await res.json();
      const recentPosts = Array.isArray(allPosts) ? allPosts.slice(0, 5) : [];

      if (recentPosts.length === 0) {
        container.innerHTML = `
          <div class="empty-posts">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            <p>No posts yet. Be the first to share!</p>
          </div>`;
        return;
      }

      container.innerHTML = recentPosts
        .map((post: any) => {
          const slug =
            post.slug ||
            post.heading
              ?.toLowerCase()
              .replace(/[^\w ]+/g, "")
              .replace(/ +/g, "-") ||
            "";
          const time = timeAgo(post.updated_time || post.created_at);
          return `
          <div class="post-item">
            <a href="/question/${slug}" class="post-item-link">${post.heading}</a>
            <div class="post-item-meta">
              ${post.name || "Anonymous"} · ${time} · ${post.upvotes || 0} upvotes
            </div>
          </div>`;
        })
        .join("");
    } catch (err) {
      console.error("Error loading space posts:", err);
    }
  }

  window.addEventListener("user-logged-in", () => {
    if (spaceData) updateJoinButton(spaceData);
  });

  loadSpace();
</script>
