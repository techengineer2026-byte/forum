---
export async function getStaticPaths() {
  const SCRIPT_URL =
    "https://script.google.com/macros/s/AKfycbywCeoEu7CNLZtgRKyy4wsnvGw8B6wpNrP5ke0RoJ6XrVfwgsmBKAlIKvli79IVAWQJxQ/exec";

  try {
    const res = await fetch(`${SCRIPT_URL}?action=getSpaces`);
    const spaces = await res.json();
    return spaces.map((s: any) => ({
      params: {
        slug:
          s.slug ||
          s.name
            .toLowerCase()
            .replace(/[^\w ]+/g, "")
            .replace(/ +/g, "-"),
      },
    }));
  } catch (e) {
    return []; // Fallback if API fails during build
  }
}

import Layout from "../../layouts/Layout.astro";
---

<Layout title="Space - Tech Engineer">
  <div class="space-page">
    <!-- SKELETON LOADING -->
    <div id="spaceLoader" class="space-loader">
      <div class="skel-header">
        <div class="skel skel-icon"></div>
        <div class="skel skel-head-info">
          <div
            class="skel skel-bar"
            style="width:50%;height:24px;margin-bottom:8px"
          >
          </div>
          <div class="skel skel-bar" style="width:80%;height:12px"></div>
        </div>
      </div>
      <div class="skel-card">
        <div
          class="skel skel-bar"
          style="width:40%;height:14px;margin-bottom:10px"
        >
        </div>
        <div
          class="skel skel-bar"
          style="width:100%;height:12px;margin-bottom:6px"
        >
        </div>
        <div class="skel skel-bar" style="width:70%;height:12px"></div>
      </div>
      <div class="skel-card">
        <div
          class="skel skel-bar"
          style="width:35%;height:14px;margin-bottom:10px"
        >
        </div>
        <div
          class="skel skel-bar"
          style="width:100%;height:12px;margin-bottom:6px"
        >
        </div>
        <div class="skel skel-bar" style="width:60%;height:12px"></div>
      </div>
    </div>

    <!-- NOT FOUND -->
    <div id="spaceNotFound" class="not-found" style="display:none;">
      <svg
        width="56"
        height="56"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#d1d5db"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="2" y1="12" x2="22" y2="12"></line>
        <path
          d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
        ></path>
      </svg>
      <h2>Space not found</h2>
      <p>This space may have been removed or doesn't exist.</p>
      <a href="/following" class="back-link">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to Spaces
      </a>
    </div>

    <!-- ACTUAL CONTENT -->
    <div id="spaceContent" style="display:none;">
      <!-- HEADER -->
      <div class="space-header">
        <div class="space-icon" id="spaceIcon"></div>
        <div class="space-head-info">
          <h1 class="space-name" id="spaceName"></h1>
          <p class="space-desc" id="spaceDesc"></p>
          <div class="space-meta" id="spaceMeta"></div>
        </div>
        <button class="join-btn not-joined" id="joinBtn" type="button"
          >Join</button
        >
      </div>

      <!-- STATS BAR -->
      <div class="stats-bar" id="statsBar">
        <div class="stat-item">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
          <span id="statMembers">0</span> Members
        </div>
        <div class="stat-item">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
            ></path>
            <polyline points="14 2 14 8 20 8"></polyline>
          </svg>
          <span id="statPosts">0</span> Posts
        </div>
        <div class="stat-item" id="statCategory" style="display:none;">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <polygon
              points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
            ></polygon>
          </svg>
          <span id="statCategoryText"></span>
        </div>
      </div>

      <!-- OWNER INFO -->
      <div class="owner-card" id="ownerCard" style="display:none;">
        <div class="owner-label">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
          Owner
        </div>
        <div class="owner-info">
          <div class="owner-avatar" id="ownerAvatar"></div>
          <a class="owner-name" id="ownerName" href="#"></a>
        </div>
      </div>

      <!-- POSTS IN THIS SPACE -->
      <div class="section-card">
        <h2 class="section-title">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
            ></path>
            <polyline points="14 2 14 8 20 8"></polyline>
          </svg>
          Posts in this Space
        </h2>
        <div id="spacePosts">
          <div class="empty-posts">
            <svg
              width="36"
              height="36"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#d1d5db"
              stroke-width="1.5"
            >
              <path
                d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
              ></path>
              <polyline points="14 2 14 8 20 8"></polyline>
            </svg>
            <p>No posts yet. Be the first to share!</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- TOAST -->
  <div id="spaceToast" class="space-toast"></div>
</Layout>

<style >
  .skel {
    background: linear-gradient(90deg, #e5e7eb 25%, #f3f4f6 50%, #e5e7eb 75%);
    background-size: 200% 100%;
    animation: skelPulse 1.5s ease-in-out infinite;
    border-radius: 4px;
  }
  @keyframes skelPulse {
    0% {
      background-position: 200% 0;
