---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Question">
    <div class="question-container">
        <!-- Main Content -->
        <main class="question-main">
            <article class="question-card">
                <!-- The Engine will fill this H1 with the "Unslugified" text from the URL -->
                <h1 id="question-title">Loading...</h1>

                <div class="question-actions">
                    <button class="answer-btn">
                        <span class="icon">✍️</span> Answer
                    </button>
                    <button class="secondary-btn">Follow</button>
                    <button class="secondary-btn">Request</button>
                </div>

                <div class="answers-section">
                    <div class="answers-header">
                        <h3 id="answer-count">0 Answers</h3>
                    </div>
                    <div id="answers-container">
                        <!-- Answers will be injected here -->
                    </div>
                </div>
            </article>
        </main>

        <!-- Sidebar -->
        <aside class="related-sidebar">
            <div class="related-card">
                <h3>Related questions</h3>
                <nav id="related-questions">
                    <!-- Related links will be injected here -->
                </nav>
            </div>
        </aside>
    </div>
</Layout>

<style>
    :root {
        --q-blue: #2e69ff;
        --border-gray: #dee0e1;
        --text-dark: #282829;
        --text-light: #636466;
    }

    .question-container {
        display: flex;
        justify-content: center;
        max-width: 1000px;
        margin: 30px auto;
        gap: 24px;
        padding: 0 16px;
        font-family:
            -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica,
            Arial, sans-serif;
    }

    .question-main {
        flex: 1;
        max-width: 650px;
        min-width: 0;
    }

    .question-card {
        background: white;
        border: 1px solid var(--border-gray);
        border-radius: 8px;
        padding: 20px;
    }

    .question-card h1 {
        font-size: 22px;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 12px;
        line-height: 1.3;
    }

    .question-actions {
        display: flex;
        gap: 8px;
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 1px solid #f0f0f0;
    }

    .answer-btn {
        background: var(--q-blue);
        color: white;
        border: 1px solid var(--q-blue);
        padding: 8px 16px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .secondary-btn {
        background: transparent;
        color: var(--text-light);
        border: 1px solid var(--border-gray);
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 14px;
        cursor: pointer;
    }

    .related-sidebar {
        width: 300px;
        flex-shrink: 0;
    }

    .related-card {
        background: white;
        border: 1px solid var(--border-gray);
        border-radius: 8px;
        padding: 15px;
    }

    .related-card h3 {
        font-size: 15px;
        font-weight: 600;
        color: var(--text-light);
        margin-bottom: 12px;
        padding-bottom: 8px;
        border-bottom: 1px solid #eee;
    }

    /* MOBILE RESPONSIVE */
    @media (max-width: 850px) {
        .question-container {
            flex-direction: column;
            margin-top: 10px;
        }
        .question-main,
        .related-sidebar {
            width: 100%;
            max-width: 100%;
        }
    }
</style>

<script>
    import { renderQuestionPage } from "../scripts/questionEngine";
    // Run the engine when the page loads
    renderQuestionPage();
</script>
