---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="(Mentions) Notifications - Tech Engineer" showFooter={false}>
    <div class="notifications-layout">
        <!-- LEFT SIDEBAR: FILTERS -->
        <aside class="filters-sidebar">
            <div class="sticky-wrapper">
                <p class="filters-title">Filters</p>
                <ul class="filters-list">
                    <li><a href="/notifications">All</a></li>
                    <li><a href="/notifications/questions">Questions</a></li>
                    
                    <li><a href="/notifications/comments">Comments</a></li>
                    <li class="active"><a href="/notifications/mentions">Mentions</a></li>
                    <li><a href="/notifications/upvotes">Upvotes</a></li>
                    <li><a href="/notifications/following">Following</a></li>
                    <li><a href="/notifications/bookmarks">Bookmarks</a></li>
                    <li>
                        <a href="/notifications/announcements">Announcements</a>
                    </li>
                </ul>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="notifications-main">
            <div class="notif-header">
                <h2 class="category-name">Mentions</h2>
                <button class="settings-link">Settings</button>
            </div>

            <!-- List of Demo Notifications -->
            <div class="notif-list">
                <div class="notif-item unread">
                    <div class="notif-icon-blue">▲</div>
                    <div class="notif-text">
                        <p>
                            <b>Anurag Kohli</b> upvoted your answer in <b
                                >Computer Technology</b
                            >. <span>· 2h</span>
                        </p>
                    </div>
                    <div class="unread-dot"></div>
                </div>

                <div class="notif-item">
                    <div class="notif-icon-red">⭐</div>
                    <div class="notif-text">
                        <p>
                            New questions for you: <b
                                >"How do I learn CSS fast?"</b
                            > and 3 more. <span>· 5h</span>
                        </p>
                    </div>
                </div>

                <div class="notif-item">
                    <div class="notif-icon-gray">👥</div>
                    <div class="notif-text">
                        <p>
                            <b>Seck Zhao</b> started following you. <span
                                >· 1d</span
                            >
                        </p>
                    </div>
                </div>
            </div>
        </main>
    </div>
</Layout>

<style>
    /* Use the SAME CSS from your your-profile.astro page to keep them equal */
    .notifications-layout {
        display: flex;
        justify-content: center;
        gap: 40px;
        max-width: 1000px;
        margin: 0 auto;
        padding: 30px 15px;
        align-items: flex-start;
    }

    .filters-sidebar {
        width: 200px;
    }
    .sticky-wrapper {
        position: sticky;
        top: 70px;
    }
    .filters-title {
        font-weight: bold;
        font-size: 15px;
        border-bottom: 1px solid #ddd;
        padding-bottom: 8px;
        margin-bottom: 10px;
    }
    .filters-list {
        list-style: none;
        padding: 0;
    }
    .filters-list li {
        padding: 8px 12px;
        border-radius: 4px;
        font-size: 14px;
        color: #636466;
        cursor: pointer;
    }
    .filters-list li a {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .filters-list li.active {
        background-color: #f7e8e8;
        color: #b92b27;
        font-weight: bold;
    }
    .filters-list li:hover:not(.active) {
        background-color: #e6e6e6;
    }

    .notifications-main {
        flex: 1;
        max-width: 650px;
    }

    .notif-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #eee;
        padding-bottom: 10px;
        margin-bottom: 10px;
    }
    .category-name {
        font-size: 15px;
        font-weight: bold;
        color: #333;
    }
    .settings-link {
        background: none;
        border: none;
        color: #939598;
        font-size: 14px;
        cursor: pointer;
    }

    /* Notification Items Styling */
    .notif-item {
        display: flex;
        align-items: center;
        padding: 15px;
        border-bottom: 1px solid #f0f0f0;
        position: relative;
        cursor: pointer;
    }
    .notif-item:hover {
        background-color: #f9f9f9;
    }
    .notif-item.unread {
        background-color: #f0f7ff;
    }

    .notif-icon-blue {
        color: #2e69ff;
        margin-right: 15px;
        font-size: 18px;
    }
    .notif-icon-red {
        color: #b92b27;
        margin-right: 15px;
        font-size: 18px;
    }
    .notif-icon-gray {
        color: #939598;
        margin-right: 15px;
        font-size: 18px;
    }

    .notif-text p {
        margin: 0;
        font-size: 14px;
        color: #333;
        line-height: 1.4;
    }
    .notif-text span {
        color: #939598;
    }

    .unread-dot {
        width: 8px;
        height: 8px;
        background-color: #2e69ff;
        border-radius: 50%;
        position: absolute;
        right: 15px;
    }
</style>
