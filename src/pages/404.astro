---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 - Page Not Found" showFooter={false}>
  <div class="not-found-page">
    <div class="not-found-content">
      <div class="error-code">404</div>
      <h1>Page Not Found</h1>
      <p>Sorry, the page you're looking for doesn't exist or has been moved.</p>
      <div class="not-found-actions">
        <a href="/" class="btn-primary">Go Home</a>
        <a href="/answer" class="btn-ghost">Browse Questions</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .not-found-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    padding: 40px 20px;
  }
  .not-found-content {
    text-align: center;
    max-width: 460px;
  }
  .error-code {
    font-size: 120px;
    font-weight: 800;
    color: #e3e6ea;
    line-height: 1;
    margin-bottom: 8px;
    background: linear-gradient(135deg, #b92b27, #2e69ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .not-found-content h1 {
    font-size: 28px;
    font-weight: 800;
    color: #1a1a1a;
    margin: 0 0 12px;
  }
  .not-found-content p {
    font-size: 16px;
    color: #939598;
    margin: 0 0 28px;
    line-height: 1.5;
  }
  .not-found-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: #2e69ff;
    color: white;
    padding: 12px 28px;
    border-radius: 24px;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .btn-primary:hover {
    opacity: 0.85;
  }
  .btn-ghost {
    background: white;
    color: #2e69ff;
    padding: 12px 28px;
    border-radius: 24px;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    border: 1px solid #dee0e1;
    transition: all 0.2s;
  }
  .btn-ghost:hover {
    border-color: #2e69ff;
    background: #f8faff;
  }
</style>
