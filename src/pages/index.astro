---
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/Sidebar.astro";
import PostCard from "../components/PostCard.astro";
import AdCard from "../components/AdCard.astro";
import CreatePost from "../components/CreatePost.astro";
import ModalManager from "../components/ModalManager.astro";

// 1. IMPORT LOCAL JSON DATA
import postData from "../data/post_demo.json";
---

<Layout title="Forum - Tech engineer">
	<div class="page-layout">
		<aside class="sidebar-area">
			<Sidebar />
		</aside>

		<main class="feed-area">
			<CreatePost />

			<!-- 2. DYNAMIC USER QUESTIONS WILL INJECT HERE -->
			<div id="user-questions-feed"></div>

			<!-- 3. STATIC JSON DATA -->
			{
				postData.map((post, index) => (
					<PostCard
						id={`post-${index}`}
						avatar={post.avatar || "icon.png"}
						name={post.name || "Guest Engineer"}
						follow_enabled={post.follow_enabled}
						role_name={post.role_name || "Tech Specialist"}
						updated_time={post.updated_time || "Just now"}
						heading={post.heading}
						description={post.description}
						images={post.images || []}
						upvotes={post.upvotes || 0}
						comments={post.comments || 0}
						shares={post.shares || 0}
					/>
				))
			}

			{
				postData.length === 0 && (
					<p class="empty-state">
						No questions found. Be the first to post!
					</p>
				)
			}
		</main>

		<aside class="right-column">
			<AdCard
				url="https://techengineer.co/video-editing"
				title="Video Editing Course"
				description="Master Premiere Pro."
				image="/assets/videoeditor.gif"
			/>
			<AdCard
				url="https://techengineer.co/ai-machine-learning-course-mohali"
				title="AI Course Course"
				description="AI and Machine Learning in Mohali"
				image="/assets/ALandMLads.gif"
			/>
		</aside>
	</div>
	<ModalManager />
</Layout>

<style>
	.page-layout {
		display: flex;
		justify-content: center;
		gap: 24px;
		padding: 20px;
		background-color: #f1f2f2;
		min-height: 100vh;
		align-items: flex-start;
	}

	.sidebar-area {
		width: 160px;
		position: sticky;
		top: 80px;
		height: fit-content;
	}

	.feed-area {
		width: 580px;
	}

	.right-column {
		width: 300px;
		position: sticky;
		top: 80px;
		height: fit-content;
	}

	.empty-state {
		text-align: center;
		color: #939598;
		margin-top: 40px;
	}

	@keyframes slideDown {
		from {
			opacity: 0;
			transform: translateY(-10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 1000px) {
		.right-column {
			display: none;
		}
	}
	@media (max-width: 750px) {
		.sidebar-area {
			display: none;
		}
		.feed-area {
			width: 100%;
		}
	}
</style>
<style is:global>
	/* Styles for the dynamically injected questions */
	.dynamic-question-card {
		background: white;
		border: 1px solid #e3e6ea;
		border-radius: 8px;
		padding: 16px;
		margin-bottom: 10px;
		animation: slideDown 0.3s ease-out;
	}
	.dynamic-question-card .dq-header {
		display: flex;
		align-items: center;
		gap: 10px;
		margin-bottom: 10px;
	}
	.dynamic-question-card .dq-avatar {
		width: 32px;
		height: 32px;
		border-radius: 50%;
		object-fit: cover;
		background: #e3e6ea;
	}
	.dynamic-question-card .dq-name {
		font-weight: 700;
		font-size: 14px;
		color: #282829;
	}
	.dynamic-question-card .dq-role {
		font-size: 12px;
		color: #939598;
	}
	.dynamic-question-card .dq-heading {
		font-size: 16px;
		font-weight: 700;
		color: #282829;
		margin: 0 0 8px 0;
		line-height: 1.3;
	}
	.dynamic-question-card .dq-badge {
		display: inline-block;
		background: #eef3ff;
		color: #2e69ff;
		font-size: 11px;
		font-weight: 700;
		padding: 3px 8px;
		border-radius: 4px;
		margin-bottom: 8px;
	}
	.dynamic-question-card .dq-image {
		width: 100%;
		max-height: 300px;
		object-fit: cover;
		border-radius: 8px;
		margin-top: 8px;
		border: 1px solid #e3e6ea;
	}
</style>

<script>
	function formatContent(text: string): string {
		if (!text) return "";
		text = text.replace(
			/```([a-z]*)\s*([\s\S]*?)\s*```/g,
			(_, lang: string, code: string) => {
				const escapedCode = code
					.replace(/</g, "&lt;")
					.replace(/>/g, "&gt;")
					.trim();
				return `<pre class="code-block"><code class="language-${lang || "text"}">${escapedCode}</code></pre>`;
			},
		);
		text = text.replace(/`([^`]+)`/g, (_, code: string) => {
			const escapedCode = code
				.replace(/</g, "&lt;")
				.replace(/>/g, "&gt;");
			return `<code class="inline-code">${escapedCode}</code>`;
		});
		text = text.replace(/\n/g, "<br />");
		return text;
	}
	// ====== 1. OPEN MODAL FUNCTION ======
	window.openModal = function (tab: string) {
		const modal = document.getElementById("question-modal");
		if (modal && modal instanceof HTMLDialogElement) modal.showModal();
		if (tab) {
			const tabElement = document.getElementById(tab);
			if (tabElement) tabElement.click();
		}
	};

	const GOOGLE_SHEET_URL =
		"https://script.google.com/macros/s/AKfycbxlZOW0AuGlzMPuNZ5bGKYiK_DNZp8geGUwrYopvp-lezOxlIjb761sS7aDLPJlRrqDHg/exec?action=getPosts";
	const publicFeed = document.getElementById("user-questions-feed");

	// ====== 2. HELPER: Format Date ======
	function timeSince(date: Date) {
		const seconds = Math.floor(
			(new Date().getTime() - date.getTime()) / 1000,
		);
		let interval = seconds / 31536000;
		if (interval > 1) return Math.floor(interval) + "y";
		interval = seconds / 2592000;
		if (interval > 1) return Math.floor(interval) + "mo";
		interval = seconds / 86400;
		if (interval > 1) return Math.floor(interval) + "d";
		interval = seconds / 3600;
		if (interval > 1) return Math.floor(interval) + "h";
		interval = seconds / 60;
		if (interval > 1) return Math.floor(interval) + "m";
		return "Just now";
	}

	// ====== 3. HELPER: Generate EXACT PostCard HTML ======
	// ====== HELPER: Generate EXACT PostCard HTML ======
	function createPostCardHTML(post: any) {
		const slug =
			post.slug ||
			post.heading
				.toLowerCase()
				.replace(/[^\w ]+/g, "")
				.replace(/ +/g, "-");

		// Avatar fallback
		let avatarHtml = "";
		const av = post.avatar;
		if (av && (av.startsWith("data:image") || av.startsWith("http"))) {
			avatarHtml = `<img src="${av}" alt="${post.name}" class="avatar" />`;
		} else if (av && av !== "icon.png") {
			avatarHtml = `<img src="/assets/${av}" alt="${post.name}" class="avatar" />`;
		} else {
			avatarHtml = `<div class="avatar" style="background:#b92b27;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:bold;font-size:14px;">${post.name?.charAt(0).toUpperCase() || "U"}</div>`;
		}

		// Format Upvotes
		const displayUpvotes = post.upvotes || 0;
		const upvoteText =
			displayUpvotes >= 1000
				? (displayUpvotes / 1000).toFixed(1) + "K"
				: displayUpvotes;

		// Format Images (Matches PostCard.astro grid)
		let imagesHtml = "";
		const images = post.images || [];
		if (images.length > 0) {
			const gridClass = `grid-${Math.min(images.length, 4)}`;
			imagesHtml += `<div class="post-images-grid ${gridClass}">`;
			images.slice(0, 4).forEach((img: string, index: number) => {
				if (index === 3 && images.length > 4) {
					imagesHtml += `<div class="grid-item with-overlay"><img src="/assets/${img}" alt="" /><div class="more-count">+${images.length - 3}</div></div>`;
				} else {
					imagesHtml += `<div class="grid-item"><img src="/assets/${img}" alt="" /></div>`;
				}
			});
			imagesHtml += `</div>`;
		}

		// Follow button
		const followHtml = post.follow_enabled
			? `<button class="follow-btn" data-author="${post.name}" onclick="window.toggleFollow(this)" type="button">Follow</button>`
			: "";

		return `
		<div class="post-card" data-id="${post.id}" data-slug="${slug}" data-heading="${post.heading}">
			<div class="post-header">
				${avatarHtml}
				<div class="header-main">
					<div class="header-top">
						<a href="/user?name=${encodeURIComponent(post.name)}" class="name">${post.name}</a>
						${followHtml}
					</div>
					<div class="header-sub">
						<span class="role">${post.role_name || "Tech Engineer"}</span>
						<span class="dot">•</span>
						<span class="time">${post.updated_time || "Just now"}</span>
					</div>
				</div>
			</div>

			<div class="post-body">
				<a href="/question/${slug}" class="heading-link">
					<h2 class="heading">${formatContent(post.heading)}</h2>
				</a>
				<div class="description collapsed">
					<p class="description-text">${formatContent(post.description || "")}</p>
					<button class="read-more" type="button" data-action="expand">Read more</button>
					<button class="read-less hidden" type="button" data-action="collapse">Show less</button>
				</div>
			</div>

			${imagesHtml}

			<div class="post-footer">
				<div class="vote-group">
					<button class="upvote-btn" data-count="${displayUpvotes}" aria-label="Upvote">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"></path></svg>
						<span class="btn-text">Upvote · <span class="upvote-count">${upvoteText}</span></span>
					</button>
					<button class="downvote-btn" aria-label="Downvote">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7"></path></svg>
					</button>
				</div>
				<button class="action-btn comment-toggle" aria-label="Comment">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
					<span class="action-count">${post.comments || 0}</span>
				</button>
				<button class="action-btn share-toggle" aria-label="Share">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg>
					<span class="action-count">${post.shares || 0}</span>
				</button>
				<button class="action-btn more-btn" aria-label="More options">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"></circle><circle cx="19" cy="12" r="1"></circle><circle cx="5" cy="12" r="1"></circle></svg>
				</button>
			</div>

			<div class="comments-section hidden">
				<div class="comments-list"></div>
				<div class="add-comment">
					<img src="/assets/icon.png" class="comment-avatar" alt="You" />
					<input type="text" class="comment-input" placeholder="Add a comment..." />
					<button class="comment-submit" type="button">Post</button>
				</div>
			</div>

			<div class="share-section hidden">
				<div class="share-row">
					<button class="share-option" data-share="copy"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg><span>Copy link</span></button>
					<button class="share-option" data-share="twitter"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg><span>Twitter</span></button>
					<button class="share-option" data-share="facebook"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg><span>Facebook</span></button>
					<button class="share-option" data-share="whatsapp"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg><span>WhatsApp</span></button>
				</div>
				<div class="share-toast hidden">Link copied to clipboard!</div>
			</div>

			<div class="more-section hidden">
				<button class="more-option" data-action="save"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg><span>Save</span></button>
				<button class="more-option" data-action="copy-link"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg><span>Copy link</span></button>
				<div class="more-divider"></div>
				<button class="more-option" data-action="hide"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"></path><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg><span>Hide</span></button>
				<button class="more-option danger" data-action="report"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path><line x1="4" y1="22" x2="4" y2="15"></line></svg><span>Report</span></button>
			</div>
		</div>`;
	}

	// ====== 4. FETCH & RENDER PUBLIC POSTS ======
	async function loadPublicPosts() {
		if (!publicFeed) return;

		try {
			const response = await fetch(GOOGLE_SHEET_URL);
			const posts = await response.json();

			if (!posts || posts.length === 0) {
				publicFeed.innerHTML = "";
				return;
			}

			// Generate exact PostCard HTML for each post
			publicFeed.innerHTML = posts.map(createPostCardHTML).join("");

			// ✅ Attach all upvote/comment/share logic to the new cards
			if (typeof (window as any).initPostLogic === "function") {
				(window as any).initPostLogic();
			}
		} catch (error) {
			console.error("Failed to load public posts:", error);
		} finally {
			// Hide loader if it exists
			const loader = document.getElementById("app-loader");
			if (loader) {
				loader.classList.add("fade-out");
				setTimeout(() => loader.remove(), 500);
			}
		}
	}

	// Load on page start
	loadPublicPosts();

	// Instant UI update when author posts
	window.addEventListener("post-added", () => loadPublicPosts());
</script>
