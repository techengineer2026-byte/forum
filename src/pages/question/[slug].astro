</style>

<script>
  const SCRIPT_URL =
    "https://script.google.com/macros/s/AKfycbxlZOW0AuGlzMPuNZ5bGKYiK_DNZp8geGUwrYopvp-lezOxlIjb761sS7aDLPJlRrqDHg/exec";

  function isUserLoggedIn(): boolean {
    return localStorage.getItem("userId") !== null;
  }
  function showLoginModal() {
    const loginModal = document.getElementById("loginModal");
    if (loginModal) loginModal.classList.add("active");
    else window.dispatchEvent(new CustomEvent("show-login-modal"));
  }
  function getCurrentUser() {
    return {
      email: localStorage.getItem("userId") || "",
      name: localStorage.getItem("currentUser") || "Anonymous",
      avatar: localStorage.getItem("userAvatar") || "/assets/icon.png",
    };
  }
  function getTimeAgo(date: Date): string {
    const seconds = Math.floor((new Date().getTime() - date.getTime()) / 1000);
    if (seconds < 60) return "Just now";
    if (seconds < 3600) return Math.floor(seconds / 60) + "m ago";
    if (seconds < 86400) return Math.floor(seconds / 3600) + "h ago";
    if (seconds < 604800) return Math.floor(seconds / 86400) + "d ago";
    return Math.floor(seconds / 604800) + "w ago";
  }

  const card = document.querySelector(".qcard") as HTMLElement;
  if (card) {
    const postId = card.getAttribute("data-id");
    const slug = card.getAttribute("data-slug");
    const heading = card.getAttribute("data-heading") || "";

    const upBtn = card.querySelector(".upvote-btn") as HTMLButtonElement;
    const downBtn = card.querySelector(".downvote-btn") as HTMLButtonElement;
    const voteCount = card.querySelector(".qvote-count") as HTMLElement;
    const answerModal = document.getElementById("answerModal") as HTMLElement;
    const answerTextarea = document.getElementById(
      "answerTextarea",
    ) as HTMLTextAreaElement;
    const submitAnswerBtn = document.querySelector(
      ".submit-answer",
    ) as HTMLButtonElement;
    const closeModalBtn = document.querySelector(
      ".qclose-modal",
    ) as HTMLButtonElement;
    const cancelAnswerBtn = document.querySelector(
      ".cancel-answer",
    ) as HTMLButtonElement;
    const commentsContainer = document.getElementById(
      "commentsContainer",
    ) as HTMLElement;

    let upvotes = parseInt(voteCount?.getAttribute("data-count") || "0");
    let isUpvoted = false,
      isDownvoted = false,
      isProcessing = false;

    const updateScore = () => {
      if (voteCount)
        voteCount.textContent =
          upvotes >= 1000
            ? (upvotes / 1000).toFixed(1) + "K"
            : upvotes.toString();
    };

    // UPVOTE
    const syncUpvote = async (increment: boolean) => {
      if (isProcessing) return;
      isProcessing = true;
      const user = getCurrentUser();
      try {
        const res = await fetch(SCRIPT_URL, {
          method: "POST",
          body: JSON.stringify({
            action: "updateUpvote",
            postId,
            increment,
            actorEmail: user.email,
            actorName: user.name,
          }),
        });
        const data = await res.json();
        if (data.status === "success") {
          upvotes = data.newCount;
          updateScore();
        }
      } catch (err) {
        isUpvoted = !isUpvoted;
        upvotes = isUpvoted ? upvotes + 1 : upvotes - 1;
        upBtn?.classList.toggle("active", isUpvoted);
        updateScore();
      } finally {
        isProcessing = false;
      }
    };

    upBtn?.addEventListener("click", () => {
      if (!isUserLoggedIn()) {
        showLoginModal();
        return;
      }
      if (isProcessing) return;
      if (isUpvoted) {
        isUpvoted = false;
        upBtn.classList.remove("active");
        syncUpvote(false);
      } else {
        isUpvoted = true;
        upBtn.classList.add("active");
        if (isDownvoted) {
          isDownvoted = false;
          downBtn.classList.remove("active");
        }
        syncUpvote(true);
      }
    });

    downBtn?.addEventListener("click", () => {
      if (!isUserLoggedIn()) {
        showLoginModal();
        return;
      }
      if (isDownvoted) {
        isDownvoted = false;
        downBtn.classList.remove("active");
      } else {
        isDownvoted = true;
        downBtn.classList.add("active");
        if (isUpvoted) {
          isUpvoted = false;
          upBtn.classList.remove("active");
          syncUpvote(false);
        }
      }
    });

    // ANSWER MODAL
    const openAnswerModal = () => {
      if (!isUserLoggedIn()) {
        showLoginModal();
        return;
      }
      answerModal?.classList.remove("hidden");
      setTimeout(() => answerTextarea?.focus(), 100);
    };
    document
      .querySelectorAll(".write-answer-main, .write-answer-empty")
      .forEach((btn) => {
        btn.addEventListener("click", openAnswerModal);
      });
    closeModalBtn?.addEventListener("click", () =>
      answerModal?.classList.add("hidden"),
    );
    cancelAnswerBtn?.addEventListener("click", () =>
      answerModal?.classList.add("hidden"),
    );

    answerTextarea?.addEventListener("input", () => {
      if (submitAnswerBtn)
        submitAnswerBtn.disabled = answerTextarea.value.trim().length === 0;
    });

    submitAnswerBtn?.addEventListener("click", async () => {
      const text = answerTextarea.value.trim();
      if (!text) return;
      submitAnswerBtn.disabled = true;
      submitAnswerBtn.textContent = "Posting...";
      const user = getCurrentUser();
      try {
        const res = await fetch(SCRIPT_URL, {
          method: "POST",
          body: JSON.stringify({
            action: "addComment",
            postId,
            parentID: "",
            userEmail: user.email,
            userName: user.name,
            userAvatar: user.avatar,
            commentText: text,
          }),
        });
        const result = await res.json();
        if (result.status === "success") {
          answerTextarea.value = "";
          answerModal?.classList.add("hidden");
          await loadComments();
        }
      } catch (err) {
        alert("Could not post answer.");
      } finally {
        submitAnswerBtn.disabled = false;
        submitAnswerBtn.textContent = "Post Answer";
      }
    });

    // SAVE / SHARE / REPORT (stats bar)
    document.querySelectorAll(".save-btn, .save-btn-main").forEach((btn) => {
      btn.addEventListener("click", () => {
        if (!isUserLoggedIn()) {
          showLoginModal();
          return;
        }
        const bookmarks = JSON.parse(localStorage.getItem("bookmarks") || "[]");
        if (!bookmarks.includes(postId || "")) {
          bookmarks.push(postId);
          localStorage.setItem("bookmarks", JSON.stringify(bookmarks));
          alert("Question saved!");
        } else {
          alert("Already saved!");
        }
      });
    });

    document
      .querySelectorAll(".share-btn-stats, .share-btn-main")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          const url = `${window.location.origin}/question/${slug}`;
          navigator.clipboard.writeText(url);
          alert("Link copied to clipboard!");
        });
      });

    document
      .querySelectorAll(".report-btn, .report-btn-main")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          if (!isUserLoggedIn()) {
            showLoginModal();
            return;
          }
          if (confirm("Report this question?"))
            alert("Thank you! We'll review it.");
        });
      });

    // LOAD COMMENTS
    async function loadComments() {
      if (!postId || !commentsContainer) return;
      const userEmail = localStorage.getItem("userId") || "";
      try {
        const res = await fetch(
          `${SCRIPT_URL}?action=getComments&postId=${postId}&userEmail=${encodeURIComponent(userEmail)}`,
        );
        const comments = await res.json();
        if (comments.length === 0) return; // Keep empty state
        commentsContainer.innerHTML = "";
        comments.forEach((c: any) => renderComment(c, null));
      } catch (err) {
        console.error(err);
      }
    }

    function renderComment(comment: any, parentID: string | null) {
      const div = document.createElement("div");
      div.className = "qcomment-item";
      const timeStr = comment.timestamp
        ? getTimeAgo(new Date(comment.timestamp))
        : "Just now";
      const likeClass = comment.userLiked ? "liked" : "";
      const avatarUrl = comment.userAvatar || "/assets/icon.png";
      div.innerHTML = `
        <img src="${avatarUrl}" class="qcomment-avatar" onerror="this.onerror=null;this.src='/assets/icon.png';" />
        <div class="qcomment-content">
          <div class="qcomment-meta">
            <span class="qcomment-name">${comment.userName}</span>
            <span class="dot">•</span>
            <span class="qcomment-time">${timeStr}</span>
          </div>
          <p class="qcomment-text">${comment.text || ""}</p>
          <div class="qcomment-actions">
            <button class="qcomment-action like-btn" data-comment-id="${comment.id}" type="button">
              ${comment.userLiked ? "❤️" : "🤍"} <span class="like-count">${comment.likes || 0}</span>
            </button>
            <button class="qcomment-action" type="button">Reply</button>
          </div>
        </div>
      `;
      const likeBtn = div.querySelector(".like-btn");
      likeBtn?.addEventListener("click", () =>
        toggleLike(comment.id, likeBtn as HTMLButtonElement),
      );
      commentsContainer?.appendChild(div);
    }

    async function toggleLike(commentId: string, btn: HTMLButtonElement) {
      if (!isUserLoggedIn()) {
        showLoginModal();
        return;
      }
      try {
        const res = await fetch(SCRIPT_URL, {
          method: "POST",
          body: JSON.stringify({
            action: "toggleCommentLike",
            commentId,
            userEmail: localStorage.getItem("userId") || "",
          }),
        });
        const result = await res.json();
        if (result.status === "success") {
          btn.innerHTML = `${result.liked ? "❤️" : "🤍"} <span class="like-count">${result.likes}</span>`;
          btn.classList.toggle("liked", result.liked);
        }
      } catch (err) {
        console.error(err);
      }
    }

    loadComments();
  }
</script>
