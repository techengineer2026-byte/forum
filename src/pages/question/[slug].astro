---
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const SCRIPT_URL =
    "https://script.google.com/macros/s/AKfycbwS4kLCU7sm9LX0sGrBC4f8LNAuSyGwjaSS6fEJq3jbwQapxoVnX6Qs2VXQO2ePecs8rA/exec";

  function sanitizeSlug(raw: string | null | undefined): string {
    if (!raw) return "";
    return raw
      .toLowerCase()
      .replace(/[^\w -]+/g, "") // Keeps hyphens!
      .replace(/ +/g, "-")
      .replace(/-+/g, "-")
      .replace(/^-+|-+$/g, "")
      .trim();
  }

  try {
    const res = await fetch(`${SCRIPT_URL}?action=getPosts`);
    const posts = await res.json();

    return posts
      .map((p: any) => {
        const slug =
          sanitizeSlug(p.slug) || sanitizeSlug(p.heading) || String(p.id || "");

        const safePost = { ...p };

        // Strip base64 from images (prevents 431 error)
        if (safePost.images) {
          try {
            let imgs =
              typeof safePost.images === "string"
                ? JSON.parse(safePost.images)
                : safePost.images;
            if (Array.isArray(imgs)) {
              safePost.images = imgs.filter(
                (img: any) =>
                  typeof img === "string" &&
                  !img.startsWith("iVBOR") &&
                  !img.startsWith("/9j/"),
              );
            }
          } catch {
            safePost.images = [];
          }
        }

        // Strip base64 from avatar
        if (
          safePost.avatar &&
          typeof safePost.avatar === "string" &&
          (safePost.avatar.startsWith("iVBOR") ||
            safePost.avatar.startsWith("/9j/"))
        ) {
          safePost.avatar = "";
        }

        return { params: { slug }, props: { post: safePost } };
      })
      .filter((item) => item.params.slug && item.params.slug.trim() !== "");
  } catch (e) {
    return [];
  }
}

const { post }: { post: any } = Astro.props;

// ===== SEO & MEDIA HELPERS (Keep your existing code below) =====
function stripHtml(html: string): string {
  return html
    .replace(/<[^>]*>/g, "")
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">")
    .replace(/&amp;/g, "&")
    .replace(/&#39;/g, "'")
    .replace(/&quot;/g, '"')
    .replace(/\s+/g, " ")
    .trim();
}

function getMediaUrl(url: string | null | undefined): string {
  if (!url || url === "icon.png" || url === "null" || url === "")
    return "/assets/icon.png";
  if (url.startsWith("data:")) return url;
  if (url.startsWith("http://") || url.startsWith("https://")) return url;
  if (url.startsWith("iVBOR") || url.startsWith("/9j/"))
    return `data:image/png;base64,${url}`;
  return `/assets/${url}`;
}
function getSeoImage(p: any): { url: string; isSquare: boolean } {
  // FIRST: Check post images - but be more thorough!
  let images: any = p?.images || [];
  if (typeof images === "string") {
    try {
      images = JSON.parse(images);
    } catch {
      // Try splitting by comma if JSON parse fails
      images = images.split(",").filter((i: string) => i.trim() !== "");
    }
  }

  // Filter images properly
  if (Array.isArray(images)) {
    const validImages = images.filter(
      (img: any) =>
        img &&
        typeof img === "string" &&
        img.length > 10 &&
        (img.startsWith("http://") ||
          img.startsWith("https://") ||
          img.startsWith("data:")),
    );

    if (validImages.length > 0) {
      const firstImage = validImages[0];
      if (typeof firstImage === "string" && firstImage.startsWith("http")) {
        // ✅ POST IMAGE FOUND - RETURN IT
        return { url: firstImage, isSquare: false }; // Assuming post images are landscape
      }
    }
  }

  // SECOND: Only if NO post images, use avatar
  if (
    p?.avatar &&
    p.avatar !== "icon.png" &&
    p.avatar !== "null" &&
    p.avatar.length > 5 &&
    typeof p.avatar === "string" &&
    p.avatar.startsWith("http")
  ) {
    const resizedAvatar = p.avatar.replace(/=s\d+-c$/, "=s800-c");
    return { url: resizedAvatar, isSquare: true };
  }

  // THIRD: Fallback to default icon
  return { url: "/assets/NoImage.png", isSquare: false };
}

function parseUrlImages(p: any): string[] {
  let imagesRaw: any = p?.images || [];
  if (typeof imagesRaw === "string") {
    try {
      imagesRaw = JSON.parse(imagesRaw);
    } catch {
      imagesRaw = imagesRaw.split(",").filter((i: string) => i.trim() !== "");
    }
  }
  return [...new Set(imagesRaw as any[])].filter(
    (img: any) =>
      img &&
      img !== "null" &&
      typeof img === "string" &&
      (img.startsWith("http://") || img.startsWith("https://")),
  ) as string[];
}

const postImages = parseUrlImages(post);
const seoTitle = post
  ? `${post.heading} | Tech Engineer Forum`
  : "Question | Tech Engineer Forum";
const rawDescription = post?.description || post?.heading || "";
let seoDescription = stripHtml(rawDescription).substring(0, 160);
const { url: seoImageUrl, isSquare: seoImageIsSquare } = getSeoImage(post);
if (seoDescription.length < 80) {
  const headingText = post?.heading ? `${post.heading} - ` : "";
  seoDescription = `${headingText}Ask and answer tech questions on Tech Engineer Forum. Join the community of developers.`;
  seoDescription = seoDescription.substring(0, 160);
}

const jsonLd = post
  ? {
      "@context": "https://schema.org",
      "@type": "QAPage",
      mainEntity: {
        "@type": "Question",
        name: post.heading,
        text: stripHtml(post.description || ""),
        author: { "@type": "Person", name: post.name || "Anonymous" },
        dateCreated: post.updated_time || undefined,
        answerCount: post.comments || 0,
        upvoteCount: post.upvotes || 0,
      },
    }
  : null;
const hasValidAvatar =
  post?.avatar &&
  post.avatar !== "icon.png" &&
  post.avatar !== "null" &&
  post.avatar !== "";
const avatarLetter = (post?.name || "U").charAt(0).toUpperCase();
---

<Layout
  title={seoTitle}
  description={seoDescription}
  image={seoImageUrl}
  imageIsSquare={seoImageIsSquare}
>
  <!-- JSON-LD for Google Rich Results -->
  {
    jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )
  }

  <div class="qpage">
    <!-- BREADCRUMB — server-rendered ✅ -->
    <nav class="qbreadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/">TechCast</a></li>
        <li><a href="/">Questions</a></li>
        <li class="active">{post?.heading || "Question"}</li>
      </ol>
    </nav>

    <div class="qlayout">
      <!-- MAIN CONTENT -->
      <main class="qmain">
        <!-- QUESTION CARD — server-rendered from props ✅ -->
        <article
          class="qcard"
          id="qCard"
          data-id={post?.id}
          data-upvotes={post?.upvotes || 0}
        >
          <div class="qcard-top">
            <!-- VOTE COLUMN -->
            <div class="qvote-col">
              <button
                class="qvote-btn upvote-btn"
                type="button"
                aria-label="Upvote"
              >
                <svg
                  class="qicon"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M12 19V5M5 12l7-7 7 7"></path></svg
                >
              </button>
              <span class="qvote-count" id="voteCount"
                >{post?.upvotes || 0}</span
              >
              <span class="qvote-label">Vote</span>
              <button
                class="qvote-btn downvote-btn"
                type="button"
                aria-label="Downvote"
              >
                <svg
                  class="qicon"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M12 5v14M19 12l-7 7-7-7"></path></svg
                >
              </button>
            </div>

            <!-- CONTENT COLUMN -->
            <div class="qcontent-col">
              <h1 class="qtitle">{post?.heading || ""}</h1>

              <div class="qmeta-row">
                {
                  hasValidAvatar ? (
                    <img
                      src={getMediaUrl(post.avatar)}
                      alt={post.name || "User"}
                      class="qavatar"
                      width="36"
                      height="36"
                      style="border-radius:50%"
                    />
                  ) : (
                    <div class="avatar letter-avatar">{avatarLetter}</div>
                  )
                }
                <div class="qmeta-info">
                  <a
                    href={`/user?name=${encodeURIComponent(post?.name || "")}`}
                    class="qauthor-name"
                  >
                    {post?.name || "Anonymous"}
                  </a>
                  <div class="qauthor-sub">
                    <span>{post?.role_name || "Tech Engineer"}</span> •
                    <span>Asked </span><span
                      >{post?.updated_time || "Recently"}</span
                    >
                  </div>
                </div>
              </div>

              <div class="qdescription" set:html={post?.description || ""} />

              <!-- IMAGES GRID -->
              {
                postImages.length > 0 && (
                  <div
                    class={`qimages-grid grid-${Math.min(postImages.length, 4)}`}
                  >
                    {postImages
                      .slice(0, 4)
                      .map((img: string, index: number) => {
                        const imgUrl = getMediaUrl(img);
                        return (
                          <div
                            class={`grid-item${index === 3 && postImages.length > 4 ? " with-overlay" : ""}`}
                          >
                            <img
                              src={imgUrl}
                              alt=""
                              onerror="this.parentElement.style.display='none'"
                            />
                            {index === 3 && postImages.length > 4 && (
                              <div class="more-count">
                                +{postImages.length - 3}
                              </div>
                            )}
                          </div>
                        );
                      })}
                  </div>
                )
              }
            </div>
          </div>

          <!-- STATS BAR -->
          <div class="qdivider"></div>
          <div class="qstats-bar">
            <span class="qstat-item">
              <svg
                class="qstat-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M12 19V5M5 12l7-7 7 7"></path></svg
              >
              <span id="statVotes">{post?.upvotes || 0}</span> Votes
            </span>
            <span class="qstat-item">
              <svg
                class="qstat-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"
                ></path></svg
              >
              <span id="statAnswers">{post?.comments || 0}</span> Answers
            </span>
            <span class="qstat-item">
              <svg
                class="qstat-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"
                ></path><circle cx="12" cy="12" r="3"></circle></svg
              >
              <span id="statViews">--</span> Views
            </span>
          </div>

          <!-- ACTION BUTTONS -->
          <div class="qaction-buttons">
            <button class="qbtn-primary write-answer-main">
              <svg
                class="qbtn-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M12 20h9"></path><path
                  d="M16.5 3.5a2.121 2.121 0 113 3L7 19l-4 1 1-4L16.5 3.5z"
                ></path></svg
              >
              Answer Question
            </button>
            <button class="qbtn-secondary share-btn-main">
              <svg
                class="qbtn-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="18" cy="5" r="3"></circle><circle
                  cx="6"
                  cy="12"
                  r="3"></circle><circle cx="18" cy="19" r="3"></circle><line
                  x1="8.59"
                  y1="13.51"
                  x2="15.42"
                  y2="17.49"></line><line
                  x1="15.41"
                  y1="6.51"
                  x2="8.59"
                  y2="10.49"></line></svg
              >
              Share
            </button>
            <button class="qbtn-secondary report-btn-main">
              <svg
                class="qbtn-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"
                ></path><line x1="4" y1="22" x2="4" y2="15"></line></svg
              >
              Report
            </button>
            <button
              class="qbtn-secondary delete-post-btn"
              id="deletePostBtn"
              style="display:none; color:#cb2027; border-color:#fecaca;"
            >
              <svg
                class="qbtn-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="3 6 5 6 21 6"></polyline><path
                  d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"
                ></path></svg
              >
              Delete
            </button>
          </div>
        </article>

        <!-- ANSWERS SECTION — still loads dynamically -->
        <section class="qanswers-section">
          <h2 class="qanswers-title">
            Answers (<span id="answersCount">{post?.comments || 0}</span>)
          </h2>
          <div id="commentsContainer">
            <div class="qempty-answers">
              <p>Loading answers...</p>
            </div>
          </div>

          <!-- ADD ANSWER INPUT -->
          <div class="qadd-answer">
            <input
              type="text"
              id="answerInput"
              placeholder="Write an answer..."
            />
            <button id="submitAnswerBtn" class="qbtn-primary">
              <svg
                class="qbtn-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><line x1="22" y1="2" x2="11" y2="13"></line><polygon
                  points="22 2 15 22 11 13 2 9 22 2"></polygon></svg
              >
              Post
            </button>
          </div>
        </section>
      </main>

      <!-- RIGHT SIDEBAR — server-rendered ✅ -->
      <aside class="qsidebar">
        <div class="qsidebar-card">
          <h3 class="qsidebar-title">Question Stats</h3>
          <ul class="qstats-list">
            <li>
              <span class="qstat-label">Asked</span>
              <span class="qstat-value">{post?.updated_time || "Recently"}</span
              >
            </li>
            <li>
              <span class="qstat-label">Upvotes</span>
              <span class="qstat-value" id="sidebarVotes"
                >{post?.upvotes || 0}</span
              >
            </li>
            <li>
              <span class="qstat-label">Answers</span>
              <span class="qstat-value" id="sidebarAnswers"
                >{post?.comments || 0}</span
              >
            </li>
          </ul>
        </div>
      </aside>
    </div>
  </div>

  <!-- TOAST NOTIFICATION -->
  <div id="toast" class="qtoast">
    <span id="toastIcon" class="qtoast-icon-wrap"></span>
    <span id="toastMsg"></span>
  </div>

  <!-- REPORT MODAL -->
  <div id="reportModal" class="qmodal-overlay" style="display:none;">
    <div class="qmodal">
      <h3 class="qmodal-title">
        <svg
          class="qmodal-title-icon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"
          ></path><line x1="4" y1="22" x2="4" y2="15"></line></svg
        >
        Report Question
      </h3>
      <p class="qmodal-desc">Why are you reporting this question?</p>
      <div class="qmodal-options">
        <label class="qmodal-option">
          <input type="radio" name="reportReason" value="spam" />
          <span>Spam or advertisement</span>
        </label>
        <label class="qmodal-option">
          <input type="radio" name="reportReason" value="inappropriate" />
          <span>Inappropriate content</span>
        </label>
        <label class="qmodal-option">
          <input type="radio" name="reportReason" value="misleading" />
          <span>Misleading or incorrect</span>
        </label>
        <label class="qmodal-option">
          <input type="radio" name="reportReason" value="duplicate" />
          <span>Duplicate question</span>
        </label>
        <label class="qmodal-option">
          <input type="radio" name="reportReason" value="other" />
          <span>Other</span>
        </label>
      </div>
      <textarea
        id="reportDetails"
        class="qmodal-textarea"
        placeholder="Additional details (optional)..."
        rows="3"></textarea>
      <div class="qmodal-actions">
        <button class="qbtn-secondary" id="reportCancelBtn">Cancel</button>
        <button class="qbtn-primary" id="reportSubmitBtn">Submit Report</button>
      </div>
    </div>
  </div>
  <!-- IMAGE LIGHTBOX -->
  <div id="imageLightbox" class="lightbox-overlay">
    <button class="lightbox-close" id="lightboxClose" aria-label="Close">
      <svg
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <div class="lightbox-content">
      <img id="lightboxImg" src="" alt="" />
    </div>
    <div class="lightbox-counter" id="lightboxCounter"></div>
    <button
      class="lightbox-nav lightbox-prev"
      id="lightboxPrev"
      aria-label="Previous"
    >
      <svg
        width="32"
        height="32"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>
    <button
      class="lightbox-nav lightbox-next"
      id="lightboxNext"
      aria-label="Next"
    >
      <svg
        width="32"
        height="32"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</Layout>

<style is:global>
  /* ===== SKELETON LOADING ===== */
  .skel {
    background: linear-gradient(90deg, #e5e7eb 25%, #f3f4f6 50%, #e5e7eb 75%);
    background-size: 200% 100%;
    animation: skelPulse 1.5s ease-in-out infinite;
    border-radius: 6px;
  }
  @keyframes skelPulse {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  /* ===== ICON SIZES ===== */
  .qicon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  .qstat-icon {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    position: relative;
    top: 2px;
    margin-right: 2px;
  }
  .qbtn-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  .qmodal-title-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    position: relative;
    top: 3px;
    margin-right: 4px;
    color: #ef4444;
  }
  .qlike-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    position: relative;
    top: 1px;
  }

  /* ===== BASE PAGE ===== */
  .qpage {
    max-width: 1180px;
    margin: 0 auto;
    padding: 20px 15px;
    background: #f9fafb;
    min-height: 100vh;
  }
  .qbreadcrumb {
    padding: 12px 0;
    font-size: 13px;
  }
  .qbreadcrumb ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 6px;
  }
  .qbreadcrumb li:not(:last-child)::after {
    content: "›";
    margin-left: 6px;
    color: #ccc;
  }
  .qbreadcrumb a {
    color: #2e69ff;
    text-decoration: none;
  }
  .qbreadcrumb .active {
    color: #282829;
    max-width: 400px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .qlayout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 20px;
  }
  @media (max-width: 900px) {
    .qlayout {
      grid-template-columns: 1fr;
    }
  }

  .qcard {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 20px;
  }
  .qcard-top {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 20px;
  }
  @media (max-width: 500px) {
    .qcard-top {
      grid-template-columns: 1fr;
    }
    .qvote-col {
      flex-direction: row !important;
      justify-content: center;
      gap: 12px !important;
    }
  }
  .qvote-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .qvote-btn {
    background: transparent;
    border: 1px solid #e5e7eb;
    color: #6b7280;
    cursor: pointer;
    padding: 6px;
    border-radius: 6px;
    display: flex;
    transition: all 0.15s ease;
  }
  .qvote-btn:hover {
    background: #f3f4f6;
    color: #111827;
  }
  .qvote-btn.active-up {
    background: #dbeafe;
    border-color: #2e69ff;
    color: #2e69ff;
  }
  .qvote-btn.active-down {
    background: #fee2e2;
    border-color: #ef4444;
    color: #ef4444;
  }
  .qvote-count {
    font-size: 20px;
    font-weight: 800;
    color: #111827;
    margin-top: 4px;
  }
  .qvote-label {
    font-size: 11px;
    color: #6b7280;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .qtitle {
    font-size: 22px;
