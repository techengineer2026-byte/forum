---
export async function getStaticPaths() {
  const SCRIPT_URL =
    "https://script.google.com/macros/s/AKfycbywCeoEu7CNLZtgRKyy4wsnvGw8B6wpNrP5ke0RoJ6XrVfwgsmBKAlIKvli79IVAWQJxQ/exec";

  try {
    const res = await fetch(`${SCRIPT_URL}?action=getPosts`);
    const posts = await res.json();
    return posts.map((p: any) => ({
      params: {
        slug:
          p.slug ||
          p.heading
            ?.toLowerCase()
            .replace(/[^\w ]+/g, "")
            .replace(/ +/g, "-") ||
          "",
      },
    }));
  } catch (e) {
    return [];
  }
}

import Layout from "../../layouts/Layout.astro";
---

<Layout title="Loading Question...">
  <div class="qpage">
    <!-- BREADCRUMB -->
    <nav class="qbreadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/">TechCast</a></li>
        <li><a href="/">Questions</a></li>
        <li class="active" id="bc-title">Loading...</li>
      </ol>
    </nav>

    <div class="qlayout">
      <!-- MAIN CONTENT -->
      <main class="qmain">
        <!-- SKELETON LOADER -->
        <div id="qLoader" class="qcard">
          <div class="qcard-top">
            <div class="qvote-col">
              <div class="skel skel-btn"></div>
              <div class="skel skel-vote"></div>
              <div class="skel skel-sm"></div>
              <div class="skel skel-btn"></div>
            </div>
            <div class="qcontent-col">
              <div class="skel skel-title"></div>
              <div class="qmeta-row">
                <div class="skel skel-avatar"></div>
                <div>
                  <div class="skel skel-name"></div>
                  <div class="skel skel-sub"></div>
                </div>
              </div>
              <div class="skel skel-line"></div>
              <div class="skel skel-line skel-short"></div>
              <div class="skel skel-line skel-short2"></div>
            </div>
          </div>
          <div class="qdivider"></div>
          <div class="qstats-bar">
            <div class="skel skel-stat"></div>
            <div class="skel skel-stat"></div>
            <div class="skel skel-stat"></div>
          </div>
          <div class="qaction-buttons">
            <div class="skel skel-action"></div>
            <div class="skel skel-action"></div>
            <div class="skel skel-action"></div>
          </div>
        </div>

        <!-- 404 STATE -->
        <div id="qNotFound" class="qstate-box" style="display:none;">
          <h2>Question not found</h2>
          <p>This question may have been removed or doesn't exist.</p>
          <a href="/" class="back-link">← Back to Home</a>
        </div>

        <!-- ACTUAL QUESTION CONTENT -->
        <div id="qContent" style="display:none;">
          <article class="qcard" id="qCard">
            <div class="qcard-top">
              <!-- VOTE COLUMN -->
              <div class="qvote-col">
                <button
                  class="qvote-btn upvote-btn"
                  type="button"
                  aria-label="Upvote"
                >
                  <svg
                    class="qicon"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M12 19V5M5 12l7-7 7 7"></path></svg
                  >
                </button>
                <span class="qvote-count" id="voteCount">0</span>
                <span class="qvote-label">Vote</span>
                <button
                  class="qvote-btn downvote-btn"
                  type="button"
                  aria-label="Downvote"
                >
                  <svg
                    class="qicon"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M12 5v14M19 12l-7 7-7-7"></path></svg
                  >
                </button>
              </div>

              <!-- CONTENT COLUMN -->
              <div class="qcontent-col">
                <h1 class="qtitle" id="qTitle"></h1>

                <div class="qmeta-row">
                  <img
                    src="/assets/icon.png"
                    class="qavatar"
                    id="qAvatar"
                    width="36"
                    height="36"
                    style="border-radius:50%"
                  />
                  <div class="qmeta-info">
                    <a href="#" class="qauthor-name" id="qAuthor"></a>
                    <div class="qauthor-sub">
                      <span id="qRole"></span> • <span>Asked </span><span
                        id="qTime"></span>
                    </div>
                  </div>
                </div>

                <p class="qdescription" id="qDesc"></p>
              </div>
            </div>

            <!-- STATS BAR -->
            <div class="qdivider"></div>
            <div class="qstats-bar">
              <span class="qstat-item">
                <svg
                  class="qstat-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M12 19V5M5 12l7-7 7 7"></path></svg
                >
                <span id="statVotes">0</span> Votes
              </span>
              <span class="qstat-item">
                <svg
                  class="qstat-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"
                  ></path></svg
                >
                <span id="statAnswers">0</span> Answers
              </span>
              <span class="qstat-item">
                <svg
                  class="qstat-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"
                  ></path><circle cx="12" cy="12" r="3"></circle></svg
                >
                <span id="statViews">0</span> Views
              </span>
            </div>

            <!-- ACTION BUTTONS -->
            <div class="qaction-buttons">
              <button class="qbtn-primary write-answer-main">
                <svg
                  class="qbtn-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M12 20h9"></path><path
                    d="M16.5 3.5a2.121 2.121 0 113 3L7 19l-4 1 1-4L16.5 3.5z"
                  ></path></svg
                >
                Answer Question
              </button>
              <button class="qbtn-secondary share-btn-main">
                <svg
                  class="qbtn-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><circle cx="18" cy="5" r="3"></circle><circle
                    cx="6"
                    cy="12"
                    r="3"></circle><circle cx="18" cy="19" r="3"></circle><line
                    x1="8.59"
                    y1="13.51"
                    x2="15.42"
                    y2="17.49"></line><line
                    x1="15.41"
                    y1="6.51"
                    x2="8.59"
                    y2="10.49"></line></svg
                >
                Share
              </button>
              <button class="qbtn-secondary report-btn-main">
                <svg
                  class="qbtn-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"
                  ></path><line x1="4" y1="22" x2="4" y2="15"></line></svg
                >
                Report
              </button>
            </div>
          </article>

          <!-- ANSWERS SECTION -->
          <section class="qanswers-section">
            <h2 class="qanswers-title">
              Answers (<span id="answersCount">0</span>)
            </h2>
            <div id="commentsContainer">
              <div class="qempty-answers">
                <p>Be the first to answer this question!</p>
              </div>
            </div>

            <!-- ADD ANSWER INPUT -->
            <div class="qadd-answer">
              <input
                type="text"
                id="answerInput"
                placeholder="Write an answer..."
              />
              <button id="submitAnswerBtn" class="qbtn-primary">
                <svg
                  class="qbtn-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><line x1="22" y1="2" x2="11" y2="13"></line><polygon
                    points="22 2 15 22 11 13 2 9 22 2"></polygon></svg
                >
                Post
              </button>
            </div>
          </section>
        </div>
      </main>

      <!-- RIGHT SIDEBAR -->
      <aside class="qsidebar">
        <!-- SKELETON SIDEBAR -->
        <div id="sidebarLoader" class="qsidebar-card">
          <div class="skel skel-sidebar-title"></div>
          <ul class="qstats-list">
            <li><div class="skel skel-sidebar-row"></div></li>
            <li><div class="skel skel-sidebar-row"></div></li>
            <li><div class="skel skel-sidebar-row"></div></li>
          </ul>
        </div>

        <!-- REAL SIDEBAR -->
        <div id="sidebarContent" class="qsidebar-card" style="display:none;">
          <h3 class="qsidebar-title">Question Stats</h3>
          <ul class="qstats-list">
            <li>
              <span class="qstat-label">Asked</span>
              <span class="qstat-value" id="sidebarTime">-</span>
            </li>
            <li>
              <span class="qstat-label">Upvotes</span>
              <span class="qstat-value" id="sidebarVotes">0</span>
            </li>
            <li>
              <span class="qstat-label">Answers</span>
              <span class="qstat-value" id="sidebarAnswers">0</span>
            </li>
          </ul>
        </div>
      </aside>
    </div>
  </div>

  <!-- TOAST NOTIFICATION -->
  <div id="toast" class="qtoast">
    <span id="toastIcon" class="qtoast-icon-wrap"></span>
    <span id="toastMsg"></span>
  </div>

  <!-- REPORT MODAL -->
  <div id="reportModal" class="qmodal-overlay" style="display:none;">
    <div class="qmodal">
      <h3 class="qmodal-title">
        <svg
          class="qmodal-title-icon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"
          ></path><line x1="4" y1="22" x2="4" y2="15"></line></svg
        >
        Report Question
      </h3>
      <p class="qmodal-desc">Why are you reporting this question?</p>
      <div class="qmodal-options">
        <label class="qmodal-option">
          <input type="radio" name="reportReason" value="spam" />
          <span>Spam or advertisement</span>
        </label>
        <label class="qmodal-option">
          <input type="radio" name="reportReason" value="inappropriate" />
          <span>Inappropriate content</span>
        </label>
        <label class="qmodal-option">
          <input type="radio" name="reportReason" value="misleading" />
          <span>Misleading or incorrect</span>
        </label>
        <label class="qmodal-option">
          <input type="radio" name="reportReason" value="duplicate" />
          <span>Duplicate question</span>
        </label>
        <label class="qmodal-option">
          <input type="radio" name="reportReason" value="other" />
          <span>Other</span>
        </label>
      </div>
      <textarea
        id="reportDetails"
        class="qmodal-textarea"
        placeholder="Additional details (optional)..."
        rows="3"></textarea>
      <div class="qmodal-actions">
        <button class="qbtn-secondary" id="reportCancelBtn">Cancel</button>
        <button class="qbtn-primary" id="reportSubmitBtn">Submit Report</button>
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  /* ===== SKELETON LOADING ===== */
  .skel {
    background: linear-gradient(90deg, #e5e7eb 25%, #f3f4f6 50%, #e5e7eb 75%);
    background-size: 200% 100%;
    animation: skelPulse 1.5s ease-in-out infinite;
    border-radius: 6px;
  }
  @keyframes skelPulse {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }
  .skel-btn {
    width: 32px;
    height: 32px;
    border-radius: 6px;
  }
  .skel-vote {
    width: 28px;
    height: 24px;
    margin: 4px 0;
  }
  .skel-sm {
    width: 28px;
    height: 12px;
  }
  .skel-title {
    width: 80%;
    height: 28px;
    margin-bottom: 16px;
  }
  .skel-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .skel-name {
    width: 120px;
    height: 16px;
    margin-bottom: 6px;
  }
  .skel-sub {
    width: 160px;
    height: 12px;
  }
  .skel-line {
    width: 100%;
    height: 14px;
    margin-bottom: 10px;
  }
  .skel-short {
    width: 75%;
  }
  .skel-short2 {
    width: 50%;
  }
  .skel-stat {
    width: 80px;
    height: 16px;
  }
  .skel-action {
    width: 150px;
    height: 38px;
    border-radius: 6px;
  }
  .skel-sidebar-title {
    width: 60%;
    height: 18px;
    margin-bottom: 16px;
  }
  .skel-sidebar-row {
    width: 100%;
    height: 20px;
  }

  /* ===== ICON SIZES ===== */
  .qicon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  .qstat-icon {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    position: relative;
    top: 2px;
    margin-right: 2px;
  }
  .qbtn-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  .qmodal-title-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    position: relative;
    top: 3px;
    margin-right: 4px;
    color: #ef4444;
  }
  .qlike-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    position: relative;
    top: 1px;
  }

  /* ===== BASE PAGE ===== */
  .qpage {
    max-width: 1180px;
    margin: 0 auto;
    padding: 20px 15px;
    background: #f9fafb;
    min-height: 100vh;
  }
  .qstate-box {
    text-align: center;
    padding: 80px 0;
    color: #939598;
    font-size: 16px;
    background: white;
    border-radius: 8px;
    margin-top: 20px;
  }
  .qstate-box h2 {
    margin: 0 0 8px;
    color: #111827;
  }
  .qstate-box .back-link {
    color: #2e69ff;
    text-decoration: none;
    font-weight: 600;
  }
  .qbreadcrumb {
    padding: 12px 0;
    font-size: 13px;
  }
  .qbreadcrumb ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 6px;
  }
  .qbreadcrumb li:not(:last-child)::after {
    content: "›";
    margin-left: 6px;
    color: #ccc;
  }
  .qbreadcrumb a {
    color: #2e69ff;
    text-decoration: none;
  }
  .qbreadcrumb .active {
    color: #282829;
    max-width: 400px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .qlayout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 20px;
  }
  @media (max-width: 900px) {
    .qlayout {
      grid-template-columns: 1fr;
    }
  }

  .qcard {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 20px;
  }
  .qcard-top {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 20px;
  }
  @media (max-width: 500px) {
    .qcard-top {
      grid-template-columns: 1fr;
    }
    .qvote-col {
      flex-direction: row !important;
      justify-content: center;
      gap: 12px !important;
    }
  }
  .qvote-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .qvote-btn {
    background: transparent;
    border: 1px solid #e5e7eb;
    color: #6b7280;
    cursor: pointer;
    padding: 6px;
    border-radius: 6px;
    display: flex;
    transition: all 0.15s ease;
  }
  .qvote-btn:hover {
    background: #f3f4f6;
    color: #111827;
  }
  .qvote-btn.active-up {
    background: #dbeafe;
    border-color: #2e69ff;
    color: #2e69ff;
  }
  .qvote-btn.active-down {
    background: #fee2e2;
    border-color: #ef4444;
    color: #ef4444;
  }
  .qvote-count {
    font-size: 20px;
    font-weight: 800;
    color: #111827;
    margin-top: 4px;
  }
  .qvote-label {
    font-size: 11px;
    color: #6b7280;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .qtitle {
    font-size: 22px;
    font-weight: 800;
    margin: 0 0 16px 0;
    line-height: 1.35;
    color: #111827;
  }

  .qmeta-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }
  .qavatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    background: #f1f2f2;
    flex-shrink: 0;
  }
  .qauthor-name {
    font-weight: 700;
    font-size: 14px;
    color: #2e69ff;
    text-decoration: none;
  }
  .qauthor-name:hover {
    text-decoration: underline;
  }
  .qauthor-sub {
    font-size: 12px;
    color: #6b7280;
    display: flex;
    gap: 6px;
    margin-top: 2px;
  }
  .qdescription {
    font-size: 15px;
    line-height: 1.7;
    color: #374151;
    margin: 0 0 12px 0;
  }

  .qdivider {
    height: 1px;
    background: #f3f4f6;
    margin: 16px -20px;
  }
  .qstats-bar {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    padding-bottom: 16px;
  }
  .qstat-item {
    font-size: 13px;
    color: #6b7280;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .qaction-buttons {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .qbtn-primary {
    background: #2e69ff;
    color: white;
    border: none;
    padding: 9px 20px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.15s ease;
  }
  .qbtn-primary:hover {
    background: #1e5ae6;
  }
  .qbtn-primary:active {
    transform: scale(0.97);
  }
  .qbtn-primary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .qbtn-secondary {
    background: white;
    color: #374151;
    border: 1px solid #d1d5db;
    padding: 9px 18px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.15s ease;
  }
  .qbtn-secondary:hover {
    background: #f9fafb;
    border-color: #9ca3af;
  }
  .qbtn-secondary:active {
    transform: scale(0.97);
  }

  .qanswers-section {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 24px;
    margin-top: 16px;
  }
  .qanswers-title {
    font-size: 18px;
    margin: 0 0 24px 0;
    color: #111827;
    font-weight: 700;
  }
  .qempty-answers {
    text-align: center;
    padding: 30px 20px 40px;
    color: #6b7280;
  }

  .qcomment-item {
    display: flex;
    gap: 12px;
    padding: 16px 0;
    border-bottom: 1px solid #f3f4f6;
  }
  .qcomment-item:last-child {
    border-bottom: none;
  }
  .qcomment-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
  .qcomment-content {
    flex: 1;
  }
  .qcomment-name {
    font-weight: 700;
    font-size: 14px;
    color: #111827;
  }
  .qcomment-time {
    font-size: 12px;
    color: #6b7280;
    margin-left: 6px;
  }
  .qcomment-text {
    font-size: 15px;
    color: #1f2937;
    margin: 6px 0 0 0;
    line-height: 1.6;
  }
  .qlike-btn {
    background: none;
    border: 1px solid transparent;
    cursor: pointer;
    font-size: 13px;
    color: #6b7280;
    padding: 4px 8px;
    border-radius: 4px;
    transition: all 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
  .qlike-btn:hover {
    background: #fef2f2;
    border-color: #fecaca;
    color: #ef4444;
  }
  .qlike-btn.liked {
    color: #ef4444;
  }

  .qadd-answer {
    margin-top: 20px;
    display: flex;
    gap: 10px;
  }
  .qadd-answer input {
    flex: 1;
    padding: 10px 14px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 14px;
    outline: none;
    transition: border-color 0.15s;
  }
  .qadd-answer input:focus {
    border-color: #2e69ff;
    box-shadow: 0 0 0 3px rgba(46, 105, 255, 0.1);
  }

  .qsidebar-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 18px;
  }
  .qsidebar-title {
    font-size: 15px;
    font-weight: 700;
    margin: 0 0 16px 0;
    color: #111827;
  }
  .qstats-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .qstats-list li {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid #f3f4f6;
    font-size: 14px;
  }
  .qstats-list li:last-child {
    border-bottom: none;
  }
  .qstat-label {
    color: #6b7280;
  }
  .qstat-value {
    color: #111827;
    font-weight: 700;
  }

  /* ===== TOAST ===== */
  .qtoast {
    position: fixed;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    background: #111827;
    color: white;
    padding: 12px 24px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transition: all 0.3s ease;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    display: flex;
    align-items: center;
    gap: 8px;
    max-width: 90vw;
  }
  .qtoast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .qtoast-icon-wrap {
    display: flex;
    align-items: center;
  }
  .qtoast-icon-wrap svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }
  .qtoast.success {
    background: #065f46;
  }
  .qtoast.error {
    background: #991b1b;
  }
  .qtoast.info {
    background: #111827;
  }

  /* ===== REPORT MODAL ===== */
  .qmodal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 9998;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    animation: fadeIn 0.2s ease;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  .qmodal {
    background: white;
    border-radius: 12px;
    padding: 28px;
    max-width: 460px;
    width: 100%;
    animation: slideUp 0.25s ease;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
  }
  @keyframes slideUp {
    from {
      transform: translateY(20px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
  .qmodal-title {
    margin: 0 0 6px;
    font-size: 18px;
    font-weight: 800;
    color: #111827;
    display: flex;
    align-items: center;
  }
  .qmodal-desc {
    margin: 0 0 18px;
    font-size: 14px;
    color: #6b7280;
  }
  .qmodal-options {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 14px;
  }
  .qmodal-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.15s;
    font-size: 14px;
    color: #374151;
  }
  .qmodal-option:hover {
    background: #f9fafb;
    border-color: #d1d5db;
  }
  .qmodal-option input[type="radio"] {
    accent-color: #2e69ff;
    width: 16px;
    height: 16px;
  }
  .qmodal-option input[type="radio"]:checked + span {
    color: #111827;
    font-weight: 600;
  }
  .qmodal-textarea {
    width: 100%;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 14px;
    resize: vertical;
    outline: none;
    margin-bottom: 18px;
    font-family: inherit;
  }
  .qmodal-textarea:focus {
    border-color: #2e69ff;
    box-shadow: 0 0 0 3px rgba(46, 105, 255, 0.1);
  }
  .qmodal-actions {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
  }
</style>

<script>
  const SCRIPT_URL =
    "https://script.google.com/macros/s/AKfycbywCeoEu7CNLZtgRKyy4wsnvGw8B6wpNrP5ke0RoJ6XrVfwgsmBKAlIKvli79IVAWQJxQ/exec";

  const pathParts = window.location.pathname.split("/");
  const slug =
    pathParts[pathParts.length - 1] || pathParts[pathParts.length - 2];

  interface Post {
    id: string;
    heading: string;
    avatar: string;
    upvotes: number;
    comments: number;
  }

  let currentPost: Post | null = null;
  let userVoteState: "none" | "up" | "down" = "none";

  // SVG icon strings for reuse in JS
  const ICONS = {
    heartOutline:
      '<svg class="qlike-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>',
    heartFilled:
      '<svg class="qlike-icon" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="color:#ef4444"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>',
    check:
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>',
    x: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>',
    info: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>',
  };

  function getMediaUrl(url: string | null | undefined): string {
    if (!url || url === "icon.png" || url === "null" || url === "")
      return "/assets/icon.png";
    if (url.startsWith("data:")) return url;
    if (url.startsWith("http://") || url.startsWith("https://")) return url;
    if (url.startsWith("iVBOR") || url.startsWith("/9j/"))
      return `data:image/png;base64,${url}`;
    return `/assets/${url}`;
  }

  function timeAgo(dateStr: string | null | undefined): string {
    if (!dateStr) return "Recently";
    try {
      const date = new Date(dateStr);
      const seconds = Math.floor(
        (new Date().getTime() - date.getTime()) / 1000,
      );
      if (seconds < 60) return "Just now";
      if (seconds < 3600) return Math.floor(seconds / 60) + "m ago";
      if (seconds < 86400) return Math.floor(seconds / 3600) + "h ago";
      if (seconds < 604800) return Math.floor(seconds / 86400) + "d ago";
      return date.toLocaleDateString();
    } catch (e) {
      return "Recently";
    }
  }

  // ===== TOAST =====
  function showToast(
    message: string,
    type: "success" | "error" | "info" = "info",
    duration = 2500,
  ) {
    const toast = document.getElementById("toast") as HTMLDivElement;
    const toastIcon = document.getElementById("toastIcon") as HTMLSpanElement;
    const toastMsg = document.getElementById("toastMsg") as HTMLSpanElement;

    toast.className = "qtoast " + type;
    toastMsg.textContent = message;

    if (type === "success") toastIcon.innerHTML = ICONS.check;
    else if (type === "error") toastIcon.innerHTML = ICONS.x;
    else toastIcon.innerHTML = ICONS.info;

    toast.classList.add("show");
    setTimeout(() => toast.classList.remove("show"), duration);
  }

  // ===== UPDATE VOTE UI =====
  function updateVoteUI(count: number) {
    (document.getElementById("voteCount") as HTMLElement).innerText =
      String(count);
    (document.getElementById("statVotes") as HTMLElement).innerText =
      String(count);
    (document.getElementById("sidebarVotes") as HTMLElement).innerText =
      String(count);

    const upBtn = document.querySelector(".upvote-btn") as HTMLButtonElement;
    const downBtn = document.querySelector(
      ".downvote-btn",
    ) as HTMLButtonElement;

    upBtn.classList.remove("active-up");
    downBtn.classList.remove("active-down");

    if (userVoteState === "up") upBtn.classList.add("active-up");
    if (userVoteState === "down") downBtn.classList.add("active-down");
  }

  // ===== LOAD QUESTION =====
  async function loadQuestion() {
    const qLoader = document.getElementById("qLoader") as HTMLDivElement;
    const qNotFound = document.getElementById("qNotFound") as HTMLDivElement;
    const qContent = document.getElementById("qContent") as HTMLDivElement;
    const sidebarLoader = document.getElementById(
      "sidebarLoader",
    ) as HTMLDivElement;
    const sidebarContent = document.getElementById(
      "sidebarContent",
    ) as HTMLDivElement;

    try {
      const res = await fetch(
        `${SCRIPT_URL}?action=getPostBySlug&slug=${slug}`,
      );
      const post = await res.json();

      if (!post) {
        qLoader.style.display = "none";
        sidebarLoader.style.display = "none";
        qNotFound.style.display = "block";
        return;
      }

      currentPost = post;
      qLoader.style.display = "none";
      sidebarLoader.style.display = "none";
      qContent.style.display = "block";
      sidebarContent.style.display = "block";

      document.title = `${post.heading} | Tech Engineer`;

      (document.getElementById("bc-title") as HTMLElement).innerText =
        post.heading;
      (document.getElementById("qTitle") as HTMLElement).innerText =
        post.heading;
      (document.getElementById("qAvatar") as HTMLImageElement).src =
        getMediaUrl(post.avatar);
      (document.getElementById("qAuthor") as HTMLElement).innerText =
        post.name || "Anonymous";
      (document.getElementById("qRole") as HTMLElement).innerText =
        post.role_name || "";
      (document.getElementById("qTime") as HTMLElement).innerText =
        post.updated_time || "";
      (document.getElementById("qDesc") as HTMLElement).innerHTML =
        post.description || "";

      const viewCount = Math.floor(Math.random() * 50) + 5;
      (document.getElementById("statViews") as HTMLElement).innerText =
        String(viewCount);

      updateVoteUI(post.upvotes || 0);

      (document.getElementById("statAnswers") as HTMLElement).innerText =
        String(post.comments || 0);
      (document.getElementById("answersCount") as HTMLElement).innerText =
        String(post.comments || 0);

      (document.getElementById("sidebarTime") as HTMLElement).innerText =
        post.updated_time || "Recently";
      (document.getElementById("sidebarAnswers") as HTMLElement).innerText =
        String(post.comments || 0);

      // Load existing vote state
      const voteKey = `vote_${post.id}`;
      const savedVote = localStorage.getItem(voteKey);
      if (savedVote === "up" || savedVote === "down") {
        userVoteState = savedVote as "up" | "down";
        updateVoteUI(post.upvotes || 0);
      }

      loadComments();
    } catch (err) {
      qLoader.style.display = "none";
      sidebarLoader.style.display = "none";
      qNotFound.style.display = "block";
    }
  }

  // ===== LOAD COMMENTS =====
  async function loadComments() {
    if (!currentPost) return;
    const container = document.getElementById(
      "commentsContainer",
    ) as HTMLDivElement;
    if (!container) return;

    try {
      const userEmail = localStorage.getItem("userId") || "";
      const res = await fetch(
        `${SCRIPT_URL}?action=getComments&postId=${currentPost.id}&userEmail=${encodeURIComponent(userEmail)}`,
      );
      const comments = await res.json();

      if (comments.length === 0) {
        container.innerHTML =
          '<div class="qempty-answers"><p>Be the first to answer this question!</p></div>';
        return;
      }

      container.innerHTML = "";

      comments.forEach((c: any) => {
        const div = document.createElement("div");
        div.className = "qcomment-item";
        const heartIcon = c.likedByUser
          ? ICONS.heartFilled
          : ICONS.heartOutline;
        const likedClass = c.likedByUser ? " liked" : "";
        div.innerHTML = `
          <img src="${getMediaUrl(c.userAvatar)}" class="qcomment-avatar" alt="${c.userName}" />
          <div class="qcomment-content">
            <span class="qcomment-name">${c.userName}</span><span class="qcomment-time">${timeAgo(c.timestamp)}</span>
            <p class="qcomment-text">${c.text || ""}</p>
            <div style="margin-top: 8px; display: flex; gap: 15px;">
               <button class="qlike-btn${likedClass}" data-id="${c.id}">${heartIcon} <span>${c.likes || 0}</span></button>
            </div>
          </div>
        `;
        container.appendChild(div);
      });

      // Like listeners
      container.querySelectorAll(".qlike-btn").forEach((btn) => {
        btn.addEventListener("click", async () => {
          if (!localStorage.getItem("userId"))
            return showToast("Please login to like answers", "info");
          const id = btn.getAttribute("data-id");
          try {
            const r = await fetch(SCRIPT_URL, {
              method: "POST",
              body: JSON.stringify({
                action: "toggleCommentLike",
                commentId: id,
                userEmail: localStorage.getItem("userId"),
              }),
            });
            const d = await r.json();
            if (d.status === "success") {
              const icon = d.liked ? ICONS.heartFilled : ICONS.heartOutline;
              btn.innerHTML = `${icon} <span>${d.likes}</span>`;
              if (d.liked) {
                btn.classList.add("liked");
              } else {
                btn.classList.remove("liked");
              }
              showToast(d.liked ? "Liked!" : "Like removed", "success");
            }
          } catch (e) {
            showToast("Error liking answer", "error");
          }
        });
      });
    } catch (err) {
      console.error("Error loading comments:", err);
    }
  }

  // ===== UPVOTE =====
  document.querySelector(".upvote-btn")?.addEventListener("click", async () => {
    if (!localStorage.getItem("userId"))
      return showToast("Please login to upvote", "info");
    if (!currentPost) return;

    if (userVoteState === "up") {
      userVoteState = "none";
      localStorage.removeItem(`vote_${currentPost.id}`);
      const count = Math.max(0, (currentPost.upvotes || 0) - 1);
      currentPost.upvotes = count;
      updateVoteUI(count);
      showToast("Vote removed", "info");
      return;
    }

    userVoteState = "up";
    localStorage.setItem(`vote_${currentPost.id}`, "up");

    const user = {
      email: localStorage.getItem("userId"),
      name: localStorage.getItem("currentUser"),
    };

    try {
      const res = await fetch(SCRIPT_URL, {
        method: "POST",
        body: JSON.stringify({
          action: "updateUpvote",
          postId: currentPost.id,
          increment: true,
          actorEmail: user.email,
          actorName: user.name,
        }),
      });
      const data = await res.json();
      if (data.status === "success") {
        currentPost.upvotes = data.newCount;
        updateVoteUI(data.newCount);
        showToast("Upvoted!", "success");
      }
    } catch (err) {
      showToast("Error upvoting", "error");
    }
  });

  // ===== DOWNVOTE =====
  document
    .querySelector(".downvote-btn")
    ?.addEventListener("click", async () => {
      if (!localStorage.getItem("userId"))
        return showToast("Please login to downvote", "info");
      if (!currentPost) return;

      if (userVoteState === "down") {
        userVoteState = "none";
        localStorage.removeItem(`vote_${currentPost.id}`);
        updateVoteUI(currentPost.upvotes || 0);
        showToast("Downvote removed", "info");
        return;
      }

      const wasUp = userVoteState === "up";
      userVoteState = "down";
      localStorage.setItem(`vote_${currentPost.id}`, "down");

      if (wasUp && currentPost.upvotes > 0) {
        currentPost.upvotes -= 1;
      }
      updateVoteUI(currentPost.upvotes || 0);
      showToast("Downvoted", "info");
    });

  // ===== ANSWER QUESTION BUTTON =====
  document
    .querySelector(".write-answer-main")
    ?.addEventListener("click", () => {
      const input = document.getElementById("answerInput") as HTMLInputElement;
      input.scrollIntoView({ behavior: "smooth", block: "center" });
      setTimeout(() => input.focus(), 400);
    });

  // ===== SHARE BUTTON =====
  document
    .querySelector(".share-btn-main")
    ?.addEventListener("click", async () => {
      const url = window.location.href;
      const title = currentPost?.heading || "Check out this question";

      if (navigator.share) {
        try {
          await navigator.share({ title, url });
          return;
        } catch (e) {
          // User cancelled or error — fallback to clipboard
        }
      }

      try {
        await navigator.clipboard.writeText(url);
        showToast("Link copied to clipboard!", "success");
      } catch (e) {
        const textarea = document.createElement("textarea");
        textarea.value = url;
        textarea.style.position = "fixed";
        textarea.style.opacity = "0";
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand("copy");
        document.body.removeChild(textarea);
        showToast("Link copied to clipboard!", "success");
      }
    });

  // ===== REPORT BUTTON =====
  const reportModal = document.getElementById("reportModal") as HTMLDivElement;
  const reportCancelBtn = document.getElementById(
    "reportCancelBtn",
  ) as HTMLButtonElement;
  const reportSubmitBtn = document.getElementById(
    "reportSubmitBtn",
  ) as HTMLButtonElement;

  document.querySelector(".report-btn-main")?.addEventListener("click", () => {
    reportModal.style.display = "flex";
  });

  reportCancelBtn?.addEventListener("click", () => {
    reportModal.style.display = "none";
  });

  reportModal?.addEventListener("click", (e) => {
    if (e.target === reportModal) {
      reportModal.style.display = "none";
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && reportModal.style.display === "flex") {
      reportModal.style.display = "none";
    }
  });

  reportSubmitBtn?.addEventListener("click", async () => {
    const selected = document.querySelector(
      'input[name="reportReason"]:checked',
    ) as HTMLInputElement;
    const details = (
      document.getElementById("reportDetails") as HTMLTextAreaElement
    ).value.trim();

    if (!selected) {
      showToast("Please select a reason", "error");
      return;
    }

    if (!localStorage.getItem("userId")) {
      showToast("Please login to report", "info");
      return;
    }

    reportSubmitBtn.disabled = true;
    reportSubmitBtn.innerText = "Submitting...";

    try {
      const res = await fetch(SCRIPT_URL, {
        method: "POST",
        body: JSON.stringify({
          action: "reportPost",
          postId: currentPost?.id,
          reason: selected.value,
          details: details,
          reporterEmail: localStorage.getItem("userId"),
          reporterName: localStorage.getItem("currentUser"),
        }),
      });
      const data = await res.json();
      if (data.status === "success") {
        showToast("Report submitted. Thank you!", "success");
        reportModal.style.display = "none";
        const checkedRadio = document.querySelector(
          'input[name="reportReason"]:checked',
        ) as HTMLInputElement;
        if (checkedRadio) checkedRadio.checked = false;
        (
          document.getElementById("reportDetails") as HTMLTextAreaElement
        ).value = "";
      } else {
        showToast("Could not submit report. Try again.", "error");
      }
    } catch (err) {
      showToast("Error submitting report", "error");
    } finally {
      reportSubmitBtn.disabled = false;
      reportSubmitBtn.innerText = "Submit Report";
    }
  });

  // ===== SUBMIT ANSWER =====
  document
    .getElementById("submitAnswerBtn")
    ?.addEventListener("click", async () => {
      const input = document.getElementById("answerInput") as HTMLInputElement;
      const text = input.value.trim();
      if (!text || !currentPost) return;
      if (!localStorage.getItem("userId"))
        return showToast("Please login to answer", "info");

      const submitBtn = document.getElementById(
        "submitAnswerBtn",
      ) as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.innerHTML = "Posting...";

      const user = {
        email: localStorage.getItem("userId"),
        name: localStorage.getItem("currentUser"),
        avatar: localStorage.getItem("userAvatar") || "/assets/icon.png",
      };

      try {
        await fetch(SCRIPT_URL, {
          method: "POST",
          body: JSON.stringify({
            action: "addComment",
            postId: currentPost.id,
            parentID: "",
            userEmail: user.email,
            userName: user.name,
            userAvatar: user.avatar,
            commentText: text,
          }),
        });
        input.value = "";
        showToast("Answer posted!", "success");
        loadComments();
      } catch (err) {
        showToast("Error posting answer", "error");
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = `<svg class="qbtn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Post`;
      }
    });

  // Submit answer on Enter key
  document.getElementById("answerInput")?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      document.getElementById("submitAnswerBtn")?.click();
    }
  });

  // ===== START =====
  loadQuestion();
</script>
