---
// src/pages/question/[slug].astro
import Layout from "../../layouts/Layout.astro";

const { slug } = Astro.params;
const SCRIPT_URL =
  "https://script.google.com/macros/s/AKfycbxlZOW0AuGlzMPuNZ5bGKYiK_DNZp8geGUwrYopvp-lezOxlIjb761sS7aDLPJlRrqDHg/exec";

interface Post {
  id: string;
  avatar: string;
  name: string;
  follow_enabled: boolean;
  role_name: string;
  updated_time: string;
  heading: string;
  description: string;
  images: string[];
  upvotes: number;
  comments: number;
  shares: number;
  slug: string;
  type: string;
  created_at: string;
}

let post: Post | null = null;
let relatedPosts: Post[] = [];

try {
  const response = await fetch(`${SCRIPT_URL}?action=getPosts`);
  const allPosts: Post[] = await response.json();
  post = allPosts.find((p: Post) => p.slug === slug) || null;

  if (post) {
    relatedPosts = allPosts
      .filter((p: Post) => p.id !== post!.id && p.name === post!.name)
      .slice(0, 3);
  }
} catch (error) {
  console.error("Error fetching post:", error);
}

if (!post) {
  return Astro.redirect("/404");
}

const safePost = post;

function getAvatarUrl(avatar: string | null | undefined): string {
  if (!avatar || avatar === "icon.png" || avatar === "null")
    return "/assets/icon.png";
  if (avatar.startsWith("http://") || avatar.startsWith("https://"))
    return avatar;
  if (avatar.includes("googleusercontent.com") || avatar.includes("github.com"))
    return avatar;
  return `/assets/${avatar}`;
}

const authorAvatar = getAvatarUrl(safePost.avatar);
const defaultAvatar = "/assets/icon.png";

function getValidDate(dateValue: any): Date {
  if (!dateValue) return new Date();
  if (typeof dateValue === "string") {
    const parsed = new Date(dateValue);
    if (isNaN(parsed.getTime())) return new Date();
    return parsed;
  }
  if (dateValue instanceof Date) {
    return isNaN(dateValue.getTime()) ? new Date() : dateValue;
  }
  return new Date();
}

const createdDate = getValidDate(safePost.created_at);
const updatedDate = getValidDate(safePost.updated_time);
const publishedDate = createdDate.toISOString();
const modifiedDate = updatedDate.toISOString();

const seoTitle = `${safePost.heading} | Tech Engineer`;
const seoDescription = safePost.description
  ? safePost.description.substring(0, 160)
  : `${safePost.heading} - Read answers and join the discussion on Tech Engineer`;
const seoImage =
  safePost.images && safePost.images[0]
    ? safePost.images[0].startsWith("http")
      ? safePost.images[0]
      : `${Astro.site}/assets/${safePost.images[0]}`
    : `${Astro.site}/assets/og-default.png`;
const canonicalURL = new URL(
  `/question/${safePost.slug}`,
  Astro.site,
).toString();

// Mock views for now
const viewCount = Math.floor(Math.random() * 50) + 5;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "QAPage",
  mainEntity: {
    "@type": "Question",
    name: safePost.heading,
    text: safePost.heading,
    answerCount: safePost.comments || 0,
    upvoteCount: safePost.upvotes || 0,
    dateCreated: publishedDate,
    author: {
      "@type": "Person",
      name: safePost.name,
      image: authorAvatar,
    },
  },
};
---

<Layout title={seoTitle} description={seoDescription} showFooter={true}>
  <div class="qpage">
    <!-- BREADCRUMB -->
    <nav class="qbreadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/">TechCast</a></li>
        <li><a href="/">Questions</a></li>
        <li class="active">{safePost.heading}</li>
      </ol>
    </nav>

    <div class="qlayout">
      <!-- MAIN CONTENT -->
      <main class="qmain">
        <!-- QUESTION CARD -->
        <article
          class="qcard"
          data-id={safePost.id}
          data-slug={safePost.slug}
          data-heading={safePost.heading}
        >
          <div class="qcard-top">
            <!-- VOTE COLUMN (LEFT) -->
            <div class="qvote-col">
              <button
                class="qvote-btn upvote-btn"
                type="button"
                aria-label="Upvote"
              >
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 19V5M5 12l7-7 7 7"></path>
                </svg>
              </button>
              <span
                class="qvote-count"
                data-count={String(safePost.upvotes || 0)}
                >{safePost.upvotes || 0}</span
              >
              <span class="qvote-label">Vote</span>
              <button
                class="qvote-btn downvote-btn"
                type="button"
                aria-label="Downvote"
              >
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 5v14M19 12l-7 7-7-7"></path>
                </svg>
              </button>
            </div>

            <!-- CONTENT COLUMN (RIGHT) -->
            <div class="qcontent-col">
              <h1 class="qtitle">{safePost.heading}</h1>

              <div class="qmeta-row">
                <img
                  src={authorAvatar}
                  alt={safePost.name}
                  class="qavatar"
                  onerror="this.onerror=null;this.src='/assets/icon.png';"
                />
                <div class="qmeta-info">
                  <a href={`/user?name=${safePost.name}`} class="qauthor-name"
                    >{safePost.name}</a
                  >
                  <div class="qauthor-sub">
                    <span>{safePost.role_name}</span>
                    <span class="dot">•</span>
                    <span>Asked {safePost.updated_time}</span>
                  </div>
                </div>
                <button
                  class="qmore-btn"
                  type="button"
                  aria-label="More options"
                >
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                  >
                    <circle cx="12" cy="5" r="1.5"></circle>
                    <circle cx="12" cy="12" r="1.5"></circle>
                    <circle cx="12" cy="19" r="1.5"></circle>
                  </svg>
                </button>
              </div>

              <p class="qdescription">{safePost.description}</p>

              {
                safePost.images && safePost.images.length > 0 && (
                  <div class="qimages">
                    {safePost.images.map((img: string) => {
                      const imgUrl = img.startsWith("http")
                        ? img
                        : `/assets/${img}`;
                      return (
                        <img
                          src={imgUrl}
                          alt={safePost.heading}
                          loading="lazy"
                          onerror="this.onerror=null;this.src='/assets/icon.png';"
                        />
                      );
                    })}
                  </div>
                )
              }
            </div>
          </div>

          <div class="qdivider"></div>

          <!-- STATS BAR -->
          <div class="qstats-bar">
            <span class="qstat-item"
              ><svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><path d="M7 11v4a1 1 0 0 0 1 1h2v3l4-3h4a1 1 0 0 0 1-1v-4"
                ></path><path d="M14 7V3l-4 3H6a1 1 0 0 0-1 1v4"></path></svg
              >
              {safePost.upvotes || 0} Vote{
                safePost.upvotes !== 1 ? "s" : ""
              }</span
            >
            <span class="qstat-item"
              ><svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><path
                  d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                ></path></svg
              >
              {safePost.comments || 0} Answer{
                safePost.comments !== 1 ? "s" : ""
              }</span
            >
            <span class="qstat-item"
              ><svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"
                ></path><circle cx="12" cy="12" r="3"></circle></svg
              >
              {viewCount} Views</span
            >
            <button class="qstat-item qstat-action save-btn" type="button">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"
                ></path></svg
              > Save
            </button>
            <button
              class="qstat-item qstat-action share-btn-stats"
              type="button"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><circle cx="18" cy="5" r="3"></circle><circle
                  cx="6"
                  cy="12"
                  r="3"></circle><circle cx="18" cy="19" r="3"></circle><line
                  x1="8.59"
                  y1="13.51"
                  x2="15.42"
                  y2="17.49"></line><line
                  x1="15.41"
                  y1="6.51"
                  x2="8.59"
                  y2="10.49"></line></svg
              > Share
            </button>
            <button class="qstat-item qstat-action report-btn" type="button">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><path
                  d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"
                ></path><line x1="4" y1="22" x2="4" y2="15"></line></svg
              > Report
            </button>
          </div>

          <!-- ACTION BUTTONS -->
          <div class="qaction-buttons">
            <button class="qbtn-primary write-answer-main" type="button">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><path d="M12 20h9"></path><path
                  d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"
                ></path></svg
              >
              Answer Question
            </button>
            <button class="qbtn-secondary save-btn-main" type="button">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"
                ></path></svg
              >
              Save
            </button>
            <button class="qbtn-secondary share-btn-main" type="button">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><circle cx="18" cy="5" r="3"></circle><circle
                  cx="6"
                  cy="12"
                  r="3"></circle><circle cx="18" cy="19" r="3"></circle><line
                  x1="8.59"
                  y1="13.51"
                  x2="15.42"
                  y2="17.49"></line><line
                  x1="15.41"
                  y1="6.51"
                  x2="8.59"
                  y2="10.49"></line></svg
              >
              Share
            </button>
            <button class="qbtn-secondary report-btn-main" type="button">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><path
                  d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"
                ></path><line x1="4" y1="22" x2="4" y2="15"></line></svg
              >
              Report
            </button>
          </div>
        </article>

        <!-- ANSWERS SECTION -->
        <section class="qanswers-section">
          <h2 class="qanswers-title">Answers ({safePost.comments || 0})</h2>

          <div id="commentsContainer" data-post-id={safePost.id}>
            <div class="qempty-answers">
              <div class="qempty-illustration">
                <svg
                  width="100"
                  height="100"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path
                    d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                  ></path>
                </svg>
                <div class="qempty-badge">?</div>
              </div>
              <h3 class="qempty-title">No answers yet</h3>
              <p class="qempty-text">
                Be the first to answer this question and help others.
              </p>
              <button class="qempty-cta write-answer-empty" type="button">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  ><path d="M12 20h9"></path><path
                    d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"
                  ></path></svg
                >
                Write an Answer
              </button>
            </div>
          </div>
        </section>
      </main>

      <!-- SIDEBAR -->
      <aside class="qsidebar">
        <div class="qsidebar-card">
          <h3 class="qsidebar-title">Question Stats</h3>
          <ul class="qstats-list">
            <li>
              <span class="qstat-icon"
                ><svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  ><circle cx="12" cy="12" r="10"></circle><polyline
                    points="12 6 12 12 16 14"></polyline></svg
                ></span
              >
              <span class="qstat-label">Asked</span>
              <span class="qstat-value">{safePost.updated_time}</span>
            </li>
            <li>
              <span class="qstat-icon"
                ><svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  ><path
                    d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"
                  ></path></svg
                ></span
              >
              <span class="qstat-label">Upvotes</span>
              <span class="qstat-value">{safePost.upvotes || 0}</span>
            </li>
            <li>
              <span class="qstat-icon"
                ><svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  ><path
                    d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                  ></path></svg
                ></span
              >
              <span class="qstat-label">Answers</span>
              <span class="qstat-value">{safePost.comments || 0}</span>
            </li>
            <li>
              <span class="qstat-icon"
                ><svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  ><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"
                  ></path><circle cx="12" cy="12" r="3"></circle></svg
                ></span
              >
              <span class="qstat-label">Views</span>
              <span class="qstat-value">{viewCount}</span>
            </li>
            <li>
              <span class="qstat-icon"
                ><svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  ><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"
                  ></polyline></svg
                ></span
              >
              <span class="qstat-label">Last activity</span>
              <span class="qstat-value">{safePost.updated_time}</span>
            </li>
          </ul>
        </div>

        {
          relatedPosts.length > 0 && (
            <div class="qsidebar-card">
              <h3 class="qsidebar-title">Related Questions</h3>
              <ul class="qrelated-list">
                {relatedPosts.map((related: Post) => (
                  <li>
                    <a href={`/question/${related.slug}`} class="qrelated-link">
                      {related.heading}
                    </a>
                    <span class="qrelated-meta">
                      {related.comments || 0} answer
                      {related.comments !== 1 ? "s" : ""}
                    </span>
                  </li>
                ))}
              </ul>
              <a href="/" class="qview-more">
                View more questions
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <>
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </>
                </svg>
              </a>
            </div>
          )
        }
      </aside>
    </div>
  </div>

  <!-- ANSWER INPUT MODAL -->
  <div id="answerModal" class="qanswer-modal hidden">
    <div class="qanswer-modal-content">
      <div class="qanswer-modal-header">
        <h3>Write Your Answer</h3>
        <button class="qclose-modal" type="button">&times;</button>
      </div>
      <textarea
        id="answerTextarea"
        placeholder="Share your knowledge and help others..."></textarea>
      <div class="qanswer-modal-footer">
        <button class="qbtn-secondary cancel-answer" type="button"
          >Cancel</button
        >
        <button class="qbtn-primary submit-answer" type="button" disabled
          >Post Answer</button
        >
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .qpage {
    max-width: 1180px;
    margin: 0 auto;
    padding: 20px 15px;
    background: #f9fafb;
    min-height: 100vh;
  }

  /* BREADCRUMB */
  .qbreadcrumb {
    padding: 12px 0;
    font-size: 13px;
  }
  .qbreadcrumb ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }
  .qbreadcrumb li {
    color: #636466;
    display: flex;
    align-items: center;
  }
  .qbreadcrumb li:not(:last-child)::after {
    content: "›";
    margin-left: 6px;
    color: #ccc;
  }
  .qbreadcrumb a {
    color: #2e69ff;
    text-decoration: none;
  }
  .qbreadcrumb a:hover {
    text-decoration: underline;
  }
  .qbreadcrumb li.active {
    color: #282829;
    max-width: 400px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .qlayout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 20px;
    margin-top: 8px;
  }

  @media (max-width: 900px) {
    .qlayout {
      grid-template-columns: 1fr;
    }
  }

  .qmain {
    min-width: 0;
  }

  /* QUESTION CARD */
  .qcard {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 20px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
  }

  .qcard-top {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 20px;
  }

  /* VOTE COLUMN */
  .qvote-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding-top: 4px;
  }
  .qvote-btn {
    background: transparent;
    border: 1px solid #e5e7eb;
    color: #6b7280;
    cursor: pointer;
    padding: 6px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
  }
  .qvote-btn:hover {
    background: #f3f4f6;
    border-color: #d1d5db;
  }
  .qvote-btn.upvote-btn.active {
    color: #2e69ff;
    background: #ebf0ff;
    border-color: #2e69ff;
  }
  .qvote-btn.downvote-btn.active {
    color: #cb2027;
    background: #fef2f2;
    border-color: #cb2027;
  }
  .qvote-count {
    font-size: 20px;
    font-weight: 800;
    color: #111827;
    margin-top: 4px;
  }
  .qvote-label {
    font-size: 11px;
    color: #6b7280;
    font-weight: 500;
    margin-bottom: 4px;
  }

  /* CONTENT COLUMN */
  .qcontent-col {
    min-width: 0;
  }
  .qtitle {
    font-size: 22px;
    font-weight: 800;
    margin: 0 0 16px 0;
    line-height: 1.35;
    color: #111827;
  }
  .qmeta-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }
  .qavatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    background: #f1f2f2;
    flex-shrink: 0;
  }
  .qmeta-info {
    flex: 1;
    min-width: 0;
  }
  .qauthor-name {
    font-weight: 700;
    font-size: 14px;
    color: #2e69ff;
    text-decoration: none;
    display: block;
  }
  .qauthor-name:hover {
    text-decoration: underline;
  }
  .qauthor-sub {
    font-size: 12px;
    color: #6b7280;
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 2px;
  }
  .dot {
    opacity: 0.6;
  }
  .qmore-btn {
    background: transparent;
    border: none;
    color: #6b7280;
    cursor: pointer;
    padding: 6px;
    border-radius: 50%;
    display: flex;
  }
  .qmore-btn:hover {
    background: #f3f4f6;
  }
  .qdescription {
    font-size: 14px;
    line-height: 1.7;
    color: #374151;
    margin: 0 0 12px 0;
  }
  .qimages {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 8px;
    margin: 12px 0;
  }
  .qimages img {
    width: 100%;
    border-radius: 6px;
  }

  .qdivider {
    height: 1px;
    background: #f3f4f6;
    margin: 16px -20px 16px -20px;
  }

  /* STATS BAR */
  .qstats-bar {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    padding: 0 0 16px 0;
  }
  .qstat-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
