    color: #111827;
  }
  .qstats-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .qstats-list li {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid #f3f4f6;
