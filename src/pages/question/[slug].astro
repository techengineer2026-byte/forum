<script>
  const SCRIPT_URL =
    "https://script.google.com/macros/s/AKfycbwS4kLCU7sm9LX0sGrBC4f8LNAuSyGwjaSS6fEJq3jbwQapxoVnX6Qs2VXQO2ePecs8rA/exec";
  const pathParts = window.location.pathname.split("/");
  const slug =
    pathParts[pathParts.length - 1] || pathParts[pathParts.length - 2];
  // ===== Read post data from server-rendered card =====
  const qCard = document.getElementById("qCard") as HTMLElement;
  const postId = qCard?.getAttribute("data-id") || "";
  let currentUpvotes = parseInt(qCard?.getAttribute("data-upvotes") || "0");
  let userVoteState: "none" | "up" | "down" = "none";

  const ICONS = {
    heartOutline:
      '<svg class="qlike-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>',
    heartFilled:
      '<svg class="qlike-icon" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="color:#ef4444"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>',
    check:
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>',
    x: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>',
    info: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>',
  };

  function getMediaUrl(url: string | null | undefined): string {
    if (!url || url === "icon.png" || url === "null" || url === "")
      return "/assets/icon.png";
    if (url.startsWith("data:")) return url;
    if (url.startsWith("http://") || url.startsWith("https://")) return url;
    if (url.startsWith("iVBOR") || url.startsWith("/9j/"))
      return `data:image/png;base64,${url}`;
    return `/assets/${url}`;
  }

  function timeAgo(dateStr: string | null | undefined): string {
    if (!dateStr) return "Recently";
    try {
      const date = new Date(dateStr);
      const seconds = Math.floor(
        (new Date().getTime() - date.getTime()) / 1000,
      );
      if (seconds < 60) return "Just now";
      if (seconds < 3600) return Math.floor(seconds / 60) + "m ago";
      if (seconds < 86400) return Math.floor(seconds / 3600) + "h ago";
      if (seconds < 604800) return Math.floor(seconds / 86400) + "d ago";
      return date.toLocaleDateString();
    } catch (e) {
      return "Recently";
    }
  }

  // ===== TOAST =====
  function showToast(
    message: string,
    type: "success" | "error" | "info" = "info",
    duration = 2500,
  ) {
    const toast = document.getElementById("toast") as HTMLDivElement;
    const toastIcon = document.getElementById("toastIcon") as HTMLSpanElement;
    const toastMsg = document.getElementById("toastMsg") as HTMLSpanElement;
    toast.className = "qtoast " + type;
    toastMsg.textContent = message;
    if (type === "success") toastIcon.innerHTML = ICONS.check;
    else if (type === "error") toastIcon.innerHTML = ICONS.x;
    else toastIcon.innerHTML = ICONS.info;
    toast.classList.add("show");
    setTimeout(() => toast.classList.remove("show"), duration);
  }

  // ===== UPDATE VOTE UI =====
  function updateVoteUI(count: number) {
    (document.getElementById("voteCount") as HTMLElement).innerText =
      String(count);
    (document.getElementById("statVotes") as HTMLElement).innerText =
      String(count);
    (document.getElementById("sidebarVotes") as HTMLElement).innerText =
      String(count);
    const upBtn = document.querySelector(".upvote-btn") as HTMLButtonElement;
    const downBtn = document.querySelector(
      ".downvote-btn",
    ) as HTMLButtonElement;
    upBtn.classList.remove("active-up");
    downBtn.classList.remove("active-down");
    if (userVoteState === "up") upBtn.classList.add("active-up");
    if (userVoteState === "down") downBtn.classList.add("active-down");
  }

  // ===== INIT VOTE STATE FROM LOCAL STORAGE =====
  if (postId) {
    const voteKey = `vote_${postId}`;
    const savedVote = localStorage.getItem(voteKey);
    if (savedVote === "up" || savedVote === "down") {
      userVoteState = savedVote as "up" | "down";
      updateVoteUI(currentUpvotes);
    }

    // Random view count (same as before)
    const viewCount = Math.floor(Math.random() * 50) + 5;
    (document.getElementById("statViews") as HTMLElement).innerText =
      String(viewCount);
  }
  // ===== HYDRATE BASE64 IMAGES (stripped from props to avoid 431) =====
  // ===== HYDRATE BASE64 IMAGES (stripped from props to avoid 431) =====
  async function hydrateBase64Images() {
    try {
      const res = await fetch(
        `${SCRIPT_URL}?action=getPostBySlug&slug=${slug}`,
      );
      const fullPost = await res.json();
      if (!fullPost) return;

      // Restore base64 avatar
      if (
        fullPost.avatar &&
        typeof fullPost.avatar === "string" &&
        (fullPost.avatar.startsWith("iVBOR") ||
          fullPost.avatar.startsWith("/9j/"))
      ) {
        const letterAvatar = document.querySelector(".letter-avatar");
        if (letterAvatar) {
          const img = document.createElement("img");
          img.src = getMediaUrl(fullPost.avatar);
          img.alt = fullPost.name || "User";
          img.className = "qavatar";
          img.width = 36;
          img.height = 36;
          img.style.borderRadius = "50%";
          letterAvatar.replaceWith(img);
        }
      }

      // Parse ALL images from the full post
      let imgs: any = fullPost.images || [];
      if (typeof imgs === "string") {
        try {
          imgs = JSON.parse(imgs);
        } catch {
          imgs = imgs.split(",").filter((i: string) => i.trim() !== "");
        }
      }

      // Collect ALL valid images (URLs + base64), skip garbage
      const allValidImages = [...new Set(imgs as any[])].filter(
        (img: any) =>
          img &&
          img !== "null" &&
          img !== "undefined" &&
          typeof img === "string" &&
          img.length > 10 &&
          (img.startsWith("http://") ||
            img.startsWith("https://") ||
            img.startsWith("iVBOR") ||
            img.startsWith("/9j/") ||
            img.startsWith("UklG") ||
            img.startsWith("PHN2Zy")),
      ) as string[];

      if (allValidImages.length > 0) {
        const descEl = document.querySelector(".qdescription");
        const existingGrid = document.querySelector(".qimages-grid");

        // Remove the old grid (might have broken images from server render)
        if (existingGrid) {
          existingGrid.remove();
        }

        // Build a fresh grid with ALL valid images
        if (descEl) {
          const grid = document.createElement("div");
          const gridCount = Math.min(allValidImages.length, 4);
          grid.className = `qimages-grid grid-${gridCount}`;

          allValidImages.slice(0, 4).forEach((img: string, index: number) => {
            const imgUrl = getMediaUrl(img);
            const item = document.createElement("div");
            item.className = "grid-item";
            if (index === 3 && allValidImages.length > 4) {
              item.classList.add("with-overlay");
              item.innerHTML = `<img src="${imgUrl}" alt="" onerror="this.parentElement.style.display='none'" /><div class="more-count">+${allValidImages.length - 3}</div>`;
            } else {
              item.innerHTML = `<img src="${imgUrl}" alt="" onerror="this.parentElement.style.display='none'" />`;
            }
            grid.appendChild(item);
          });

          descEl.after(grid);
        }
      }
    } catch (err) {
      console.error("Error hydrating images:", err);
    }
  }
  // ===== LOAD COMMENTS =====
  async function loadComments() {
    if (!postId) return;
    const container = document.getElementById(
      "commentsContainer",
    ) as HTMLDivElement;
    if (!container) return;

    try {
      const userEmail = localStorage.getItem("userId") || "";
      const res = await fetch(
        `${SCRIPT_URL}?action=getComments&postId=${postId}&userEmail=${encodeURIComponent(userEmail)}`,
      );
      const comments = await res.json();

      if (comments.length === 0) {
        container.innerHTML =
          '<div class="qempty-answers"><p>Be the first to answer this question!</p></div>';
        return;
      }

      container.innerHTML = "";

      comments.forEach((c: any) => {
        const div = document.createElement("div");
        div.className = "qcomment-item";
        const heartIcon = c.likedByUser
          ? ICONS.heartFilled
          : ICONS.heartOutline;
        const likedClass = c.likedByUser ? " liked" : "";
        div.innerHTML = `
          <img src="${getMediaUrl(c.userAvatar)}" class="qcomment-avatar" alt="${c.userName}" />
          <div class="qcomment-content">
            <span class="qcomment-name">${c.userName}</span><span class="qcomment-time">${timeAgo(c.timestamp)}</span>
            <p class="qcomment-text">${c.text || ""}</p>
            <div style="margin-top: 8px; display: flex; gap: 15px;">
               <button class="qlike-btn${likedClass}" data-id="${c.id}">${heartIcon} <span>${c.likes || 0}</span></button>
            </div>
          </div>
        `;
        container.appendChild(div);
      });

      container.querySelectorAll(".qlike-btn").forEach((btn) => {
        btn.addEventListener("click", async () => {
          if (!localStorage.getItem("userId"))
            return showToast("Please login to like answers", "info");
          const id = btn.getAttribute("data-id");
          try {
            const r = await fetch(SCRIPT_URL, {
              method: "POST",
              body: JSON.stringify({
                action: "toggleCommentLike",
                commentId: id,
                userEmail: localStorage.getItem("userId"),
              }),
            });
            const d = await r.json();
            if (d.status === "success") {
              const icon = d.liked ? ICONS.heartFilled : ICONS.heartOutline;
              btn.innerHTML = `${icon} <span>${d.likes}</span>`;
              if (d.liked) btn.classList.add("liked");
              else btn.classList.remove("liked");
              showToast(d.liked ? "Liked!" : "Like removed", "success");
            }
          } catch (e) {
            showToast("Error liking answer", "error");
          }
        });
      });
    } catch (err) {
      console.error("Error loading comments:", err);
    }
  }

  // ===== UPVOTE =====
  document.querySelector(".upvote-btn")?.addEventListener("click", async () => {
    if (!localStorage.getItem("userId"))
      return showToast("Please login to upvote", "info");
    if (!postId) return;

    if (userVoteState === "up") {
      userVoteState = "none";
      localStorage.removeItem(`vote_${postId}`);
      currentUpvotes = Math.max(0, currentUpvotes - 1);
      updateVoteUI(currentUpvotes);
      showToast("Vote removed", "info");
      return;
    }

    userVoteState = "up";
    localStorage.setItem(`vote_${postId}`, "up");

    const user = {
      email: localStorage.getItem("userId"),
      name: localStorage.getItem("currentUser"),
    };

    try {
      const res = await fetch(SCRIPT_URL, {
        method: "POST",
        body: JSON.stringify({
          action: "updateUpvote",
          postId,
          increment: true,
          actorEmail: user.email,
          actorName: user.name,
        }),
      });
      const data = await res.json();
      if (data.status === "success") {
        currentUpvotes = data.newCount;
        updateVoteUI(data.newCount);
        showToast("Upvoted!", "success");
      }
    } catch (err) {
      showToast("Error upvoting", "error");
    }
  });

  // ===== DOWNVOTE =====
  document
    .querySelector(".downvote-btn")
    ?.addEventListener("click", async () => {
      if (!localStorage.getItem("userId"))
        return showToast("Please login to downvote", "info");
      if (!postId) return;

      if (userVoteState === "down") {
        userVoteState = "none";
        localStorage.removeItem(`vote_${postId}`);
        updateVoteUI(currentUpvotes);
        showToast("Downvote removed", "info");
        return;
      }

      const wasUp = userVoteState === "up";
      userVoteState = "down";
      localStorage.setItem(`vote_${postId}`, "down");

      if (wasUp && currentUpvotes > 0) {
        currentUpvotes -= 1;
      }
      updateVoteUI(currentUpvotes);
      showToast("Downvoted", "info");
    });

  // ===== ANSWER QUESTION BUTTON =====
  document
    .querySelector(".write-answer-main")
    ?.addEventListener("click", () => {
      const input = document.getElementById("answerInput") as HTMLInputElement;
      input.scrollIntoView({ behavior: "smooth", block: "center" });
      setTimeout(() => input.focus(), 400);
    });

  // ===== SHARE BUTTON =====
  document
    .querySelector(".share-btn-main")
    ?.addEventListener("click", async () => {
      const url = window.location.href;
      const title =
        document.querySelector(".qtitle")?.textContent ||
        "Check out this question";

      if (navigator.share) {
        try {
          await navigator.share({ title, url });
          return;
        } catch (e) {
          /* fallback to clipboard */
        }
      }

      try {
        await navigator.clipboard.writeText(url);
        showToast("Link copied to clipboard!", "success");
      } catch (e) {
        const textarea = document.createElement("textarea");
        textarea.value = url;
        textarea.style.position = "fixed";
        textarea.style.opacity = "0";
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand("copy");
        document.body.removeChild(textarea);
        showToast("Link copied to clipboard!", "success");
      }
    });

  // ===== REPORT BUTTON =====
  const reportModal = document.getElementById("reportModal") as HTMLDivElement;
  const reportCancelBtn = document.getElementById(
    "reportCancelBtn",
  ) as HTMLButtonElement;
  const reportSubmitBtn = document.getElementById(
    "reportSubmitBtn",
  ) as HTMLButtonElement;

  document.querySelector(".report-btn-main")?.addEventListener("click", () => {
    reportModal.style.display = "flex";
  });

  reportCancelBtn?.addEventListener("click", () => {
    reportModal.style.display = "none";
  });

  reportModal?.addEventListener("click", (e) => {
    if (e.target === reportModal) reportModal.style.display = "none";
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && reportModal.style.display === "flex") {
      reportModal.style.display = "none";
    }
  });

  reportSubmitBtn?.addEventListener("click", async () => {
    const selected = document.querySelector(
      'input[name="reportReason"]:checked',
    ) as HTMLInputElement;
    const details = (
      document.getElementById("reportDetails") as HTMLTextAreaElement
    ).value.trim();

    if (!selected) {
      showToast("Please select a reason", "error");
      return;
    }
    if (!localStorage.getItem("userId")) {
      showToast("Please login to report", "info");
      return;
    }

    reportSubmitBtn.disabled = true;
    reportSubmitBtn.innerText = "Submitting...";

    try {
      const res = await fetch(SCRIPT_URL, {
        method: "POST",
        body: JSON.stringify({
          action: "reportPost",
          postId,
          reason: selected.value,
          details,
          reporterEmail: localStorage.getItem("userId"),
          reporterName: localStorage.getItem("currentUser"),
        }),
      });
      const data = await res.json();
      if (data.status === "success") {
        showToast("Report submitted. Thank you!", "success");
        reportModal.style.display = "none";
        const checkedRadio = document.querySelector(
          'input[name="reportReason"]:checked',
        ) as HTMLInputElement;
        if (checkedRadio) checkedRadio.checked = false;
        (
          document.getElementById("reportDetails") as HTMLTextAreaElement
        ).value = "";
      } else {
        showToast("Could not submit report. Try again.", "error");
      }
    } catch (err) {
      showToast("Error submitting report", "error");
    } finally {
      reportSubmitBtn.disabled = false;
      reportSubmitBtn.innerText = "Submit Report";
    }
  });

  // ===== SUBMIT ANSWER =====
  document
    .getElementById("submitAnswerBtn")
    ?.addEventListener("click", async () => {
      const input = document.getElementById("answerInput") as HTMLInputElement;
      const text = input.value.trim();
      if (!text || !postId) return;
      if (!localStorage.getItem("userId"))
        return showToast("Please login to answer", "info");

      const submitBtn = document.getElementById(
        "submitAnswerBtn",
      ) as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.innerHTML = "Posting...";

      const user = {
        email: localStorage.getItem("userId"),
        name: localStorage.getItem("currentUser"),
        avatar: localStorage.getItem("userAvatar") || "/assets/icon.png",
      };

      try {
        await fetch(SCRIPT_URL, {
          method: "POST",
          body: JSON.stringify({
            action: "addComment",
            postId,
            parentID: "",
            userEmail: user.email,
            userName: user.name,
            userAvatar: user.avatar,
            commentText: text,
          }),
        });
        input.value = "";
        showToast("Answer posted!", "success");
        loadComments();
      } catch (err) {
        showToast("Error posting answer", "error");
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = `<svg class="qbtn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Post`;
      }
    });

  document.getElementById("answerInput")?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") document.getElementById("submitAnswerBtn")?.click();
  });
  // ===== GUEST LOGIN PROMPT FOR ANSWER INPUT =====
  const addAnswerDiv = document.querySelector(".qadd-answer") as HTMLElement;
  if (addAnswerDiv && !localStorage.getItem("userId")) {
    addAnswerDiv.innerHTML = `
      <input type="text" id="answerInput" placeholder="Write an answer..." disabled style="flex:1;padding:10px 14px;border:1px solid #d1d5db;border-radius:6px;font-size:14px;outline:none;background:#f9fafb;color:#9ca3af;" />
      <button class="qbtn-primary" type="button" id="guestAnswerLogin" style="opacity:1;">
        <svg class="qbtn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        Login to Answer
      </button>
    `;
    document
      .getElementById("guestAnswerLogin")
      ?.addEventListener("click", () => {
        const loginModal = document.getElementById("loginModal");
        if (loginModal) loginModal.classList.add("active");
        else window.dispatchEvent(new CustomEvent("show-login-modal"));
      });
  }

  // ===== START =====
  // ===== SHOW DELETE BUTTON IF USER IS AUTHOR =====
  if (postId) {
    const authorName =
      document.querySelector(".qauthor-name")?.textContent || "";
    const currentUser = localStorage.getItem("currentUser") || "";
    const deleteBtn = document.getElementById(
      "deletePostBtn",
    ) as HTMLButtonElement;

    // Check if logged in user is the post author
    if (currentUser && authorName && currentUser === authorName && deleteBtn) {
      deleteBtn.style.display = "inline-flex";
    }

    // ===== DELETE POST CLICK HANDLER =====
    deleteBtn?.addEventListener("click", async () => {
      if (!localStorage.getItem("userId")) {
        showToast("Please login to delete", "info");
        return;
      }

      if (
        !confirm(
          "Are you sure you want to delete this post? This cannot be undone.",
        )
      )
        return;

      deleteBtn.disabled = true;
      deleteBtn.innerText = "Deleting...";

      try {
        const res = await fetch(SCRIPT_URL, {
          method: "POST",
          body: JSON.stringify({
            action: "deletePost",
            postId,
          }),
        });
        const data = await res.json();
        if (data.status === "success") {
          showToast("Post deleted! Redirecting...", "success");
          setTimeout(() => {
            window.location.href = "/"; // Go back to homepage
          }, 1500);
        } else {
          showToast("Could not delete post", "error");
          deleteBtn.disabled = false;
          deleteBtn.innerHTML = `<svg class="qbtn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg> Delete`;
        }
      } catch (err) {
        showToast("Error deleting post", "error");
        deleteBtn.disabled = false;
        deleteBtn.innerHTML = `<svg class="qbtn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg> Delete`;
      }
    });
  }
  // ===== IMAGE LIGHTBOX =====
  const lightbox = document.getElementById("imageLightbox") as HTMLDivElement;
  const lightboxImg = document.getElementById(
    "lightboxImg",
  ) as HTMLImageElement;
  const lightboxClose = document.getElementById(
    "lightboxClose",
  ) as HTMLButtonElement;
  const lightboxCounter = document.getElementById(
    "lightboxCounter",
  ) as HTMLDivElement;
  const lightboxPrev = document.getElementById(
    "lightboxPrev",
  ) as HTMLButtonElement;
  const lightboxNext = document.getElementById(
    "lightboxNext",
  ) as HTMLButtonElement;
  let lightboxImages: string[] = [];
  let lightboxIndex = 0;

  function openLightbox(images: string[], startIndex: number) {
    lightboxImages = images;
    lightboxIndex = startIndex;
    updateLightbox();
    lightbox.classList.add("active");
    document.body.style.overflow = "hidden";
  }

  function closeLightbox() {
    lightbox.classList.remove("active");
    document.body.style.overflow = "";
  }

  function updateLightbox() {
    if (lightboxImages.length === 0) return;
    lightboxImg.src = getMediaUrl(lightboxImages[lightboxIndex]);
    if (lightboxImages.length > 1) {
      lightboxCounter.textContent = `${lightboxIndex + 1} / ${lightboxImages.length}`;
      lightboxCounter.style.display = "block";
      lightboxPrev.classList.toggle("hidden-nav", lightboxIndex === 0);
      lightboxNext.classList.toggle(
        "hidden-nav",
        lightboxIndex === lightboxImages.length - 1,
      );
    } else {
      lightboxCounter.style.display = "none";
      lightboxPrev.classList.add("hidden-nav");
      lightboxNext.classList.add("hidden-nav");
    }
  }

  lightboxClose?.addEventListener("click", (e) => {
    e.stopPropagation();
    closeLightbox();
  });

  lightbox?.addEventListener("click", (e) => {
    if (
      e.target === lightbox ||
      e.target === document.querySelector(".lightbox-content")
    ) {
      closeLightbox();
    }
  });

  lightboxPrev?.addEventListener("click", (e) => {
    e.stopPropagation();
    if (lightboxIndex > 0) {
      lightboxIndex--;
      updateLightbox();
    }
  });

  lightboxNext?.addEventListener("click", (e) => {
    e.stopPropagation();
    if (lightboxIndex < lightboxImages.length - 1) {
      lightboxIndex++;
      updateLightbox();
    }
  });

  document.addEventListener("keydown", (e) => {
    if (!lightbox.classList.contains("active")) return;
    if (e.key === "Escape") closeLightbox();
    if (e.key === "ArrowLeft" && lightboxIndex > 0) {
      lightboxIndex--;
      updateLightbox();
    }
    if (e.key === "ArrowRight" && lightboxIndex < lightboxImages.length - 1) {
      lightboxIndex++;
      updateLightbox();
    }
  });

  // Attach click handlers to grid images
  function attachLightboxToGrid() {
    document
      .querySelectorAll(
        ".qimages-grid .grid-item img, .post-images-grid .grid-item img",
      )
      .forEach((img) => {
        img.removeEventListener("click", handleImageClick);
        img.addEventListener("click", handleImageClick);
      });
  }

  function handleImageClick(e: Event) {
    const clickedImg = e.target as HTMLImageElement;
    const grid = clickedImg.closest(".qimages-grid, .post-images-grid");
    if (!grid) return;

    const allImgs = Array.from(grid.querySelectorAll(".grid-item img"))
      .map((img) => (img as HTMLImageElement).src)
      .filter((src) => src && !src.endsWith("/assets/icon.png"));

    if (allImgs.length === 0) return;

    const clickedSrc = clickedImg.src;
    const index = allImgs.indexOf(clickedSrc);
    openLightbox(allImgs, index >= 0 ? index : 0);
  }

  // Run on initial load + after hydrateBase64Images
  attachLightboxToGrid();

  // Also attach after base64 images load
  const origHydrate = hydrateBase64Images;
  // We'll use a MutationObserver to detect when new images are added
  const gridObserver = new MutationObserver(() => {
    attachLightboxToGrid();
  });
  const descEl = document.querySelector(".qdescription");
  if (descEl) {
    gridObserver.observe(descEl.parentElement!, {
      childList: true,
      subtree: true,
    });
  }
  hydrateBase64Images();
  loadComments();
</script>
