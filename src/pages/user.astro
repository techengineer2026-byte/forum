---
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/Sidebar.astro";

const name = Astro.url.searchParams.get("name") || "Guest";
---

<Layout title={`${name}'s Profile - TechEngineer`}>
  <div class="profile-page-layout">
    <aside class="sidebar-area">
      <Sidebar />
    </aside>

    <main class="profile-main">
      <!-- PROFILE HEADER (Modern Cover + Overlap) -->
      <div class="profile-card">
        <div class="profile-cover"></div>
        
        <div class="profile-avatar-wrap">
          <div class="profile-avatar-letter" id="profileAvatarLetter">
            {name?.charAt(0).toUpperCase()}
          </div>
          <img id="profileAvatarImg" class="profile-avatar-img" style="display:none" alt={name} />
        </div>

        <div class="profile-info-area">
          <h1 class="profile-name">{name}</h1>
          <span id="profileUsername" class="profile-username">@username</span>
          <span id="profileRole" class="profile-role-badge">Member</span>

          <p id="profileBio" class="profile-bio empty">This user hasn't written a bio yet.</p>

          <div class="profile-details-grid">
            <div class="detail-item" id="detailCollege" style="display:none">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
              <span id="collegeText"></span>
            </div>
            <div class="detail-item" id="detailCourse" style="display:none">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
              <span id="courseText"></span>
            </div>
            <div class="detail-item" id="detailLocation" style="display:none">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span id="locationText"></span>
            </div>
          </div>

          <div class="profile-links" id="pLinks"></div>
          
          <div class="profile-interests-section">
            <div id="pInterests" class="interests-container">
              <span class="interest-chip empty">No interests listed</span>
            </div>
          </div>
        </div>
      </div>

      <!-- STATS BAR -->
      <div class="profile-stats-bar">
        <div class="pstat">
          <svg class="pstat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
          <span id="questionCount">0</span> Questions
        </div>
        <div class="pstat">
          <svg class="pstat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
          <span id="postCount">0</span> Posts
        </div>
        <div class="pstat">
          <svg class="pstat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 19V5M5 12l7-7 7 7"></path></svg>
          <span id="totalUpvotes">0</span> Upvotes
        </div>
      </div>

      <!-- TABS -->
      <div class="tabs">
        <button class="tab active" id="tab-questions">
          <svg class="tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
          Questions
        </button>
        <button class="tab" id="tab-posts">
          <svg class="tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
          Posts
        </button>
      </div>

      <!-- ACTIVITY FEED -->
      <div id="activity-feed" class="activity-feed">
        <div class="skel-activity">
          <div class="skel skel-badge"></div>
          <div class="skel skel-heading"></div>
          <div class="skel skel-line"></div>
          <div class="skel skel-meta"></div>
        </div>
        <div class="skel-activity">
          <div class="skel skel-badge" style="width:40px"></div>
          <div class="skel skel-heading" style="width:65%"></div>
          <div class="skel skel-line" style="width:90%"></div>
          <div class="skel skel-meta" style="width:40%"></div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style is:global>
  /* ===== SKELETON ===== */
  .skel { background: linear-gradient(90deg, #e5e7eb 25%, #f3f4f6 50%, #e5e7eb 75%); background-size: 200% 100%; animation: skelPulse 1.5s ease-in-out infinite; border-radius: 4px; }
  @keyframes skelPulse { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
  .skel-activity { padding: 16px 8px; border-bottom: 1px solid #f5f5f5; }
  .skel-badge { width: 55px; height: 20px; margin-bottom: 10px; }
  .skel-heading { width: 80%; height: 18px; margin-bottom: 8px; }
  .skel-line { width: 100%; height: 13px; margin-bottom: 8px; }
  .skel-meta { width: 45%; height: 12px; }

  /* ===== LAYOUT ===== */
  .profile-page-layout { display: flex; justify-content: center; gap: 24px; padding: 20px; background-color: #f1f2f2; min-height: 100vh; align-items: flex-start; }
  .sidebar-area { width: 160px; position: sticky; top: 80px; height: fit-content; }
  .profile-main { width: 620px; max-width: 100%; }

  /* ===== PROFILE CARD ===== */
  .profile-card { background: white; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); overflow: hidden; position: relative; margin-bottom: 16px; }
  .profile-cover { height: 120px; background: linear-gradient(135deg, #2e69ff 0%, #1a4a7c 100%); }
  .profile-avatar-wrap { position: absolute; top: 60px; left: 24px; }
  .profile-avatar-letter { width: 110px; height: 110px; border-radius: 50%; background: linear-gradient(135deg, #b92b27, #d94440); color: white; display: flex; align-items: center; justify-content: center; font-size: 42px; font-weight: 800; border: 4px solid white; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
  .profile-avatar-img { width: 110px; height: 110px; border-radius: 50%; object-fit: cover; border: 4px solid white; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
  
  .profile-info-area { padding: 70px 24px 24px; }
  .profile-name { font-size: 26px; font-weight: 800; color: #111827; margin: 0; }
  .profile-username { font-size: 14px; color: #6b7280; display: block; margin-top: 2px; }
  .profile-role-badge { display: inline-block; margin-top: 8px; padding: 4px 14px; background: #eef3ff; color: #2e69ff; border-radius: 999px; font-weight: 600; font-size: 13px; }
  
  .profile-bio { margin-top: 12px; font-size: 15px; line-height: 1.6; color: #374151; }
  .profile-bio.empty { color: #9ca3af; font-style: italic; }

  .profile-details-grid { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 16px; }
  .detail-item { display: flex; align-items: center; gap: 6px; font-size: 14px; color: #6b7280; }
  .detail-item svg { color: #9ca3af; flex-shrink: 0; }

  .profile-links { display: flex; gap: 10px; margin-top: 16px; }
  .social-link { display: inline-flex; align-items: center; gap: 6px; padding: 5px 12px; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 12px; font-weight: 500; text-decoration: none; color: #374151; transition: all 0.2s; }
  .social-link:hover { border-color: #2e69ff; color: #2e69ff; }

  .profile-interests-section { margin-top: 20px; border-top: 1px solid #f3f4f6; padding-top: 16px; }
  .interests-container { display: flex; flex-wrap: wrap; gap: 8px; }
  .interest-chip { padding: 6px 16px; background: #f3f4f6; color: #374151; border-radius: 999px; font-size: 13px; font-weight: 500; }
  .interest-chip.empty { color: #9ca3af; font-style: italic; background: transparent; padding: 0; }

  /* ===== STATS BAR ===== */
  .profile-stats-bar { background: #ffffff; border: 1px solid #e3e6ea; border-radius: 12px; padding: 16px 20px; display: flex; gap: 24px; margin-bottom: 12px; }
  .pstat { display: flex; align-items: center; gap: 6px; font-size: 14px; font-weight: 600; color: #374151; }
  .pstat-icon { width: 18px; height: 18px; color: #6b7280; }
  .pstat span { color: #111827; font-weight: 800; }

  /* ===== TABS ===== */
  .tabs { display: flex; background: #ffffff; border: 1px solid #e3e6ea; border-radius: 12px 12px 0 0; border-bottom: none; }
  .tab { flex: 1; padding: 14px; background: none; border: none; font-weight: 700; font-size: 14px; color: #6b7280; cursor: pointer; border-bottom: 3px solid transparent; transition: color 0.2s, border-color 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; }
  .tab:hover { color: #111827; }
  .tab.active { color: #2e69ff; border-bottom-color: #2e69ff; }
  .tab-icon { width: 16px; height: 16px; }

  /* ===== ACTIVITY FEED ===== */
  .activity-feed { background: #ffffff; border: 1px solid #e3e6ea; border-radius: 0 0 12px 12px; padding: 4px 12px; min-height: 200px; }
  .activity-item { padding: 16px 8px; border-bottom: 1px solid #f3f4f6; transition: background 0.15s; }
  .activity-item:last-child { border-bottom: none; }
  .activity-item:hover { background: #fafbfc; }
  .activity-item-top { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
  .activity-badge { display: inline-flex; align-items: center; gap: 4px; background: #eef3ff; color: #2e69ff; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 4px; }
  .activity-badge.post-badge { background: #fef3c7; color: #92400e; }
  .activity-badge-icon { width: 12px; height: 12px; }
  .activity-time { font-size: 12px; color: #9ca3af; }
  .activity-heading { font-size: 16px; font-weight: 700; color: #111827; line-height: 1.4; margin: 0 0 6px; text-decoration: none; display: block; }
  .activity-heading:hover { color: #2e69ff; text-decoration: underline; }
  .activity-desc { font-size: 14px; color: #6b7280; line-height: 1.5; margin: 0 0 8px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .activity-meta { display: flex; gap: 16px; align-items: center; }
  .activity-meta-item { display: inline-flex; align-items: center; gap: 4px; font-size: 12px; color: #9ca3af; font-weight: 600; }
  .activity-meta-icon { width: 14px; height: 14px; }
  .no-activity { text-align: center; color: #9ca3af; padding: 50px 20px; }
  .no-activity-icon { width: 48px; height: 48px; color: #d1d5db; margin-bottom: 12px; }

  @media (max-width: 750px) {
    .sidebar-area { display: none; }
    .profile-main { width: 100%; }
    .profile-avatar-wrap { left: 16px; top: 70px; }
    .profile-avatar-letter, .profile-avatar-img { width: 80px; height: 80px; font-size: 32px; }
    .profile-info-area { padding: 50px 16px 16px; }
    .profile-stats-bar { flex-wrap: wrap; gap: 16px; }
  }
</style>

<script define:vars={{ name }}>
  const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbwfpjk3Y2gzDt0T_JS7c2OhQajr_UildmeqEgQVPQxIFAjYnYG8alaQF0XmGjeI-_uzkQ/exec";

  const feedContainer = document.getElementById("activity-feed");
  const tabQuestions = document.getElementById("tab-questions");
  const tabPosts = document.getElementById("tab-posts");

  let currentFilter = "Question";
  let allPosts = [];

  function getMediaUrl(url) {
    if (!url || url === "icon.png" || url === "null" || url === "") return "/assets/icon.png";
    if (url.startsWith("data:") || url.startsWith("http")) return url;
    if (url.startsWith("iVBOR") || url.startsWith("/9j/")) return `data:image/png;base64,${url}`;
    return `/assets/${url}`;
  }

  function timeAgo(dateStr) {
    if (!dateStr) return "Just now";
    try {
      const date = new Date(dateStr);
      if (isNaN(date.getTime())) return dateStr;
      const seconds = Math.floor((new Date().getTime() - date.getTime()) / 1000);
      if (seconds < 60) return "Just now";
      if (seconds < 3600) return Math.floor(seconds / 60) + "m ago";
      if (seconds < 86400) return Math.floor(seconds / 3600) + "h ago";
      if (seconds < 604800) return Math.floor(seconds / 86400) + "d ago";
      return date.toLocaleDateString();
    } catch (e) { return dateStr || "Just now"; }
  }

  // ===== LOAD USER PROFILE (3-TABLE SUPPORT) =====
  async function loadUserProfile() {
    try {
      const res = await fetch(`${SCRIPT_URL}?action=getUserByName&name=${encodeURIComponent(name)}`);
      const profile = await res.json();

      if (profile) {
        // 1. Avatar
        if (profile.avatar) {
          const letterEl = document.getElementById("profileAvatarLetter");
          const imgEl = document.getElementById("profileAvatarImg");
          if (imgEl && letterEl) {
            imgEl.src = getMediaUrl(profile.avatar);
            imgEl.style.display = "block";
            letterEl.style.display = "none";
          }
        }

        // 2. Username & Role
        document.getElementById("profileUsername").innerText = `@${profile.username || 'user'}`;
        document.getElementById("profileRole").innerText = profile.role || "Member";

        // 3. Bio (Beautiful Empty State)
        const bioEl = document.getElementById("profileBio");
        if (profile.bio && profile.bio.trim() !== "") {
          bioEl.innerText = profile.bio;
          bioEl.classList.remove("empty");
        } else {
          bioEl.innerText = "This user hasn't written a bio yet.";
          bioEl.classList.add("empty");
        }

        // 4. Details (Show only if they exist)
        if (profile.college) { document.getElementById("detailCollege").style.display = "flex"; document.getElementById("collegeText").innerText = profile.college; }
        if (profile.course) { document.getElementById("detailCourse").style.display = "flex"; document.getElementById("courseText").innerText = profile.course; }
        if (profile.location) { document.getElementById("detailLocation").style.display = "flex"; document.getElementById("locationText").innerText = profile.location; }

        // 5. Social Links
        const linksContainer = document.getElementById("pLinks");
        let linksHtml = "";
        if (profile.githubUrl) linksHtml += `<a href="${profile.githubUrl}" target="_blank" class="social-link">GitHub</a>`;
        if (profile.linkedinUrl) linksHtml += `<a href="${profile.linkedinUrl}" target="_blank" class="social-link">LinkedIn</a>`;
        if (profile.website) linksHtml += `<a href="${profile.website}" target="_blank" class="social-link">Website</a>`;
        linksContainer.innerHTML = linksHtml;

        // 6. Interests (Beautiful Empty State)
        const interestsEl = document.getElementById("pInterests");
        if (profile.interests && profile.interests.trim() !== "") {
          const interestArray = profile.interests.split(",").map(i => i.trim()).filter(Boolean);
          interestsEl.innerHTML = interestArray.map(i => `<span class="interest-chip">${i}</span>`).join("");
        } else {
          interestsEl.innerHTML = '<span class="interest-chip empty">No interests listed</span>';
        }
      }
    } catch (e) {
      console.error("Profile load error:", e);
    }
  }

  // ===== LOAD ACTIVITY =====
  async function loadActivity() {
    if (!feedContainer) return;

    feedContainer.innerHTML = `<div class="skel-activity"><div class="skel skel-badge"></div><div class="skel skel-heading"></div><div class="skel skel-line"></div><div class="skel skel-meta"></div></div>`;

    try {
      const response = await fetch(`${SCRIPT_URL}?action=getPosts&username=${encodeURIComponent(name)}`);
      const data = await response.json();
      allPosts = data || [];

      const questions = allPosts.filter((item) => item.type === "Question");
      const posts = allPosts.filter((item) => item.type !== "Question");
      const totalUp = allPosts.reduce((sum, p) => sum + (p.upvotes || 0), 0);

      document.getElementById("questionCount").textContent = questions.length;
      document.getElementById("postCount").textContent = posts.length;
      document.getElementById("totalUpvotes").textContent = totalUp;

      renderFeed();
    } catch (error) {
      feedContainer.innerHTML = `<div class="no-activity"><p>Failed to load activity.</p></div>`;
    }
  }

  function renderFeed() {
    const filtered = allPosts.filter((item) => item.type === currentFilter);

    if (filtered.length === 0) {
      const typeLabel = currentFilter === "Question" ? "questions" : "posts";
      feedContainer.innerHTML = `<div class="no-activity"><p>No ${typeLabel} found for ${name}.</p></div>`;
      return;
    }

    feedContainer.innerHTML = filtered.map((item) => {
      const slug = item.slug || item.heading.toLowerCase().replace(/[^\w -]+/g, "").replace(/ +/g, "-");
      const isQuestion = item.type === "Question";
      const badgeClass = isQuestion ? "" : "post-badge";
      const timeDisplay = timeAgo(item.updated_time || item.created_at);
      let descPreview = item.description || "";
      if (descPreview.length > 150) descPreview = descPreview.substring(0, 150) + "...";

      return `
        <div class="activity-item">
          <div class="activity-item-top">
            <span class="activity-badge ${badgeClass}">${item.type}</span>
            <span class="activity-time">${timeDisplay}</span>
          </div>
          <a href="/question/${slug}" class="activity-heading">${item.heading}</a>
          ${descPreview ? `<p class="activity-desc">${descPreview}</p>` : ""}
          <div class="activity-meta">
            <span class="activity-meta-item">▲ ${item.upvotes || 0}</span>
            <span class="activity-meta-item">💬 ${item.comments || 0}</span>
          </div>
        </div>`;
    }).join("");
  }

  tabQuestions?.addEventListener("click", () => { currentFilter = "Question"; tabQuestions.classList.add("active"); tabPosts?.classList.remove("active"); renderFeed(); });
  tabPosts?.addEventListener("click", () => { currentFilter = "Post"; tabPosts.classList.add("active"); tabQuestions?.classList.remove("active"); renderFeed(); });

  loadUserProfile();
  loadActivity();
</script>