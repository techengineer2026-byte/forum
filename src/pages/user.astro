---
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/Sidebar.astro";

const name = Astro.url.searchParams.get("name") || "Guest";
---

<Layout title={`${name}'s Profile - TechEngineer`}>
  <div class="profile-page-layout">
    <aside class="sidebar-area">
      <Sidebar />
    </aside>

    <main class="profile-main">
      <!-- PROFILE HEADER -->
      <div class="profile-header">
        <div class="profile-avatar-letter" id="profileAvatarLetter">
          {name?.charAt(0).toUpperCase()}
        </div>
        <img
          id="profileAvatarImg"
          class="profile-avatar-img"
          style="display:none"
          alt={name}
        />
        <div class="profile-info">
          <h1 class="profile-name">{name}</h1>
          <p class="profile-role" id="profileRole">
            Member of TechEngineer Forum
          </p>
        </div>
      </div>

      <!-- STATS BAR -->
      <div class="profile-stats-bar">
        <div class="pstat">
          <svg
            class="pstat-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><circle cx="12" cy="12" r="10"></circle><path
              d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"></path><line
              x1="12"
              y1="17"
              x2="12.01"
              y2="17"></line></svg
          >
          <span id="questionCount">0</span> Questions
        </div>
        <div class="pstat">
          <svg
            class="pstat-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"
            ></path><polyline points="14 2 14 8 20 8"></polyline><line
              x1="16"
              y1="13"
              x2="8"
              y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg
          >
          <span id="postCount">0</span> Posts
        </div>
        <div class="pstat">
          <svg
            class="pstat-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"></path></svg
          >
          <span id="totalUpvotes">0</span> Upvotes
        </div>
      </div>

      <!-- TABS -->
      <div class="tabs">
        <button class="tab active" id="tab-questions">
          <svg
            class="tab-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><circle cx="12" cy="12" r="10"></circle><path
              d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"></path><line
              x1="12"
              y1="17"
              x2="12.01"
              y2="17"></line></svg
          >
          Questions
        </button>
        <button class="tab" id="tab-posts">
          <svg
            class="tab-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"
            ></path><polyline points="14 2 14 8 20 8"></polyline></svg
          >
          Posts
        </button>
      </div>

      <!-- ACTIVITY FEED -->
      <div id="activity-feed" class="activity-feed">
        <div class="skel-activity">
          <div class="skel skel-badge"></div>
          <div class="skel skel-heading"></div>
          <div class="skel skel-line"></div>
          <div class="skel skel-meta"></div>
        </div>
        <div class="skel-activity">
          <div class="skel skel-badge" style="width:40px"></div>
          <div class="skel skel-heading" style="width:65%"></div>
          <div class="skel skel-line" style="width:90%"></div>
          <div class="skel skel-meta" style="width:40%"></div>
        </div>
        <div class="skel-activity">
          <div class="skel skel-badge" style="width:35px"></div>
          <div class="skel skel-heading" style="width:75%"></div>
          <div class="skel skel-line" style="width:80%"></div>
          <div class="skel skel-meta" style="width:50%"></div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style is:global>
  /* ===== SKELETON ===== */
  .skel {
    background: linear-gradient(90deg, #e5e7eb 25%, #f3f4f6 50%, #e5e7eb 75%);
    background-size: 200% 100%;
    animation: skelPulse 1.5s ease-in-out infinite;
    border-radius: 4px;
  }
  @keyframes skelPulse {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }
  .skel-activity {
    padding: 16px 8px;
    border-bottom: 1px solid #f5f5f5;
  }
  .skel-badge {
    width: 55px;
    height: 20px;
    margin-bottom: 10px;
  }
  .skel-heading {
    width: 80%;
    height: 18px;
    margin-bottom: 8px;
  }
  .skel-line {
    width: 100%;
    height: 13px;
    margin-bottom: 8px;
  }
  .skel-meta {
    width: 45%;
    height: 12px;
  }

  /* ===== LAYOUT ===== */
  .profile-page-layout {
    display: flex;
    justify-content: center;
    gap: 24px;
    padding: 20px;
    background-color: #f1f2f2;
    min-height: 100vh;
    align-items: flex-start;
  }
  .sidebar-area {
    width: 160px;
    position: sticky;
    top: 80px;
    height: fit-content;
  }
  .profile-main {
    width: 580px;
    max-width: 100%;
  }

  /* ===== HEADER ===== */
  .profile-header {
    background: #ffffff;
    border: 1px solid #e3e6ea;
    border-radius: 12px;
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 12px;
  }
  .profile-avatar-letter {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, #b92b27, #d94440);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 30px;
    font-weight: 800;
    flex-shrink: 0;
  }
  .profile-avatar-img {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 3px solid #e3e6ea;
  }
  .profile-info {
    flex: 1;
    min-width: 0;
  }
  .profile-name {
    font-size: 24px;
    font-weight: 800;
    margin: 0 0 4px;
    color: #111827;
  }
  .profile-role {
    margin: 0;
    color: #6b7280;
    font-size: 14px;
  }

  /* ===== STATS BAR ===== */
  .profile-stats-bar {
    background: #ffffff;
    border: 1px solid #e3e6ea;
    border-radius: 12px;
    padding: 16px 20px;
    display: flex;
    gap: 24px;
    margin-bottom: 12px;
  }
  .pstat {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 600;
    color: #374151;
  }
  .pstat-icon {
    width: 18px;
    height: 18px;
    color: #6b7280;
  }
  .pstat span {
    color: #111827;
    font-weight: 800;
  }

  /* ===== TABS ===== */
  .tabs {
    display: flex;
    background: #ffffff;
    border: 1px solid #e3e6ea;
    border-radius: 12px 12px 0 0;
    border-bottom: none;
  }
  .tab {
    flex: 1;
    padding: 14px;
    background: none;
    border: none;
    font-weight: 700;
    font-size: 14px;
    color: #6b7280;
    cursor: pointer;
    border-bottom: 3px solid transparent;
    transition:
      color 0.2s,
      border-color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .tab:hover {
    color: #111827;
  }
  .tab.active {
    color: #2e69ff;
    border-bottom-color: #2e69ff;
  }
  .tab-icon {
    width: 16px;
    height: 16px;
  }

  /* ===== ACTIVITY FEED ===== */
  .activity-feed {
    background: #ffffff;
    border: 1px solid #e3e6ea;
    border-radius: 0 0 12px 12px;
    padding: 4px 12px;
    min-height: 200px;
  }
  .activity-item {
    padding: 16px 8px;
    border-bottom: 1px solid #f3f4f6;
    transition: background 0.15s;
  }
  .activity-item:last-child {
    border-bottom: none;
  }
  .activity-item:hover {
    background: #fafbfc;
  }
  .activity-item-top {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }
  .activity-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: #eef3ff;
    color: #2e69ff;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 4px;
  }
  .activity-badge.post-badge {
    background: #fef3c7;
    color: #92400e;
  }
  .activity-badge-icon {
    width: 12px;
    height: 12px;
  }
  .activity-time {
    font-size: 12px;
    color: #9ca3af;
  }
  .activity-heading {
    font-size: 16px;
    font-weight: 700;
    color: #111827;
    line-height: 1.4;
    margin: 0 0 6px;
    text-decoration: none;
    display: block;
  }
  .activity-heading:hover {
    color: #2e69ff;
    text-decoration: underline;
  }
  .activity-desc {
    font-size: 14px;
    color: #6b7280;
    line-height: 1.5;
    margin: 0 0 8px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .activity-meta {
    display: flex;
    gap: 16px;
    align-items: center;
  }
  .activity-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: #9ca3af;
    font-weight: 600;
  }
  .activity-meta-icon {
    width: 14px;
    height: 14px;
  }
  .no-activity {
    text-align: center;
    color: #9ca3af;
    padding: 50px 20px;
  }
  .no-activity-icon {
    width: 48px;
    height: 48px;
    color: #d1d5db;
    margin-bottom: 12px;
  }

  @media (max-width: 750px) {
    .sidebar-area {
      display: none;
    }
    .profile-main {
      width: 100%;
    }
    .profile-stats-bar {
      flex-wrap: wrap;
      gap: 16px;
    }
  }
</style>

<script define:vars={{ name }}>
  const SCRIPT_URL =
    "https://script.google.com/macros/s/AKfycbwfpjk3Y2gzDt0T_JS7c2OhQajr_UildmeqEgQVPQxIFAjYnYG8alaQF0XmGjeI-_uzkQ/exec";

  const feedContainer = document.getElementById("activity-feed");
  const tabQuestions = document.getElementById("tab-questions");
  const tabPosts = document.getElementById("tab-posts");

  let currentFilter = "Question";
  let allPosts = [];

  // ===== HELPERS =====
  function getMediaUrl(url) {
    if (!url || url === "icon.png" || url === "null" || url === "")
      return "/assets/icon.png";
    if (url.startsWith("data:")) return url;
    if (url.startsWith("http://") || url.startsWith("https://")) return url;
    if (url.startsWith("iVBOR") || url.startsWith("/9j/"))
      return `data:image/png;base64,${url}`;
    return `/assets/${url}`;
  }

  function timeAgo(dateStr) {
    if (!dateStr) return "Just now";
    try {
      const date = new Date(dateStr);
      if (isNaN(date.getTime())) return dateStr;
      const seconds = Math.floor(
        (new Date().getTime() - date.getTime()) / 1000,
      );
      if (seconds < 60) return "Just now";
      if (seconds < 3600) return Math.floor(seconds / 60) + "m ago";
      if (seconds < 86400) return Math.floor(seconds / 3600) + "h ago";
      if (seconds < 604800) return Math.floor(seconds / 86400) + "d ago";
      return date.toLocaleDateString();
    } catch (e) {
      return dateStr || "Just now";
    }
  }

  // ===== LOAD USER PROFILE =====
  async function loadUserProfile() {
    try {
      const res = await fetch(
        `${SCRIPT_URL}?action=getUserByName&name=${encodeURIComponent(name)}`,
      );
      const profile = await res.json();

      if (profile && profile.avatar) {
        const letterEl = document.getElementById("profileAvatarLetter");
        const imgEl = document.getElementById("profileAvatarImg");
        if (imgEl && letterEl) {
          imgEl.src = getMediaUrl(profile.avatar);
          imgEl.style.display = "block";
          letterEl.style.display = "none";
        }
      }

      if (profile && profile.role) {
        const roleEl = document.getElementById("profileRole");
        if (roleEl) roleEl.textContent = profile.role;
      }

      if (profile && profile.interests) {
        const roleEl = document.getElementById("profileRole");
        if (roleEl && profile.role) {
          roleEl.textContent = profile.role + " · " + profile.interests;
        }
      }
    } catch (e) {
      // Profile not found - keep letter avatar
    }
  }

  // ===== LOAD ACTIVITY =====
  async function loadActivity() {
    if (!feedContainer) return;

    // Show skeleton
    feedContainer.innerHTML = `
            <div class="skel-activity">
                <div class="skel skel-badge"></div>
                <div class="skel skel-heading"></div>
                <div class="skel skel-line"></div>
                <div class="skel skel-meta"></div>
            </div>
            <div class="skel-activity">
                <div class="skel skel-badge" style="width:40px"></div>
                <div class="skel skel-heading" style="width:65%"></div>
                <div class="skel skel-line" style="width:90%"></div>
                <div class="skel skel-meta" style="width:40%"></div>
            </div>
        `;

    try {
      const response = await fetch(
        `${SCRIPT_URL}?action=getPosts&username=${encodeURIComponent(name)}`,
      );
      const data = await response.json();
      allPosts = data || [];

      // Update stats
      const questions = allPosts.filter((item) => item.type === "Question");
      const posts = allPosts.filter((item) => item.type !== "Question");
      const totalUp = allPosts.reduce((sum, p) => sum + (p.upvotes || 0), 0);

      document.getElementById("questionCount").textContent = questions.length;
      document.getElementById("postCount").textContent = posts.length;
      document.getElementById("totalUpvotes").textContent = totalUp;

      renderFeed();
    } catch (error) {
      console.error("Error fetching activity:", error);
      feedContainer.innerHTML = `
                <div class="no-activity">
                    <svg class="no-activity-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    <p>Failed to load activity. Please try again.</p>
                </div>
            `;
    }
  }

  function renderFeed() {
    const filtered = allPosts.filter((item) => item.type === currentFilter);

    if (filtered.length === 0) {
      const typeLabel = currentFilter === "Question" ? "questions" : "posts";
      feedContainer.innerHTML = `
                <div class="no-activity">
                    <svg class="no-activity-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                    </svg>
                    <p>No ${typeLabel} found for ${name}.</p>
                </div>
            `;
      return;
    }

    feedContainer.innerHTML = filtered
      .map((item) => {
        const slug =
          item.slug ||
          item.heading
            .toLowerCase()
            .replace(/[^\w -]+/g, "")
            .replace(/ +/g, "-");
        const isQuestion = item.type === "Question";
        const badgeClass = isQuestion ? "" : "post-badge";
        const badgeIcon = isQuestion
          ? '<svg class="activity-badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>'
          : '<svg class="activity-badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>';

        const timeDisplay = timeAgo(item.updated_time || item.created_at);

        // Truncate description for preview
        let descPreview = item.description || "";
        if (descPreview.length > 150)
          descPreview = descPreview.substring(0, 150) + "...";

        return `
                <div class="activity-item">
                    <div class="activity-item-top">
                        <span class="activity-badge ${badgeClass}">${badgeIcon} ${item.type}</span>
                        <span class="activity-time">${timeDisplay}</span>
                    </div>
                    <a href="/question/${slug}" class="activity-heading">${item.heading}</a>
                    ${descPreview ? `<p class="activity-desc">${descPreview}</p>` : ""}
                    <div class="activity-meta">
                        <span class="activity-meta-item">
                            <svg class="activity-meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
                            ${item.upvotes || 0}
                        </span>
                        <span class="activity-meta-item">
                            <svg class="activity-meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                            ${item.comments || 0}
                        </span>
                    </div>
                </div>
                `;
      })
      .join("");
  }

  // ===== TAB LISTENERS =====
  tabQuestions?.addEventListener("click", () => {
    currentFilter = "Question";
    tabQuestions.classList.add("active");
    tabPosts?.classList.remove("active");
    renderFeed();
  });

  tabPosts?.addEventListener("click", () => {
    currentFilter = "Post";
    tabPosts.classList.add("active");
    tabQuestions?.classList.remove("active");
    renderFeed();
  });

  // ===== START =====
  loadUserProfile();
  loadActivity();
</script>
    