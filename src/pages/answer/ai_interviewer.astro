---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="AI Interviewer - Tech Engineer" showFooter={false}>
    <div class="page-layout">
        <!-- LEFT SIDEBAR -->
        <aside class="sidebar-area">
            <div class="sticky-wrapper">
                <p class="nav-title">Questions</p>
                <ul class="nav-list">
                    <li><a href="/answer">Questions for you</a></li>
                    <li><a href="/answer/requests">Answer requests</a></li>
                    <li><a href="/answer/drafts">Drafts</a></li>
                    <li class="active">
                        <a href="/answer/ai_interviewer">AI Interviewer</a>
                    </li>
                </ul>
            </div>
        </aside>

        <!-- CENTER FEED -->
        <main class="feed-area">
            <!-- TOP BOX: AI INTERVIEWER TOOL -->
            <div class="tool-box">
                <h3>AI Interviewer</h3>
                <p>
                    This tool asks personalized questions based on your Quora
                    credentials and previous answers, to help you share your
                    knowledge and experience.
                </p>
                <div class="tool-actions">
                    <button class="blue-btn-small">Get questions</button>
                    <button class="outline-btn-small"
                        >+ Customize questions</button
                    >
                </div>
            </div>

            <!-- CENTER CONTENT: EMPTY STATE -->
            <div class="empty-state">
                <div class="person-icon">
                    <svg
                        width="48"
                        height="48"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="#939598"
                        stroke-width="1.5"
                    >
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
                        ></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <line x1="19" y1="8" x2="19" y2="14"></line>
                        <line x1="22" y1="11" x2="16" y2="11"></line>
                    </svg>
                </div>

                <h2>We don't know enough about you yet</h2>
                <p>
                    Add credentials to get personalized questions in one tap.
                    Or, try it out by using 'Customize questions' above to guide
                    your questions.
                </p>

                <button class="large-blue-btn">Add credentials</button>
            </div>
        </main>
    </div>
</Layout>

<style>
    .page-layout {
        display: flex;
        justify-content: center;
        gap: 24px; /* Standard Gap */
        padding: 20px;
        background-color: #f1f2f2;
        min-height: 100vh;
        align-items: flex-start;
        max-width: 1100px; /* Standard Page Width */
        margin: 0 auto;
    }
    .sidebar-area {
        width: 160px; /* Standard Left Sidebar */
        flex-shrink: 0;
    }

    .feed-area {
        width: 580px; /* Standard Feed Width */
        flex-shrink: 0;
    }

    .right-column {
        width: 300px; /* Standard Right Sidebar Space */
        flex-shrink: 0;
    }
    .sticky-wrapper {
        position: sticky;
        top: 70px;
        height: fit-content;
    }
    .nav-title {
        font-weight: bold;
        font-size: 15px;
        border-bottom: 1px solid #ddd;
        padding-bottom: 8px;
        margin-bottom: 10px;
    }
    .nav-list {
        list-style: none;
        padding: 0;
    }
    .nav-list li {
        padding: 8px;
        border-radius: 4px;
        margin-bottom: 2px;
    }
    .nav-list li a {
        text-decoration: none;
        color: #636466;
        font-size: 14px;
        display: block;
    }
    .nav-list li.active {
        background-color: #f7e8e8;
    }
    .nav-list li.active a {
        color: #b92b27;
        font-weight: bold;
    }

    /* Top Tool Box */
    .tool-box {
        background: white;
        border: 1px solid #dee0e1;
        border-radius: 4px;
        padding: 20px;
        margin-bottom: 30px;
    }
    .tool-box h3 {
        margin: 0 0 10px 0;
        font-size: 16px;
        color: #333;
    }
    .tool-box p {
        font-size: 14px;
        color: #666;
        line-height: 1.5;
        margin-bottom: 20px;
    }

    .tool-actions {
        display: flex;
        gap: 10px;
    }
    .blue-btn-small {
        background: #9bb7ff;
        color: white;
        border: none;
        padding: 8px 20px;
        border-radius: 20px;
        font-weight: bold;
        cursor: pointer;
    }
    .outline-btn-small {
        background: white;
        border: 1px solid #ddd;
        color: #666;
        padding: 8px 20px;
        border-radius: 20px;
        font-weight: bold;
        cursor: pointer;
    }

    /* Bottom Empty State */
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding-top: 20px;
    }
    .person-icon {
        margin-bottom: 15px;
    }
    .empty-state h2 {
        font-size: 18px;
        color: #333;
        margin-bottom: 10px;
        font-weight: bold;
    }
    .empty-state p {
        font-size: 15px;
        color: #666;
        line-height: 1.4;
        max-width: 450px;
        margin-bottom: 25px;
    }

    .large-blue-btn {
        background-color: #2e69ff;
        color: white;
        border: none;
        padding: 12px 0;
        width: 100%;
        max-width: 450px;
        border-radius: 24px;
        font-weight: bold;
        font-size: 14px;
        cursor: pointer;
    }
</style>
