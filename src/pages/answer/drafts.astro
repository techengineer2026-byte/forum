---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Drafts - Tech Engineer" showFooter={false}>
  <div class="page-layout">
    <aside class="sidebar-area">
      <div class="sticky-wrapper">
        <p class="nav-title">Questions</p>
        <ul class="nav-list">
          <li><a href="/answer">Questions for you</a></li>
          <li><a href="/answer/requests">Answer requests</a></li>
          <li class="active"><a href="/answer/drafts">Drafts</a></li>
          <li><a href="/answer/ai_interviewer">AI Interviewer</a></li>
        </ul>
      </div>
    </aside>
    <main class="feed-area">
      <div class="feed-header">
        <span class="star-icon">📝</span>
        <span>Your Drafts</span>
      </div>
      <div class="empty-state">
        <div class="empty-icon">📄</div>
        <h3>No Drafts</h3>
        <p>
          When you start writing an answer and save it as a draft, it will
          appear here.
        </p>
        <a href="/answer" class="ask-btn">Browse Questions</a>
      </div>
    </main>
    <aside class="right-column"></aside>
  </div>
</Layout>

<style>
  .page-layout {
    display: flex;
    justify-content: center;
    gap: 30px;
    max-width: 1100px;
    margin: 0 auto;
    padding: 30px 15px;
    align-items: flex-start;
  }
  .sticky-wrapper {
    position: sticky;
    top: 70px;
  }
  .sidebar-area {
    width: 160px;
  }
  .nav-title {
    font-weight: bold;
    font-size: 15px;
    border-bottom: 1px solid #ddd;
    padding-bottom: 8px;
    margin-bottom: 10px;
  }
  .nav-list {
    list-style: none;
    padding: 0;
  }
  .nav-list li {
    padding: 8px;
    border-radius: 4px;
    margin-bottom: 2px;
  }
  .nav-list li a {
    text-decoration: none;
    color: #636466;
    font-size: 14px;
    display: block;
  }
  .nav-list li.active {
    background-color: #f7e8e8;
  }
  .nav-list li.active a {
    color: #b92b27;
    font-weight: bold;
  }
  .nav-list li:hover:not(.active) {
    background-color: #e6e6e6;
  }
  .feed-area {
    width: 580px;
  }
  .feed-header {
    padding: 12px 15px;
    border-bottom: 1px solid #dee0e1;
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: bold;
    color: #333;
    background: white;
    border-radius: 8px 8px 0 0;
  }
  .star-icon {
    font-size: 18px;
  }
  .empty-state {
    text-align: center;
    padding: 60px 20px;
    color: #939598;
    border: 1px solid #dee0e1;
    border-top: none;
    border-radius: 0 0 8px 8px;
    background: white;
  }
  .empty-icon {
    font-size: 40px;
    margin-bottom: 12px;
  }
  .empty-state h3 {
    font-size: 18px;
    color: #636466;
    margin: 0 0 8px;
  }
  .empty-state p {
    font-size: 14px;
    margin: 0 0 16px;
  }
  .ask-btn {
    display: inline-block;
    background: #2e69ff;
    color: white;
    padding: 9px 22px;
    border-radius: 20px;
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
  }
  .right-column {
    width: 280px;
  }
</style>
