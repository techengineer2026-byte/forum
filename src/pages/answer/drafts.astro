---
import Layout from "../../layouts/Layout.astro";
---

<!-- No footer for this page -->
<Layout title="Drafts - Tech Engineer" showFooter={false}>
    <div class="page-layout">
        <!-- LEFT SIDEBAR -->
        <aside class="sidebar-area">
            <div class="sticky-wrapper">
                <p class="nav-title">Questions</p>
                <ul class="nav-list">
                    <li><a href="/answer">Questions for you</a></li>
                    <li><a href="/answer/requests">Answer requests</a></li>
                    <li class="active"><a href="/answer/drafts">Drafts</a></li>
                    <li><a href="/answer/ai_interviewer">AI Interviewer</a></li>
                </ul>
            </div>
        </aside>

        <!-- CENTER FEED (Empty State for Drafts) -->
        <main class="feed-area">
            <div class="empty-state">
                <!-- Mailbox Icon -->
                <div class="mailbox-icon">
                    <svg
                        width="120"
                        height="120"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="#ccc"
                        stroke-width="0.5"
                    >
                        <path
                            d="M22 13V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v12c0 1.1.9 2 2 2h8"
                        ></path>
                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
                        ></path>
                        <path d="M19 16v6"></path>
                        <path d="M16 19h6"></path>
                    </svg>
                </div>

                <h2>No answer drafts</h2>
                <p>
                    Start writing answers by finding questions to answer in
                    Questions for You.
                </p>

                <a href="/answer" class="blue-btn">See questions for you</a>
            </div>
        </main>

        <!-- RIGHT SIDEBAR -->
        <aside class="right-column">
            <div class="sticky-wrapper">
                <div class="topic-box">
                    <h3>Add topics you know about</h3>
                    <p>
                        Adding topics helps us find questions for you to answer
                    </p>
                    <button class="outline-btn">Add topics</button>
                </div>
            </div>
        </aside>
    </div>
</Layout>

<style>
    .page-layout {
        display: flex;
        justify-content: center;
        gap: 30px;
        max-width: 1100px;
        margin: 0 auto;
        padding: 30px 15px;
        align-items: flex-start; /* Required for sticky */
    }

    .sticky-wrapper {
        position: sticky;
        top: 70px;
        height: fit-content;
    }

    /* LEFT NAV */
    .sidebar-area {
        width: 160px;
    }
    .nav-title {
        font-weight: bold;
        font-size: 15px;
        border-bottom: 1px solid #ddd;
        padding-bottom: 8px;
        margin-bottom: 10px;
    }
    .nav-list {
        list-style: none;
        padding: 0;
    }
    .nav-list li {
        padding: 8px;
        border-radius: 4px;
        margin-bottom: 2px;
    }
    .nav-list li a {
        text-decoration: none;
        color: #636466;
        font-size: 14px;
        display: block;
    }

    /* Drafts active state (Pink background, Red text) */
    .nav-list li.active {
        background-color: #f7e8e8;
    }
    .nav-list li.active a {
        color: #b92b27;
        font-weight: bold;
    }
    .nav-list li:hover:not(.active) {
        background-color: #e6e6e6;
    }

    /* CENTER AREA */
    .feed-area {
        flex: 1;
        max-width: 580px;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 60px;
    }
    .mailbox-icon {
        margin-bottom: 20px;
        opacity: 0.6;
    }

    .empty-state {
        text-align: center;
    }
    .empty-state h2 {
        font-size: 18px;
        color: #333;
        margin-bottom: 10px;
        font-weight: bold;
    }
    .empty-state p {
        font-size: 15px;
        color: #666;
        line-height: 1.4;
        margin-bottom: 25px;
    }

    .blue-btn {
        background-color: #2e69ff;
        color: white;
        text-decoration: none;
        padding: 10px 30px;
        border-radius: 24px;
        font-weight: bold;
        font-size: 14px;
        display: inline-block;
        transition: background 0.2s;
    }
    .blue-btn:hover {
        background-color: #1a54e6;
    }

    /* RIGHT SIDEBAR */
    .right-column {
        width: 220px;
    }
    .topic-box {
        background: white;
        border: 1px solid #dee0e1;
        padding: 16px;
        border-radius: 8px;
    }
    .topic-box h3 {
        font-size: 14px;
        margin: 0 0 8px 0;
        color: #333;
    }
    .topic-box p {
        font-size: 13px;
        color: #666;
        margin-bottom: 15px;
        line-height: 1.4;
    }

    .outline-btn {
        background: none;
        border: 1px solid #2e69ff;
        color: #2e69ff;
        padding: 6px 20px;
        border-radius: 20px;
        font-weight: bold;
        cursor: pointer;
        font-size: 13px;
        width: 100%;
    }
    .outline-btn:hover {
        background-color: #f0f5ff;
    }
</style>
