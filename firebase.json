{
  "hosting": {
    "public": "dist",
    "clean": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/question/**",
        "destination": "/question/index.html"
      },
      {
        "source": "/space/**",
        "destination": "/space/index.html"
      }
    ]
  }
}